<!DOCTYPE html>
<html lang="fr">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>Dépôt - Altiora Capital Africa</title>
    <link href="https://fonts.googleapis.com/css2?family=Poppins:wght@300;400;500;600;700;800&display=swap" rel="stylesheet">
    <link rel="stylesheet" href="https://cdnjs.cloudflare.com/ajax/libs/font-awesome/6.5.0/css/all.min.css">
    <style>
        * { margin:0; padding:0; box-sizing:border-box; font-family:'Poppins','Segoe UI',sans-serif; }
        body { background:#F5EFE6; color:#3D2B1F; min-height:100vh; padding-bottom:90px; }
        .container { max-width:430px; margin:0 auto; }

        .page-header {
            background: linear-gradient(135deg, #D4921F, #A0631A);
            padding: 50px 20px 28px; color:#fff;
            display:flex; align-items:center; gap:14px;
        }
        .back-btn {
            width:36px; height:36px; border-radius:50%;
            background:rgba(255,255,255,0.2); display:flex; align-items:center;
            justify-content:center; color:#fff; text-decoration:none; font-size:16px; flex-shrink:0;
        }
        .header-text h1 { font-size:20px; font-weight:700; }
        .header-text p { font-size:13px; color:rgba(255,255,255,0.85); margin-top:2px; }

        .content { padding:16px; }

        .info-card {
            background:#FFFBF0; border:1px solid #F5D78A; border-radius:14px;
            padding:14px 16px; margin-bottom:16px;
        }
        .info-card h3 { color:#A0631A; font-size:13px; font-weight:700; margin-bottom:8px;
            display:flex; align-items:center; gap:7px; }
        .info-card li {
            font-size:12px; color:#7D5A38; margin-bottom:4px;
            padding-left:18px; position:relative; list-style:none;
        }
        .info-card li::before { content:'✓'; position:absolute; left:0; color:#C47D1E; font-weight:700; }

        .alert-box {
            border-radius:12px; padding:13px 16px; margin-bottom:16px;
            font-size:14px; display:flex; align-items:center; gap:10px;
        }
        .alert-error { background:#FFF0EE; border:1px solid #F5A9A0; color:#C0392B; }
        .alert-success { background:#F0FFF4; border:1px solid #86EFAC; color:#166534; }

        .form-card {
            background:#fff; border-radius:18px; padding:22px 18px;
            margin-bottom:14px; box-shadow:0 4px 16px rgba(196,125,30,0.10);
            border:1px solid #F0E0C8;
        }
        .form-group { margin-bottom:16px; }
        .form-label {
            display:flex; align-items:center; gap:8px;
            color:#7D5A38; font-size:13px; font-weight:600; margin-bottom:8px;
        }
        .form-label i { color:#C47D1E; }
        .form-input {
            width:100%; background:#FBF5EC; border:1.5px solid #E8D5B0;
            border-radius:12px; padding:13px 15px; color:#3D2B1F; font-size:14px;
            font-family:'Poppins',sans-serif; outline:none; transition:border-color 0.2s;
        }
        .form-input:focus { border-color:#C47D1E; box-shadow:0 0 0 3px rgba(196,125,30,0.12); }
        .form-input option { background:#fff; color:#3D2B1F; }
        .btn-submit {
            width:100%; background:linear-gradient(135deg,#D4921F,#B07018);
            color:#fff; border:none; border-radius:14px; padding:16px;
            font-size:16px; font-weight:700; cursor:pointer; margin-top:8px;
            box-shadow:0 6px 18px rgba(196,125,30,0.38); transition:transform 0.2s;
            font-family:'Poppins',sans-serif;
        }
        .btn-submit:hover { transform:translateY(-2px); }
        .btn-submit:disabled { background:#E8D5B0; cursor:not-allowed; transform:none; }

        .loading-wrap { display:none; text-align:center; padding:24px; }
        .spinner {
            width:44px; height:44px; margin:0 auto 12px;
            border:4px solid #F0E0C8; border-top-color:#C47D1E;
            border-radius:50%; animation:spin 1s linear infinite;
        }
        @keyframes spin { to { transform:rotate(360deg); } }
        .loading-wrap p { color:#A87D50; font-size:14px; }
    </style>
</head>
<body>
<%- include('partials/menu', { page: 'compte' }) %>
<div class="container">
    <div class="page-header">
        <a href="/" class="back-btn"><i class="fas fa-chevron-left"></i></a>
        <div class="header-text">
            <h1>Effectuer un Dépôt</h1>
            <p>Rechargez votre compte en toute sécurité</p>
        </div>
    </div>

    <div class="content">
        <div class="info-card">
            <h3><i class="fas fa-info-circle"></i> Informations importantes</h3>
            <ul>
                <li>Le montant sera crédité instantanément</li>
                <li>Transaction sécurisée</li>
                <li>Aucun frais supplémentaire</li>
            </ul>
        </div>

        <% if (locals.error) { %>
            <div class="alert-box alert-error"><i class="fas fa-exclamation-circle"></i> <%= error %></div>
        <% } %>
        <% if (locals.success) { %>
            <div class="alert-box alert-success"><i class="fas fa-check-circle"></i> <%= success %></div>
        <% } %>

        <div class="form-card">
            <form id="depotForm" method="POST" action="/depot/process">
                <div class="form-group">
                    <label class="form-label"><i class="fas fa-money-bill-wave"></i> Montant du dépôt</label>
                    <input type="number" name="montant" id="montant" min="200" step="100" required
                           placeholder="Entrez le montant" class="form-input">
                </div>
                <div class="form-group">
                    <label class="form-label"><i class="fas fa-globe"></i> Pays</label>
                    <select name="pays" id="pays" required class="form-input">
                        <option value="">Sélectionnez votre pays</option>
                        <% Object.entries(pays_operateurs).forEach(([pays, data]) => { %>
                            <option value="<%= pays %>"
                                    data-currency="<%= data.currency %>"
                                    data-operators='<%= JSON.stringify(data.operators) %>'>
                                <%= pays %>
                            </option>
                        <% }) %>
                    </select>
                </div>
                <div class="form-group">
                    <label class="form-label"><i class="fas fa-mobile-alt"></i> Opérateur</label>
                    <select name="operateur" id="operateur" required disabled class="form-input">
                        <option value="">Sélectionnez d'abord un pays</option>
                    </select>
                </div>
                <div class="form-group">
                    <label class="form-label"><i class="fas fa-envelope"></i> Adresse email</label>
                    <input type="email" name="email" id="email" required
                           placeholder="votre@email.com" class="form-input"
                           value="<%= locals.user ? user.email : '' %>">
                </div>
                <div class="form-group">
                    <label class="form-label"><i class="fas fa-phone"></i> Numéro de téléphone</label>
                    <input type="tel" name="numero" id="numero" required
                           placeholder="Ex: 690000001" pattern="[0-9]{6,15}" class="form-input">
                </div>
                <button type="submit" class="btn-submit" id="submitBtn">
                    <i class="fas fa-lock"></i> Confirmer le paiement
                </button>
            </form>
            <div class="loading-wrap" id="loadingDiv">
                <div class="spinner"></div>
                <p>Traitement du paiement en cours...</p>
            </div>
        </div>
    </div>
</div>

<script>
const paysSelect = document.getElementById('pays');
const operateurSelect = document.getElementById('operateur');
paysSelect.addEventListener('change', function() {
    operateurSelect.innerHTML = '<option value="">Sélectionnez un opérateur</option>';
    if (this.value) {
        const selectedOption = this.options[this.selectedIndex];
        const operators = JSON.parse(selectedOption.dataset.operators);
        operateurSelect.disabled = false;
        for (const [serviceId, operatorName] of Object.entries(operators)) {
            const option = document.createElement('option');
            option.value = serviceId; option.textContent = operatorName;
            operateurSelect.appendChild(option);
        }
    } else { operateurSelect.disabled = true; }
});
document.getElementById('depotForm').addEventListener('submit', function() {
    document.getElementById('submitBtn').disabled = true;
    document.getElementById('submitBtn').innerHTML = '<i class="fas fa-spinner fa-spin"></i> Traitement en cours...';
});
</script>
</body>
</html>
