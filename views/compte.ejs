<!DOCTYPE html>
<html lang="fr">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0, maximum-scale=1.0, user-scalable=no">
    <title>Profil - Altiora Capital Africa</title>
    <link href="https://fonts.googleapis.com/css2?family=Poppins:wght@300;400;500;600;700;800&display=swap" rel="stylesheet">
    <link rel="stylesheet" href="https://cdnjs.cloudflare.com/ajax/libs/font-awesome/6.5.0/css/all.min.css">
    <style>
        * { margin:0; padding:0; box-sizing:border-box; font-family:'Poppins','Segoe UI',sans-serif; -webkit-tap-highlight-color:transparent; }
        body { background:#F5EFE6; color:#3D2B1F; min-height:100vh; padding-bottom:90px; }
        .container { max-width:430px; margin:0 auto; }

        /* Hero header */
        .profile-hero {
            background: linear-gradient(135deg, #D4921F, #A0631A),
                        url('https://images.unsplash.com/photo-1536657464919-892534f60d6e?w=800&q=70') center/cover no-repeat;
            background-blend-mode: multiply;
            padding: 50px 20px 60px;
            position: relative;
        }
        .profile-hero-top { display:flex; justify-content:space-between; align-items:flex-start; margin-bottom:20px; }
        .avatar-wrap { display:flex; align-items:center; gap:14px; }
        .avatar {
            width:58px; height:58px; border-radius:50%;
            background:rgba(255,255,255,0.25); border:2px solid rgba(255,255,255,0.6);
            display:flex; align-items:center; justify-content:center;
            font-size:22px; font-weight:800; color:#fff;
        }
        .user-meta h2 { font-size:17px; font-weight:700; color:#fff; }
        .user-meta .uid { font-size:12px; color:rgba(255,255,255,0.8); margin-top:3px; }
        .badge-active {
            display:inline-flex; align-items:center; gap:5px;
            background:rgba(16,185,129,0.25); border:1px solid rgba(16,185,129,0.5);
            border-radius:20px; padding:3px 10px; font-size:11px; color:#6EE7B7; margin-top:4px;
        }
        .logout-btn {
            width:36px; height:36px; border-radius:50%;
            background:rgba(239,68,68,0.25); border:1px solid rgba(239,68,68,0.4);
            color:#FCA5A5; display:flex; align-items:center; justify-content:center;
            cursor:pointer; font-size:16px;
        }

        /* VIP progress */
        .vip-bar-wrap { }
        .vip-label { font-size:11px; color:rgba(255,255,255,0.75); margin-bottom:6px; display:flex; justify-content:space-between; }
        .vip-bar-bg { background:rgba(255,255,255,0.2); border-radius:20px; height:6px; overflow:hidden; }
        .vip-bar-fill { background:#fff; height:100%; border-radius:20px; transition:width 0.8s ease; }

        /* Balance grid */
        .content { padding:16px; margin-top:-24px; }
        .balance-grid { display:grid; grid-template-columns:1fr 1fr; gap:10px; margin-bottom:14px; }
        .balance-card {
            background:#fff; border-radius:16px; padding:16px; text-align:center;
            box-shadow:0 4px 16px rgba(196,125,30,0.10);
        }
        .balance-lbl { font-size:11px; color:#A87D50; text-transform:uppercase; letter-spacing:0.5px; font-weight:600; }
        .balance-val { font-size:22px; font-weight:800; color:#C47D1E; margin:4px 0 2px; }
        .balance-cur { font-size:11px; color:#A87D50; }

        /* Action buttons */
        .action-grid { display:grid; grid-template-columns:1fr 1fr; gap:10px; margin-bottom:14px; }
        .action-btn {
            background:#fff; border-radius:14px; padding:16px 10px;
            text-align:center; cursor:pointer; transition:all 0.2s;
            text-decoration:none; color:#3D2B1F; display:block;
            box-shadow:0 2px 10px rgba(196,125,30,0.08);
            border:1px solid #F0E0C8;
        }
        .action-btn:hover { border-color:#C47D1E; background:#FBF5EC; }
        .action-btn i { display:block; font-size:22px; color:#C47D1E; margin-bottom:6px; }
        .action-btn span { font-size:12px; font-weight:600; }
        .collect-btn {
            background:linear-gradient(135deg,#D4921F,#B07018);
            border:none; color:#fff;
        }
        .collect-btn:hover { transform:translateY(-2px); box-shadow:0 6px 20px rgba(196,125,30,0.35); }
        .collect-btn i { color:#fff; }
        .collect-btn span { color:#fff; }
        .collect-btn.disabled { background:#E8D5B0; cursor:not-allowed; }
        .collect-btn.disabled i, .collect-btn.disabled span { color:#A87D50; }

        /* Payment timing box */
        .timing-box {
            background:#FFFBF0; border:1px solid #F5D78A; border-radius:12px;
            padding:12px 14px; margin-bottom:14px; font-size:13px; color:#92660A;
            display:none; align-items:center; gap:9px;
        }
        .timing-box.show { display:flex; }

        /* Menu list */
        .menu-card {
            background:#fff; border-radius:16px; overflow:hidden;
            margin-bottom:14px; box-shadow:0 2px 10px rgba(196,125,30,0.08);
            border:1px solid #F0E0C8;
        }
        .menu-item {
            display:flex; align-items:center; gap:14px; padding:15px 16px;
            border-bottom:1px solid #F0E0C8; text-decoration:none;
            color:#3D2B1F; cursor:pointer; transition:background 0.2s;
        }
        .menu-item:last-child { border-bottom:none; }
        .menu-item:hover { background:#FBF5EC; }
        .menu-ico {
            width:38px; height:38px; border-radius:11px;
            background:rgba(196,125,30,0.12); display:flex; align-items:center;
            justify-content:center; color:#C47D1E; font-size:16px; flex-shrink:0;
        }
        .menu-txt { flex:1; font-size:14px; font-weight:500; }
        .menu-arr { color:#C8A870; font-size:12px; }

        /* Modal */
        .modal { display:none; position:fixed; inset:0; background:rgba(0,0,0,0.5); z-index:100; align-items:flex-end; justify-content:center; }
        .modal.active { display:flex; }
        .modal-box {
            background:#fff; border-radius:24px 24px 0 0; padding:24px 20px 36px;
            width:100%; max-width:430px; animation:slideUp 0.3s ease;
        }
        @keyframes slideUp { from { transform:translateY(100%); } to { transform:translateY(0); } }
        .modal-head { display:flex; justify-content:space-between; align-items:center; margin-bottom:20px; }
        .modal-title { color:#C47D1E; font-weight:700; font-size:16px; }
        .modal-close-btn { background:none; border:none; color:#A87D50; font-size:20px; cursor:pointer; }
        .fg { margin-bottom:14px; }
        .fg label { display:block; color:#A87D50; font-size:12px; margin-bottom:6px; font-weight:500; }
        .fg input {
            width:100%; background:#FBF5EC; border:1.5px solid #E8D5B0;
            border-radius:10px; padding:12px 14px; color:#3D2B1F; font-size:14px;
            font-family:'Poppins',sans-serif; outline:none; transition:border-color 0.2s;
        }
        .fg input:focus { border-color:#C47D1E; }
        .modal-btn {
            width:100%; background:linear-gradient(135deg,#D4921F,#B07018);
            color:#fff; border:none; border-radius:12px; padding:14px;
            font-weight:700; font-size:15px; cursor:pointer; margin-top:6px;
            font-family:'Poppins',sans-serif;
        }
        .modal-msg { font-size:13px; margin-top:10px; text-align:center; }

        /* TX list */
        .tx-list { list-style:none; max-height:300px; overflow-y:auto; }
        .tx-item { display:flex; justify-content:space-between; align-items:center; padding:11px 0; border-bottom:1px solid #F0E0C8; font-size:14px; }
        .tx-item:last-child { border-bottom:none; }
        .tx-type { color:#7D5A38; }
        .tx-date { font-size:11px; color:#A87D50; margin-top:2px; }
        .tx-pos { color:#16A34A; font-weight:700; }
        .tx-neg { color:#DC2626; font-weight:700; }

        .logout-confirm-overlay {
            display:none; position:fixed; inset:0; background:rgba(0,0,0,0.5);
            z-index:200; align-items:center; justify-content:center; padding:20px;
        }
        .logout-confirm-overlay.active { display:flex; }
        .logout-confirm-box {
            background:#fff; border-radius:20px; padding:28px 24px; width:100%; max-width:320px; text-align:center;
        }
        .lc-icon { font-size:48px; color:#EF4444; margin-bottom:14px; }
        .lc-title { font-size:18px; font-weight:700; color:#3D2B1F; margin-bottom:8px; }
        .lc-msg { font-size:14px; color:#7D5A38; margin-bottom:22px; }
        .lc-btns { display:flex; gap:12px; }
        .lc-btn { flex:1; padding:13px; border-radius:12px; font-weight:600; font-size:14px; cursor:pointer; border:none; font-family:'Poppins',sans-serif; }
        .lc-confirm { background:#EF4444; color:#fff; }
        .lc-cancel { background:#FBF5EC; border:1.5px solid #E8D5B0; color:#7D5A38; }
    </style>
</head>
<body>
<%- include('partials/menu', { page: 'compte' }) %>

<div class="container">
    <div class="profile-hero">
        <div class="profile-hero-top">
            <div class="avatar-wrap">
                <div class="avatar"><%= (user.nom || 'U').charAt(0).toUpperCase() %></div>
                <div class="user-meta">
                    <h2><%= user.nom %></h2>
                    <div class="uid">
                        ID: <span id="userIdDisplay"><%= custom_id %></span>
                        <button onclick="copyId(this)" style="background:none;border:none;color:rgba(255,255,255,0.7);cursor:pointer;margin-left:4px;"><i class="fas fa-copy"></i></button>
                    </div>
                    <% if (has_active_command) { %>
                        <div class="badge-active"><i class="fas fa-circle" style="font-size:7px"></i> Plan actif</div>
                    <% } %>
                </div>
            </div>
            <button class="logout-btn" onclick="document.getElementById('logoutOverlay').classList.add('active')">
                <i class="fas fa-sign-out-alt"></i>
            </button>
        </div>
        <div class="vip-bar-wrap">
            <div class="vip-label">
                <span>VIP <%= vip ? vip.niveau : '0' %> — <%= vip ? (vip.pourcentage || 0) : 0 %>%</span>
                <span><%= vip && vip.niveau < 5 ? 'Encore ' + (vip.invitations_requises || 0) + ' filleuls' : 'Niveau max !' %></span>
            </div>
            <div class="vip-bar-bg">
                <div class="vip-bar-fill" style="width:<%= vip ? Math.min(100, vip.pourcentage || 0) : 0 %>%"></div>
            </div>
        </div>
    </div>

    <div class="content">
        <!-- Balances -->
        <div class="balance-grid">
            <div class="balance-card">
                <div class="balance-lbl">Solde Principal</div>
                <div class="balance-val"><%= parseFloat(solde || 0).toLocaleString('fr-FR') %></div>
                <div class="balance-cur">FCFA</div>
            </div>
            <div class="balance-card">
                <div class="balance-lbl">Revenus Totaux</div>
                <div class="balance-val"><%= parseFloat(revenus && revenus.total ? revenus.total : 0).toLocaleString('fr-FR') %></div>
                <div class="balance-cur">FCFA</div>
            </div>
        </div>

        <!-- Actions -->
        <div class="action-grid">
            <a href="/salaire" class="action-btn">
                <i class="fas fa-money-bill-wave"></i>
                <span>Salaire VIP</span>
            </a>
            <div class="action-btn collect-btn <%= (!can_collect || !has_active_command) ? 'disabled' : '' %>"
                 id="collectBtn"
                 onclick="<%= (can_collect && has_active_command) ? 'collectGain()' : '' %>">
                <i class="fas fa-coins"></i>
                <span>Récupérer Gain</span>
            </div>
        </div>

        <% if (!can_collect && has_active_command && next_payment_info) { %>
        <div class="timing-box show"><i class="fas fa-clock"></i> <%- next_payment_info %></div>
        <% } %>

        <!-- Menu -->
        <div class="menu-card">
            <a href="/depot" class="menu-item">
                <span class="menu-ico"><i class="fas fa-arrow-down"></i></span>
                <span class="menu-txt">Dépôt</span>
                <i class="fas fa-chevron-right menu-arr"></i>
            </a>
            <a href="/retrait" class="menu-item">
                <span class="menu-ico"><i class="fas fa-arrow-up"></i></span>
                <span class="menu-txt">Retrait</span>
                <i class="fas fa-chevron-right menu-arr"></i>
            </a>
            <a href="/portefeuille" class="menu-item">
                <span class="menu-ico"><i class="fas fa-wallet"></i></span>
                <span class="menu-txt">Portefeuille</span>
                <i class="fas fa-chevron-right menu-arr"></i>
            </a>
            <div class="menu-item" onclick="openTxModal()">
                <span class="menu-ico"><i class="fas fa-exchange-alt"></i></span>
                <span class="menu-txt">Historique des Transactions</span>
                <i class="fas fa-chevron-right menu-arr"></i>
            </div>
            <div class="menu-item" onclick="openPinModal()">
                <span class="menu-ico"><i class="fas fa-lock"></i></span>
                <span class="menu-txt"><%= has_transaction_password ? 'Modifier le code PIN' : 'Créer un code PIN' %></span>
                <i class="fas fa-chevron-right menu-arr"></i>
            </div>
            <a href="/tuto" class="menu-item">
                <span class="menu-ico"><i class="fas fa-book"></i></span>
                <span class="menu-txt">Tutoriels</span>
                <i class="fas fa-chevron-right menu-arr"></i>
            </a>
            <a href="/faq" class="menu-item">
                <span class="menu-ico"><i class="fas fa-question-circle"></i></span>
                <span class="menu-txt">FAQ</span>
                <i class="fas fa-chevron-right menu-arr"></i>
            </a>
            <a href="https://t.me/groupeofficielblackrock" target="_blank" class="menu-item">
                <span class="menu-ico"><i class="fab fa-telegram"></i></span>
                <span class="menu-txt">Groupe Telegram</span>
                <i class="fas fa-chevron-right menu-arr"></i>
            </a>
        </div>
    </div>
</div>

<!-- PIN Modal -->
<div class="modal" id="pinModal">
    <div class="modal-box">
        <div class="modal-head">
            <div class="modal-title"><i class="fas fa-lock"></i> <%= has_transaction_password ? 'Modifier le PIN' : 'Créer un PIN' %></div>
            <button class="modal-close-btn" onclick="closePinModal()"><i class="fas fa-times"></i></button>
        </div>
        <% if (has_transaction_password) { %>
        <div class="fg"><label>Ancien PIN</label><input type="password" id="old_pin" maxlength="4" placeholder="****" inputmode="numeric"></div>
        <% } %>
        <div class="fg"><label>Nouveau PIN (4 chiffres)</label><input type="password" id="new_pin" maxlength="4" placeholder="****" inputmode="numeric"></div>
        <div class="fg"><label>Confirmer le PIN</label><input type="password" id="confirm_pin" maxlength="4" placeholder="****" inputmode="numeric"></div>
        <button class="modal-btn" onclick="savePin()">Enregistrer</button>
        <div class="modal-msg" id="pinMsg"></div>
    </div>
</div>

<!-- Transactions Modal -->
<div class="modal" id="txModal">
    <div class="modal-box">
        <div class="modal-head">
            <div class="modal-title"><i class="fas fa-exchange-alt"></i> Historique</div>
            <button class="modal-close-btn" onclick="closeTxModal()"><i class="fas fa-times"></i></button>
        </div>
        <% if (transactions && transactions.length > 0) { %>
        <ul class="tx-list">
            <% transactions.forEach(tx => { %>
            <li class="tx-item">
                <div>
                    <div class="tx-type"><%= tx.type || 'transaction' %></div>
                    <div class="tx-date"><%= tx.date ? new Date(tx.date).toLocaleDateString('fr-FR') : '' %></div>
                </div>
                <span class="<%= (tx.montant > 0) ? 'tx-pos' : 'tx-neg' %>">
                    <%= (tx.montant > 0 ? '+' : '') %><%= parseFloat(tx.montant).toLocaleString('fr-FR') %> FCFA
                </span>
            </li>
            <% }); %>
        </ul>
        <% } else { %>
        <p style="color:#A87D50;text-align:center;padding:24px;font-size:14px;">Aucune transaction trouvée.</p>
        <% } %>
    </div>
</div>

<!-- Logout Confirm -->
<div class="logout-confirm-overlay" id="logoutOverlay">
    <div class="logout-confirm-box">
        <div class="lc-icon"><i class="fas fa-sign-out-alt"></i></div>
        <div class="lc-title">Déconnexion</div>
        <div class="lc-msg">Êtes-vous sûr de vouloir vous déconnecter ?</div>
        <div class="lc-btns">
            <button class="lc-btn lc-confirm" onclick="window.location.href='/deconnexion'">Oui, quitter</button>
            <button class="lc-btn lc-cancel" onclick="document.getElementById('logoutOverlay').classList.remove('active')">Annuler</button>
        </div>
    </div>
</div>

<script>
function copyId(btn) {
    const id = document.getElementById('userIdDisplay').textContent;
    navigator.clipboard.writeText(id).then(() => {
        btn.innerHTML = '<i class="fas fa-check" style="color:#C47D1E"></i>';
        setTimeout(() => { btn.innerHTML = '<i class="fas fa-copy"></i>'; }, 1500);
    }).catch(() => {
        try { document.execCommand('copy'); } catch(e) {}
    });
}
function openPinModal() { document.getElementById('pinModal').classList.add('active'); }
function closePinModal() { document.getElementById('pinModal').classList.remove('active'); }
function openTxModal() { document.getElementById('txModal').classList.add('active'); }
function closeTxModal() { document.getElementById('txModal').classList.remove('active'); }
document.getElementById('pinModal').addEventListener('click', e => { if (e.target === document.getElementById('pinModal')) closePinModal(); });
document.getElementById('txModal').addEventListener('click', e => { if (e.target === document.getElementById('txModal')) closeTxModal(); });

async function savePin() {
    const old_pin = document.getElementById('old_pin') ? document.getElementById('old_pin').value : '';
    const new_pin = document.getElementById('new_pin').value;
    const confirm_pin = document.getElementById('confirm_pin').value;
    const msg = document.getElementById('pinMsg');
    if (new_pin !== confirm_pin) { msg.textContent = 'Les PIN ne correspondent pas.'; msg.style.color = '#DC2626'; return; }
    if (!/^\d{4}$/.test(new_pin)) { msg.textContent = 'Le PIN doit être 4 chiffres.'; msg.style.color = '#DC2626'; return; }
    try {
        const res = await fetch('/update_transaction_password', { method:'POST', headers:{'Content-Type':'application/x-www-form-urlencoded'}, body:`old_pin=${old_pin}&new_pin=${new_pin}&confirm_pin=${confirm_pin}` });
        const data = await res.json();
        msg.textContent = data.message; msg.style.color = data.success ? '#16A34A' : '#DC2626';
        if (data.success) setTimeout(() => location.reload(), 1200);
    } catch(e) { msg.textContent = 'Erreur réseau'; msg.style.color = '#DC2626'; }
}

async function collectGain() {
    const btn = document.getElementById('collectBtn');
    if (btn.classList.contains('disabled')) return;
    btn.classList.add('disabled');
    try {
        const res = await fetch('/compte/collecter', { method:'POST', headers:{'Content-Type':'application/x-www-form-urlencoded'} });
        const data = await res.json();
        if (data.success) { alert('✓ ' + data.message); location.reload(); }
        else { alert('✗ ' + data.message); btn.classList.remove('disabled'); }
    } catch(e) { alert('Erreur réseau'); btn.classList.remove('disabled'); }
}
</script>
</body>
</html>
