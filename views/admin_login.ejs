<!DOCTYPE html>
<html lang="fr">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>Admin - Altiora Capital Africa</title>
    <link href="https://fonts.googleapis.com/css2?family=Poppins:wght@300;400;500;600;700;800&display=swap" rel="stylesheet">
    <style>
        * { margin:0; padding:0; box-sizing:border-box; font-family:'Poppins','Segoe UI',sans-serif; }
        body { background:#F5EFE6; color:#3D2B1F; min-height:100vh; display:flex; align-items:center; justify-content:center; padding:20px; }
        .login-card { background:#fff; border:1px solid #E8D5B0; border-radius:20px; padding:36px 28px; width:100%; max-width:380px; box-shadow:0 8px 28px rgba(196,125,30,0.15); }
        .logo { text-align:center; margin-bottom:28px; }
        .logo h1 { color:#C47D1E; font-size:1.5rem; font-weight:800; }
        .logo p { color:#A87D50; font-size:0.85rem; margin-top:4px; }
        .error { background:#FFF0EE; border:1px solid #F5A9A0; color:#C0392B; padding:10px 14px; border-radius:10px; margin-bottom:16px; font-size:0.85rem; }
        .form-group { margin-bottom:16px; }
        .form-group label { display:block; color:#A87D50; font-size:0.8rem; margin-bottom:6px; font-weight:600; }
        .form-group input {
            width:100%; background:#FBF5EC; border:1.5px solid #E8D5B0; border-radius:10px;
            padding:12px 14px; color:#3D2B1F; font-size:0.9rem; font-family:'Poppins',sans-serif;
            outline:none; transition:border-color 0.2s;
        }
        .form-group input:focus { border-color:#C47D1E; }
        .btn {
            width:100%; background:linear-gradient(135deg,#D4921F,#B07018); color:#fff;
            border:none; border-radius:12px; padding:14px; font-weight:700; font-size:1rem;
            cursor:pointer; font-family:'Poppins',sans-serif; box-shadow:0 4px 14px rgba(196,125,30,0.35);
            transition:transform 0.2s;
        }
        .btn:hover { transform:translateY(-2px); }
    </style>
</head>
<body>
<div class="login-card">
    <div class="logo">
        <h1>⚡ Altiora Admin</h1>
        <p>Accès administrateur sécurisé</p>
    </div>
    <% if (error) { %><div class="error"><%= error %></div><% } %>
    <form action="/adminxyz" method="POST">
        <div class="form-group">
            <label>Code de sécurité</label>
            <input type="password" name="security_code" placeholder="Entrez le code" required autofocus>
        </div>
        <button type="submit" class="btn">Accéder au panneau admin</button>
    </form>
</div>
</body>
</html>
