<!DOCTYPE html>
<html lang="fr">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0, maximum-scale=1.0, user-scalable=no">
    <title>Machine à Sous Gratuite - Altiora Capital Africa</title>
    <link href="https://fonts.googleapis.com/css2?family=Poppins:wght@300;400;500;600;700;800&display=swap" rel="stylesheet">
    <link rel="stylesheet" href="https://cdnjs.cloudflare.com/ajax/libs/font-awesome/6.5.0/css/all.min.css">
    <style>
        * { margin:0; padding:0; box-sizing:border-box; font-family:'Poppins','Segoe UI',sans-serif; }
        body { background:#F5EFE6; color:#3D2B1F; min-height:100vh; padding-bottom:90px; }
        .container { max-width:430px; margin:0 auto; text-align:center; }

        .page-header {
            background: linear-gradient(135deg, #D4921F, #A0631A);
            padding: 50px 20px 28px; text-align:center; color:#fff;
        }
        .page-header h1 { font-size:22px; font-weight:800; margin-bottom:4px; }
        .page-header p { font-size:13px; color:rgba(255,255,255,0.85); }

        .balance-strip {
            background:#fff; border-bottom:1px solid #F0E0C8;
            padding:14px 20px; font-size:15px; font-weight:700;
            color:#3D2B1F; display:flex; justify-content:center; align-items:center; gap:8px;
        }
        .balance-strip span { color:#C47D1E; font-size:17px; }

        /* Slot machine */
        .slot-area { padding:24px 16px; }
        .slot-machine {
            background:#fff; border-radius:20px;
            box-shadow:0 8px 30px rgba(196,125,30,0.18);
            border:2px solid #E8D5B0; padding:20px; margin-bottom:20px;
            position:relative; overflow:hidden;
        }
        .slot-machine::before {
            content:''; position:absolute; top:0; left:0; right:0; height:4px;
            background:linear-gradient(135deg,#D4921F,#B07018);
        }
        .slot-label { font-size:12px; font-weight:700; color:#A87D50;
            text-transform:uppercase; letter-spacing:1px; margin-bottom:16px; }
        .slot-reels {
            display:flex; justify-content:space-around; padding:10px 0;
            border:3px solid #C47D1E; border-radius:12px; background:#FBF5EC;
        }
        .reel {
            width:30%; height:120px; overflow:hidden; position:relative;
            border-radius:8px; box-shadow:inset 0 0 10px rgba(0,0,0,0.12);
        }
        .reel-inner { position:absolute; width:100%; top:0; transition:transform 0.1s linear; }
        .symbol {
            display:flex; align-items:center; justify-content:center;
            height:120px; font-size:50px; font-weight:bold; color:#3D2B1F;
            background:#FBF5EC; border-bottom:1px solid #F0E0C8;
        }
        .symbol i { font-size:48px; color:#C47D1E; }
        .payline {
            position:absolute; top:50%; left:0; width:100%; height:3px;
            background:#EF4444; transform:translateY(-50%);
            box-shadow:0 0 8px rgba(239,68,68,0.5); z-index:10; pointer-events:none;
        }

        .spin-btn {
            background:linear-gradient(135deg,#D4921F,#B07018);
            color:#fff; border:none; padding:16px 48px; border-radius:40px;
            font-size:20px; font-weight:800; cursor:pointer;
            box-shadow:0 6px 20px rgba(196,125,30,0.45); transition:transform 0.2s;
            text-transform:uppercase; letter-spacing:1px; font-family:'Poppins',sans-serif;
        }
        .spin-btn:hover:not(:disabled) { transform:scale(1.04); }
        .spin-btn:disabled { background:#E8D5B0; color:#A87D50; cursor:not-allowed; transform:none; box-shadow:none; }

        #timer-display {
            font-size:28px; font-weight:800; color:#C47D1E;
            background:#FBF5EC; border:1px solid #E8D5B0;
            border-radius:14px; padding:14px 22px; display:inline-block;
        }

        /* Result popup */
        .result-popup {
            display:none; position:fixed; inset:0;
            background:rgba(0,0,0,0.55); backdrop-filter:blur(8px);
            z-index:1000; align-items:center; justify-content:center;
        }
        .popup-box {
            background:#fff; padding:32px 24px; border-radius:24px;
            box-shadow:0 24px 60px rgba(196,125,30,0.30);
            border:2px solid #C47D1E; max-width:340px; width:90%;
            animation:popIn 0.4s cubic-bezier(0.175,0.885,0.32,1.275); text-align:center;
        }
        @keyframes popIn { from { transform:scale(0.8); opacity:0; } to { transform:scale(1); opacity:1; } }
        .result-icon { font-size:52px; color:#C47D1E; margin-bottom:14px;
            animation:bounce 0.8s infinite alternate; }
        @keyframes bounce { from { transform:translateY(0); } to { transform:translateY(-8px); } }
        .result-title { font-size:24px; font-weight:800; color:#C47D1E; margin-bottom:10px; }
        .result-msg { font-size:15px; color:#7D5A38; line-height:1.6; }
    </style>
    <script src="https://cdnjs.cloudflare.com/ajax/libs/gsap/3.9.1/gsap.min.js"></script>
    <script>
        const SYMBOLS = [
            '<i class="fas fa-gem"></i>',
            '<i class="fas fa-lemon"></i>',
            '<i class="fas fa-star"></i>',
            '<i class="fas fa-bell"></i>',
            '<i class="fas fa-dollar-sign"></i>',
            '<span>BAR</span>',
            '<span style="color:#C47D1E;">7</span>',
            '<i class="fas fa-wheat-awn"></i>',
        ];
        const SYMBOL_HEIGHT = 120;

        function buildReel(reelElement) {
            const inner = reelElement.querySelector('.reel-inner');
            inner.innerHTML = '';
            const totalSymbols = 20;
            for (let i = 0; i < totalSymbols; i++) {
                const randomIndex = Math.floor(Math.random() * SYMBOLS.length);
                const symbolDiv = document.createElement('div');
                symbolDiv.className = 'symbol';
                symbolDiv.innerHTML = SYMBOLS[randomIndex];
                inner.appendChild(symbolDiv);
            }
        }

        function spinReel(reelIndex, symbolIndex, spinDuration, delay) {
            const reel = document.querySelectorAll('.reel-inner')[reelIndex];
            const stopSymbolIndex = 16;
            const finalPosition = stopSymbolIndex * SYMBOL_HEIGHT;
            return new Promise(resolve => {
                const randomOffset = (Math.random() * (SYMBOL_HEIGHT/2)) - (SYMBOL_HEIGHT/4);
                gsap.to(reel, {
                    y: -finalPosition + randomOffset,
                    duration: spinDuration,
                    ease: `power${reelIndex + 2}.out`,
                    delay: delay,
                    onComplete: resolve
                });
            });
        }

        async function startSpin() {
            const spinButton = document.getElementById('spinButton');
            spinButton.disabled = true;
            spinButton.textContent = 'SPINNING...';
            const reels = document.querySelectorAll('.reel-inner');
            reels.forEach(reel => {
                gsap.to(reel, { y: -19 * SYMBOL_HEIGHT, duration: 0.5, ease: "linear", repeat: -1 });
            });
            try {
                const response = await fetch('/spin_roue', { method: 'POST' });
                const data = await response.json();
                if (data.status === 'success') {
                    const winnings = data.gains;
                    let comboSymbolIndex = winnings >= 1500 ? 6 : (winnings > 25 ? 7 : (winnings === 25 ? 3 : -1));
                    let promises = [];
                    let baseDuration = 3.0;
                    for (let i = 0; i < reels.length; i++) {
                        let finalSymbolIndex = comboSymbolIndex !== -1 ? comboSymbolIndex : Math.floor(Math.random() * SYMBOLS.length);
                        promises.push(spinReel(i, finalSymbolIndex, baseDuration + i * 0.5, 0).then(() => {
                            buildReel(document.querySelectorAll('.reel')[i]);
                        }));
                    }
                    await Promise.all(promises);
                    showResultPopup(winnings);
                    document.getElementById('soldePrincipal').textContent = data.new_solde.toLocaleString('fr') + ' <%= devise %>';
                    setTimeout(() => window.location.reload(), 3000);
                } else {
                    alert(data.message || 'Une erreur est survenue.');
                    reels.forEach(reel => gsap.killTweensOf(reel));
                    spinButton.disabled = false;
                    spinButton.textContent = 'SPIN';
                }
            } catch (error) {
                console.error('Erreur:', error);
                reels.forEach(reel => gsap.killTweensOf(reel));
                spinButton.disabled = false;
                spinButton.textContent = 'SPIN';
            }
        }

        let remainingSeconds = <%= remaining_time %>;

        function formatTime(seconds) {
            const d = Math.floor(seconds / 86400);
            const h = Math.floor((seconds % 86400) / 3600);
            const m = Math.floor((seconds % 3600) / 60);
            const s = seconds % 60;
            return `${d}j : ${h.toString().padStart(2,'0')}h : ${m.toString().padStart(2,'0')}m : ${s.toString().padStart(2,'0')}s`;
        }

        function updateTimer() {
            const spinButton = document.getElementById('spinButton');
            const timerDisplay = document.getElementById('timer-display');
            if (remainingSeconds <= 0) {
                spinButton.style.display = 'inline-block';
                spinButton.disabled = false;
                timerDisplay.style.display = 'none';
            } else {
                spinButton.style.display = 'none';
                timerDisplay.style.display = 'inline-block';
                timerDisplay.textContent = formatTime(remainingSeconds);
                remainingSeconds--;
                setTimeout(updateTimer, 1000);
            }
        }

        function showResultPopup(gains) {
            const popup = document.getElementById('resultPopup');
            const title = document.getElementById('resultTitle');
            const message = document.getElementById('resultMessage');
            if (gains > 0) {
                title.textContent = "Félicitations !";
                message.innerHTML = `Vous avez gagné <span style="color:#C47D1E;font-weight:800;">${gains.toLocaleString('fr')} <%= devise %></span>. Le montant a été ajouté à votre solde.`;
                document.getElementById('resultIcon').className = 'fas fa-trophy result-icon';
            } else {
                title.textContent = "Pas de chance...";
                message.innerHTML = "Aucun gain cette fois. Revenez dans 48 heures pour tenter à nouveau votre chance !";
                document.getElementById('resultIcon').className = 'fas fa-sad-cry result-icon';
            }
            popup.style.display = 'flex';
        }

        document.addEventListener('DOMContentLoaded', () => {
            document.querySelectorAll('.reel').forEach(buildReel);
            updateTimer();
            if (!<%= can_spin %>) { document.getElementById('spinButton').style.display = 'none'; }
        });
    </script>
</head>
<body>
<%- include('partials/menu', { page: 'index' }) %>

<div class="container">
    <div class="page-header">
        <h1><i class="fas fa-dice"></i> Machine à Sous</h1>
        <p>Tentez votre chance gratuitement !</p>
    </div>
    <div class="balance-strip">
        <i class="fas fa-coins" style="color:#C47D1E"></i>
        Solde: <span id="soldePrincipal"><%= solde.toLocaleString('fr') %> <%= devise %></span>
    </div>

    <div class="slot-area">
        <div class="slot-machine">
            <div class="slot-label">🎰 Machine à Sous Gratuite</div>
            <div class="payline"></div>
            <div class="slot-reels">
                <div class="reel"><div class="reel-inner"></div></div>
                <div class="reel"><div class="reel-inner"></div></div>
                <div class="reel"><div class="reel-inner"></div></div>
            </div>
        </div>

        <div style="margin-top:10px;">
            <button id="spinButton" class="spin-btn" onclick="startSpin()">SPIN</button>
            <div id="timer-display" style="display:none;"></div>
        </div>
    </div>
</div>

<div class="result-popup" id="resultPopup">
    <div class="popup-box">
        <div id="resultIcon" class="result-icon"></div>
        <div id="resultTitle" class="result-title"></div>
        <div id="resultMessage" class="result-msg"></div>
    </div>
</div>
</body>
</html>
