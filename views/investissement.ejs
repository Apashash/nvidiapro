<!DOCTYPE html>
<html lang="fr">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>Plans d'Investissement - Altiora Capital Africa</title>
    <link href="https://fonts.googleapis.com/css2?family=Poppins:wght@300;400;500;600;700;800&display=swap" rel="stylesheet">
    <link rel="stylesheet" href="https://cdnjs.cloudflare.com/ajax/libs/font-awesome/6.5.0/css/all.min.css">
    <style>
        * { margin:0; padding:0; box-sizing:border-box; font-family:'Poppins','Segoe UI',sans-serif; }
        body { background:#F5EFE6; color:#3D2B1F; min-height:100vh; overflow-x:hidden; padding-bottom:90px; }
        .container { max-width:430px; margin:0 auto; }

        /* Header */
        .page-header {
            background: linear-gradient(135deg, #D4921F, #A0631A);
            padding: 50px 20px 20px;
            display: flex; align-items: center; gap: 14px;
        }
        .back-btn {
            width:36px; height:36px; border-radius:50%;
            background:rgba(255,255,255,0.2); display:flex; align-items:center; justify-content:center;
            color:#fff; text-decoration:none; font-size:16px; flex-shrink:0;
        }
        .page-header h1 { font-size:20px; font-weight:700; color:#fff; }

        /* Tab nav */
        .tab-nav {
            background:#fff; border-bottom:1px solid #E8D5B0;
            display:flex; position:sticky; top:0; z-index:10;
        }
        .tab-btn {
            flex:1; padding:14px; text-align:center; cursor:pointer;
            font-size:14px; font-weight:600; color:#A87D50;
            border-bottom:3px solid transparent; transition:all 0.2s;
            display:flex; align-items:center; justify-content:center; gap:8px;
        }
        .tab-btn.active { color:#C47D1E; border-bottom-color:#C47D1E; }

        /* Plans */
        .main-content { padding:16px; }
        .plans-list { display:flex; flex-direction:column; gap:20px; }
        .plan-card {
            background:#fff; border-radius:20px;
            overflow:hidden; box-shadow:0 4px 16px rgba(196,125,30,0.12);
            transition:transform 0.2s, box-shadow 0.2s;
        }
        .plan-card:hover { transform:translateY(-4px); box-shadow:0 8px 28px rgba(196,125,30,0.20); }
        .plan-image-wrap { position:relative; height:160px; overflow:hidden; }
        .plan-image-wrap img { width:100%; height:100%; object-fit:cover; }
        .plan-duration-badge {
            position:absolute; top:12px; right:12px;
            background:linear-gradient(135deg,#D4921F,#B07018);
            color:#fff; font-size:12px; font-weight:700;
            padding:5px 12px; border-radius:20px;
            box-shadow:0 2px 8px rgba(0,0,0,0.25);
        }
        .plan-body { padding:16px; }
        .plan-name { font-size:18px; font-weight:700; color:#C47D1E; margin-bottom:12px; }
        .plan-stats {
            background:#FBF5EC; border-radius:12px; padding:12px; margin-bottom:14px;
            display:grid; grid-template-columns:1fr 1fr; gap:8px;
        }
        .stat-cell { }
        .stat-val { font-size:16px; font-weight:800; color:#C47D1E; }
        .stat-lbl { font-size:11px; color:#A87D50; margin-top:1px; }
        .plan-footer {
            display:flex; align-items:center; justify-content:space-between;
            padding-top:12px; border-top:1px solid #F0E0C8;
        }
        .plan-price { font-size:14px; color:#7D5A38; }
        .plan-price strong { font-size:18px; font-weight:800; color:#3D2B1F; }
        .btn-invest {
            background:linear-gradient(135deg,#D4921F,#B07018);
            color:#fff; border:none; border-radius:12px;
            padding:11px 24px; font-size:14px; font-weight:700;
            cursor:pointer; box-shadow:0 4px 12px rgba(196,125,30,0.4);
            transition:transform 0.2s; font-family:'Poppins',sans-serif;
        }
        .btn-invest:hover { transform:translateY(-2px); }

        /* Empty state */
        .empty-state { text-align:center; padding:60px 20px; }
        .empty-icon { font-size:52px; color:#E8D5B0; margin-bottom:16px; }
        .empty-title { font-size:18px; font-weight:600; color:#7D5A38; margin-bottom:8px; }
        .empty-msg { font-size:14px; color:#A87D50; }

        /* Popup */
        .popup {
            display:none; position:fixed; inset:0;
            background:rgba(0,0,0,0.55); backdrop-filter:blur(8px);
            z-index:1000; align-items:center; justify-content:center; padding:20px;
        }
        .popup-box {
            background:#fff; width:100%; max-width:370px;
            border-radius:24px; overflow:hidden;
            box-shadow:0 24px 60px rgba(0,0,0,0.25);
        }
        .popup-head {
            padding:20px; background:linear-gradient(135deg,#D4921F,#B07018);
            display:flex; justify-content:space-between; align-items:center;
        }
        .popup-head h3 { font-size:17px; font-weight:700; color:#fff; }
        .popup-close-btn {
            width:30px; height:30px; border-radius:50%;
            background:rgba(255,255,255,0.25); border:none; color:#fff;
            font-size:18px; cursor:pointer; display:flex; align-items:center; justify-content:center;
        }
        .popup-body { padding:24px 20px; }
        .popup-grid { display:grid; grid-template-columns:1fr 1fr; gap:12px; margin-bottom:20px; }
        .popup-stat {
            background:#FBF5EC; border:1px solid #E8D5B0;
            border-radius:12px; padding:14px; text-align:center;
        }
        .popup-stat-val { font-size:17px; font-weight:800; color:#C47D1E; margin-bottom:4px; }
        .popup-stat-lbl { font-size:12px; color:#A87D50; }
        .btn-confirm {
            width:100%; padding:16px; border:none; border-radius:14px;
            background:linear-gradient(135deg,#D4921F,#B07018);
            color:#fff; font-size:16px; font-weight:700;
            cursor:pointer; font-family:'Poppins',sans-serif;
            box-shadow:0 6px 18px rgba(196,125,30,0.4); transition:transform 0.2s;
        }
        .btn-confirm:hover { transform:translateY(-2px); }

        /* Insufficient balance */
        .floater-overlay {
            display:none; position:fixed; inset:0;
            background:rgba(0,0,0,0.6); backdrop-filter:blur(8px);
            z-index:2000; align-items:center; justify-content:center; padding:20px;
        }
        .floater-box {
            background:#fff; max-width:340px; width:100%;
            border-radius:24px; padding:36px 24px; text-align:center;
            box-shadow:0 24px 60px rgba(0,0,0,0.25);
        }
        .floater-icon { font-size:56px; margin-bottom:16px; }
        .floater-title { font-size:20px; font-weight:700; color:#3D2B1F; margin-bottom:10px; }
        .floater-msg { font-size:14px; color:#7D5A38; line-height:1.6; margin-bottom:24px; }
        .floater-btns { display:flex; gap:12px; }
        .floater-btn {
            flex:1; padding:14px; border:none; border-radius:12px;
            font-size:15px; font-weight:600; cursor:pointer; font-family:'Poppins',sans-serif;
        }
        .floater-primary { background:linear-gradient(135deg,#D4921F,#B07018); color:#fff; }
        .floater-secondary { background:#FBF5EC; border:1.5px solid #E8D5B0; color:#7D5A38; }

        .alert-msg { padding:12px 16px; border-radius:10px; margin-bottom:16px; font-size:14px; display:none; }
        .alert-error { background:#FFF0EE; border:1px solid #F5A9A0; color:#C0392B; }
        .alert-success { background:#F0FFF4; border:1px solid #86EFAC; color:#166534; }
    </style>
</head>
<body>
<%- include('partials/menu', { page: 'investissement' }) %>

<div class="container">
    <div class="page-header">
        <a href="/" class="back-btn"><i class="fas fa-chevron-left"></i></a>
        <h1>Plans d'Investissement</h1>
    </div>

    <div class="tab-nav">
        <div class="tab-btn vip <%= menu_actif === 'vip' ? 'active' : '' %>" data-menu="vip">
            <i class="fas fa-crown"></i> Actions VIP
        </div>
        <div class="tab-btn commande <%= menu_actif === 'commande' ? 'active' : '' %>" data-menu="commande">
            <i class="fas fa-shopping-bag"></i> Mes Commandes
        </div>
    </div>

    <div class="main-content">
        <div id="alertMessage" class="alert-msg"></div>

        <div class="contenu-tab <%= menu_actif === 'vip' ? '' : 'hidden' %>" id="vip-content">
            <div class="plans-list">
                <% if (plans && plans.length > 0) { %>
                    <% plans.forEach(function(plan, idx) { %>
                    <div class="plan-card">
                        <div class="plan-image-wrap">
                            <img src="<%= plan.image_url %>" alt="<%= plan.nom %>">
                            <div class="plan-duration-badge"><%= plan.duree_jours %> Jours</div>
                        </div>
                        <div class="plan-body">
                            <div class="plan-name"><%= plan.nom %></div>
                            <div class="plan-stats">
                                <div class="stat-cell">
                                    <div class="stat-val"><%= plan.revenu_journalier.toLocaleString() %> FCFA</div>
                                    <div class="stat-lbl">Revenu quotidien</div>
                                </div>
                                <div class="stat-cell">
                                    <div class="stat-val"><%= plan.revenu_total.toLocaleString() %></div>
                                    <div class="stat-lbl">Revenu total</div>
                                </div>
                            </div>
                            <div class="plan-footer">
                                <div class="plan-price">Prix : <strong><%= plan.prix.toLocaleString() %> FCFA</strong></div>
                                <button class="btn-invest"
                                    data-plan-id="<%= plan.id %>"
                                    data-nom="<%= plan.nom %>"
                                    data-prix="<%= plan.prix %>"
                                    data-gain-journalier="<%= plan.revenu_journalier %>"
                                    data-duree="<%= plan.duree_jours %>"
                                    data-gain-total="<%= plan.revenu_total %>">
                                    Investir
                                </button>
                            </div>
                        </div>
                    </div>
                    <% }); %>
                <% } else { %>
                    <div class="empty-state">
                        <div class="empty-icon"><i class="fas fa-seedling"></i></div>
                        <div class="empty-title">Aucun Plan Disponible</div>
                        <div class="empty-msg">Les plans d'investissement ne sont pas encore configurés.</div>
                    </div>
                <% } %>
            </div>
        </div>

        <div class="contenu-tab <%= menu_actif === 'commande' ? '' : 'hidden' %>" id="commande-content">
            <div class="empty-state">
                <div class="empty-icon"><i class="fas fa-exchange-alt"></i></div>
                <div class="empty-title">Redirection en cours</div>
                <div class="empty-msg">Veuillez patienter...</div>
            </div>
        </div>
    </div>
</div>

<!-- Invest Popup -->
<div class="popup" id="investPopup">
    <div class="popup-box">
        <div class="popup-head">
            <h3 id="popup-titre">Confirmer l'investissement</h3>
            <button class="popup-close-btn" onclick="fermerPopup()">&times;</button>
        </div>
        <div class="popup-body">
            <div class="popup-grid">
                <div class="popup-stat">
                    <div class="popup-stat-val" id="popup-prix">0 FCFA</div>
                    <div class="popup-stat-lbl">Prix d'achat</div>
                </div>
                <div class="popup-stat">
                    <div class="popup-stat-val" id="popup-gain-journalier">0 FCFA</div>
                    <div class="popup-stat-lbl">Gain quotidien</div>
                </div>
                <div class="popup-stat">
                    <div class="popup-stat-val" id="popup-duree">0 jours</div>
                    <div class="popup-stat-lbl">Durée totale</div>
                </div>
                <div class="popup-stat">
                    <div class="popup-stat-val" id="popup-gain-total">0 FCFA</div>
                    <div class="popup-stat-lbl">Gain total</div>
                </div>
            </div>
            <button class="btn-confirm" id="confirmerInvestBtn">Confirmer l'achat</button>
        </div>
    </div>
</div>

<!-- Insufficient Balance -->
<div class="floater-overlay" id="insufficientBalanceFloater">
    <div class="floater-box">
        <div class="floater-icon">🌾</div>
        <div class="floater-title">Solde Insuffisant</div>
        <div class="floater-msg">Votre solde actuel est de <strong><%= solde.toLocaleString() %> FCFA</strong>. Veuillez recharger pour continuer.</div>
        <div class="floater-btns">
            <button class="floater-btn floater-primary" onclick="window.location.href='/depot'">Recharger</button>
            <button class="floater-btn floater-secondary" onclick="document.getElementById('insufficientBalanceFloater').style.display='none'">Annuler</button>
        </div>
    </div>
</div>

<style>.hidden { display:none; }</style>
<script>
let currentPlan = null;
const soldeClient = <%= solde %>;

document.querySelectorAll('.tab-btn').forEach(btn => {
    btn.addEventListener('click', function() {
        const target = this.getAttribute('data-menu');
        if (target === 'commande') { window.location.href = '/'; return; }
        document.querySelectorAll('.tab-btn').forEach(b => b.classList.remove('active'));
        document.querySelectorAll('.contenu-tab').forEach(c => c.classList.add('hidden'));
        this.classList.add('active');
        document.getElementById(target + '-content').classList.remove('hidden');
    });
});

document.querySelectorAll('.btn-invest').forEach(btn => {
    btn.addEventListener('click', function() {
        currentPlan = {
            id: this.dataset.planId, nom: this.dataset.nom,
            prix: parseInt(this.dataset.prix), gainJournalier: this.dataset.gainJournalier,
            duree: this.dataset.duree, gainTotal: this.dataset.gainTotal
        };
        if (soldeClient < currentPlan.prix) {
            document.getElementById('insufficientBalanceFloater').style.display = 'flex';
        } else { ouvrirPopup(currentPlan); }
    });
});

function ouvrirPopup(plan) {
    document.getElementById('popup-titre').textContent = plan.nom;
    document.getElementById('popup-prix').textContent = plan.prix.toLocaleString() + ' FCFA';
    document.getElementById('popup-gain-journalier').textContent = parseInt(plan.gainJournalier).toLocaleString() + ' FCFA';
    document.getElementById('popup-duree').textContent = plan.duree + ' jours';
    document.getElementById('popup-gain-total').textContent = parseInt(plan.gainTotal).toLocaleString() + ' FCFA';
    document.getElementById('investPopup').style.display = 'flex';
}

function fermerPopup() { document.getElementById('investPopup').style.display = 'none'; }

document.getElementById('confirmerInvestBtn').addEventListener('click', function() {
    if (!currentPlan) return;
    this.disabled = true; this.textContent = 'Traitement...';
    fetch('/acheter-action', {
        method: 'POST',
        headers: { 'Content-Type': 'application/x-www-form-urlencoded' },
        body: 'plan_id=' + currentPlan.id
    })
    .then(res => res.json())
    .then(data => {
        if (data.success) {
            window.location.reload();
        } else {
            showAlert(data.message || "Erreur lors de l'investissement", 'error');
            fermerPopup(); this.disabled = false; this.textContent = "Confirmer l'achat";
        }
    })
    .catch(() => { showAlert('Erreur de connexion', 'error'); fermerPopup(); this.disabled = false; });
});

function showAlert(msg, type) {
    const el = document.getElementById('alertMessage');
    el.textContent = msg;
    el.className = 'alert-msg alert-' + type;
    el.style.display = 'block';
    setTimeout(() => el.style.display = 'none', 5000);
}
</script>
</body>
</html>
