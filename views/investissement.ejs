<!DOCTYPE html>
<html lang="fr">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>Investissement - NVIDIA Technologie</title>
    <link rel="stylesheet" href="https://cdnjs.cloudflare.com/ajax/libs/font-awesome/6.4.0/css/all.min.css">
    <style>
    :root {
        --primary-white: #ffffff;
        --soft-white: #f8fafc;
        --warm-white: #fefefe;
        --light-gray: #f1f5f9;
        --nvidia-green: #76B900;
        --nvidia-dark-green: #588A00;
        --accent-dark: #1e293b;
        --dark-bg: #0f172a;
        --dark-card-bg: #1e293b;
        --text-light: #e2e8f0;
        --text-mid: #94a3b8;
        --border-dark: rgba(255, 255, 255, 0.1);
        --error: #ef4444;
        --success: #10b981;
        --transition: all 0.4s cubic-bezier(0.175, 0.885, 0.32, 1.275);
    }
    * { margin: 0; padding: 0; box-sizing: border-box; font-family: 'Inter', 'Segoe UI', sans-serif; }
    body { background: linear-gradient(135deg, var(--dark-bg) 0%, #020617 100%); color: var(--text-light); min-height: 100vh; overflow-x: hidden; }
    .container { max-width: 430px; margin: 0 auto; background: transparent; }
    .background { position: fixed; top: 0; left: 0; width: 100%; height: 100%; background: radial-gradient(circle at 10% 20%, rgba(118, 185, 0, 0.08) 0%, transparent 20%), radial-gradient(circle at 90% 80%, rgba(30, 41, 59, 0.2) 0%, transparent 20%); z-index: -3; }
    .geometric-pattern { position: fixed; top: 0; left: 0; width: 100%; height: 100%; background-image: repeating-linear-gradient(0deg, var(--dark-bg), var(--dark-bg) 1px, transparent 1px, transparent 100px), repeating-linear-gradient(90deg, var(--dark-bg), var(--dark-bg) 1px, var(--border-dark) 1px, var(--border-dark) 100px); background-size: 100px 100px; opacity: 0.1; z-index: -2; animation: patternShift 60s linear infinite; }
    .green-accent { position: fixed; top: 0; right: 0; width: 400px; height: 400px; background: radial-gradient(circle, rgba(118, 185, 0, 0.2) 0%, transparent 70%); filter: blur(80px); z-index: -1; }
    .dark-accent { position: fixed; bottom: 0; left: 0; width: 400px; height: 400px; background: radial-gradient(circle, rgba(30, 41, 59, 0.3) 0%, transparent 70%); filter: blur(80px); z-index: -1; }
    .header { height: 220px; background: linear-gradient(135deg, var(--nvidia-dark-green), var(--accent-dark)); position: relative; display: flex; flex-direction: column; justify-content: flex-end; padding: 25px 20px 70px 20px; border-radius: 0 0 20px 20px; box-shadow: 0 8px 25px rgba(0, 0, 0, 0.5); }
    .header-content { text-align: center; z-index: 2; }
    .header h1 { font-size: 28px; font-weight: 700; margin-bottom: 8px; color: var(--primary-white); text-shadow: 0 2px 10px rgba(0,0,0,0.5); }
    .header p { font-size: 15px; color: rgba(255, 255, 255, 0.8); }
    .menu-navigation { position: absolute; bottom: -25px; left: 20px; right: 20px; display: flex; background: var(--dark-card-bg); border-radius: 15px; padding: 8px; box-shadow: 0 8px 25px rgba(0, 0, 0, 0.4); border: 2px solid var(--nvidia-green); }
    .menu-btn { flex: 1; padding: 12px 10px; text-align: center; cursor: pointer; border-radius: 10px; font-weight: 600; transition: var(--transition); color: var(--text-mid); font-size: 14px; display: flex; align-items: center; justify-content: center; gap: 8px; position: relative; overflow: hidden; }
    .menu-btn.active { background: linear-gradient(135deg, var(--nvidia-green), var(--nvidia-dark-green)); color: var(--primary-white); transform: scale(1.05); box-shadow: 0 4px 15px rgba(118, 185, 0, 0.4); }
    .main-content { padding: 60px 20px 30px 20px; }
    .plans-container { display: flex; flex-direction: column; gap: 18px; }
    .plan-card { background: var(--dark-card-bg); border-radius: 16px; padding: 20px; border: 1px solid rgba(118, 185, 0, 0.2); position: relative; overflow: hidden; transition: var(--transition); box-shadow: 0 8px 25px rgba(0, 0, 0, 0.3); }
    .plan-card:hover { border-color: var(--nvidia-green); transform: translateY(-8px) scale(1.02); }
    .plan-content { display: flex; align-items: flex-start; gap: 20px; margin-bottom: 16px; }
    .plan-nom { font-size: 20px; font-weight: 700; color: var(--nvidia-green); margin-bottom: 12px; }
    .plan-details { display: flex; flex-direction: column; gap: 8px; }
    .detail-item { display: flex; justify-content: space-between; align-items: center; font-size: 13px; }
    .detail-label { color: var(--text-mid); }
    .detail-value { color: var(--text-light); font-weight: 600; }
    .plan-visual { width: 90px; height: 90px; display: flex; align-items: center; justify-content: center; }
    .plan-image { width: 100%; height: 100%; border-radius: 12px; border: 3px solid var(--nvidia-green); background: var(--dark-bg); overflow: hidden; }
    .plan-image img { width: 100%; height: 100%; object-fit: cover; }
    .action-bar { background: rgba(118, 185, 0, 0.05); border-radius: 12px; padding: 15px; display: flex; align-items: center; justify-content: space-between; border: 1px solid rgba(118, 185, 0, 0.2); }
    .plan-prix { font-size: 22px; font-weight: 700; color: var(--nvidia-green); }
    .btn-investir { padding: 12px 24px; border: none; border-radius: 8px; font-size: 14px; font-weight: 600; cursor: pointer; background: linear-gradient(135deg, var(--nvidia-green), var(--nvidia-dark-green)); color: var(--primary-white); }
    .locked-section { text-align: center; padding: 80px 30px; background: var(--dark-card-bg); border-radius: 20px; border: 3px dashed rgba(118, 185, 0, 0.4); margin-top: 20px; position: relative; }
    .locked-icon { font-size: 64px; color: var(--nvidia-green); margin-bottom: 20px; }
    .locked-title { font-size: 24px; font-weight: 700; color: var(--nvidia-green); margin-bottom: 15px; }
    .locked-message { color: var(--text-mid); font-size: 16px; line-height: 1.6; }
    .popup { display: none; position: fixed; top: 0; left: 0; width: 100%; height: 100%; background: rgba(0,0,0,0.9); backdrop-filter: blur(10px); z-index: 1000; align-items: center; justify-content: center; padding: 20px; }
    .popup-content { background: var(--dark-card-bg); width: 100%; max-width: 380px; border-radius: 20px; overflow: hidden; border: 3px solid var(--nvidia-green); }
    .popup-header { padding: 25px; background: linear-gradient(135deg, var(--nvidia-green), var(--nvidia-dark-green)); color: var(--primary-white); display: flex; justify-content: space-between; align-items: center; }
    .popup-close { background: rgba(255,255,255,0.2); border: none; color: var(--primary-white); font-size: 28px; cursor: pointer; width: 36px; height: 36px; display: flex; align-items: center; justify-content: center; border-radius: 50%; }
    .popup-body { padding: 30px 25px; }
    .popup-details { display: grid; grid-template-columns: 1fr 1fr; gap: 15px; margin-bottom: 25px; }
    .popup-detail { background: rgba(118, 185, 0, 0.05); padding: 15px; border-radius: 10px; text-align: center; border: 1px solid rgba(118, 185, 0, 0.1); }
    .popup-detail-valeur { font-size: 18px; font-weight: 700; color: var(--nvidia-green); margin-bottom: 5px; }
    .popup-detail-label { color: var(--text-mid); font-size: 13px; }
    .popup-btn { width: 100%; padding: 18px; border: none; border-radius: 12px; font-size: 16px; font-weight: 700; cursor: pointer; background: linear-gradient(135deg, var(--nvidia-green), var(--nvidia-dark-green)); color: var(--primary-white); }
    .alert-message { padding: 15px 20px; border-radius: 10px; margin: 20px 0; font-size: 14px; text-align: center; display: none; }
    .alert-error { background: rgba(239, 68, 68, 0.1); border: 1px solid rgba(239, 68, 68, 0.3); color: var(--error); }
    .alert-success { background: rgba(16, 185, 129, 0.1); border: 1px solid rgba(16, 185, 129, 0.3); color: var(--success); }
    .floater-overlay { display: none; position: fixed; top: 0; left: 0; width: 100%; height: 100%; background: rgba(0, 0, 0, 0.9); backdrop-filter: blur(15px); z-index: 2000; align-items: center; justify-content: center; padding: 20px; }
    .floater-content { background: linear-gradient(135deg, var(--dark-card-bg), var(--dark-bg)); width: 100%; max-width: 350px; border-radius: 25px; padding: 40px 30px; text-align: center; border: 3px solid var(--nvidia-green); position: relative; overflow: hidden; }
    .floater-icon { font-size: 80px; color: var(--nvidia-green); margin-bottom: 25px; z-index: 2; }
    .floater-title { font-size: 26px; font-weight: 700; color: var(--nvidia-green); margin-bottom: 15px; z-index: 2; }
    .floater-message { color: var(--text-light); font-size: 16px; line-height: 1.6; margin-bottom: 30px; z-index: 2; }
    .floater-buttons { display: flex; gap: 15px; z-index: 2; }
    .floater-btn { flex: 1; padding: 16px 20px; border: none; border-radius: 12px; font-size: 16px; font-weight: 600; cursor: pointer; }
    .floater-btn-primary { background: linear-gradient(135deg, var(--nvidia-green), var(--nvidia-dark-green)); color: var(--primary-white); }
    .floater-btn-secondary { background: rgba(255, 255, 255, 0.1); color: var(--text-light); border: 2px solid rgba(255, 255, 255, 0.2); }
    .contenu-menu { display: none; }
    .contenu-menu.active { display: block; }
    @keyframes patternShift { 0% { background-position: 0 0; } 100% { background-position: 100px 100px; } }
    </style>
</head>
<body>
    <div class="background"></div>
    <div class="geometric-pattern"></div>
    <div class="green-accent"></div>
    <div class="dark-accent"></div>
    
    <div class="container">
        <div class="header">
            <div class="header-content">
                <h1>NVIDIA Technologie</h1>
                <p>Développez votre patrimoine avec des actions de pointe</p>
            </div>
            
            <div class="menu-navigation">
                <div class="menu-btn vip <%= menu_actif === 'vip' ? 'active' : '' %>" data-menu="vip">
                    <i class="fas fa-crown"></i>
                    <span>Actions VIP</span>
                </div>
                <div class="menu-btn commande <%= menu_actif === 'commande' ? 'active' : '' %>" data-menu="commande">
                    <i class="fas fa-shopping-bag"></i>
                    <span>Mes Commandes</span>
                </div>
            </div>
        </div>
        
        <div class="main-content">
            <div id="alertMessage" class="alert-message"></div>
            
            <div class="contenu-menu <%= menu_actif === 'vip' ? 'active' : '' %>" id="vip-content">
                <div class="plans-container">
                    <% if (plans && plans.length > 0) { %>
                        <% plans.forEach(function(plan, index) { %>
                        <div class="plan-card" style="animation-delay: <%= 0.8 + (index * 0.1) %>s;">
                            <div class="plan-content">
                                <div class="plan-info">
                                    <div class="plan-nom"><%= plan.nom %></div>
                                    <div class="plan-details">
                                        <div class="detail-item">
                                            <span class="detail-label">Revenu quotidien:</span>
                                            <span class="detail-value">+<%= plan.revenu_journalier.toLocaleString() %> FCFA</span>
                                        </div>
                                        <div class="detail-item">
                                            <span class="detail-label">Jours de revenu:</span>
                                            <span class="detail-value"><%= plan.duree_jours %> jours</span>
                                        </div>
                                        <div class="detail-item">
                                            <span class="detail-label">Revenu total:</span>
                                            <span class="detail-value"><%= plan.revenu_total.toLocaleString() %> FCFA</span>
                                        </div>
                                    </div>
                                </div>
                                <div class="plan-visual">
                                    <div class="plan-image">
                                        <img src="assets/vip.jpg" alt="<%= plan.nom %>">
                                    </div>
                                </div>
                            </div>
                            <div class="action-bar">
                                <div class="plan-prix"><%= plan.prix.toLocaleString() %> FCFA</div>
                                <button class="btn-investir" 
                                        data-plan-id="<%= plan.id %>" 
                                        data-nom="<%= plan.nom %>" 
                                        data-prix="<%= plan.prix %>" 
                                        data-gain-journalier="<%= plan.revenu_journalier %>" 
                                        data-duree="<%= plan.duree_jours %>" 
                                        data-gain-total="<%= plan.revenu_total %>">
                                    Investir
                                </button>
                            </div>
                        </div>
                        <% }); %>
                    <% } else { %>
                        <div class="locked-section">
                            <div class="locked-icon"><i class="fas fa-exclamation-circle"></i></div>
                            <div class="locked-title">Aucun Plan Disponible</div>
                            <div class="locked-message">Les plans d'investissement ne sont pas encore configurés.</div>
                        </div>
                    <% } %>
                </div>
            </div>
            
            <div class="contenu-menu <%= menu_actif === 'commande' ? 'active' : '' %>" id="commande-content">
                <div class="locked-section">
                    <div class="locked-icon"><i class="fas fa-exchange-alt"></i></div>
                    <div class="locked-title">Redirection en cours</div>
                    <div class="locked-message">Veuillez patienter...</div>
                </div>
            </div>
        </div>
    </div>
    
    <!-- Popups and Floaters -->
    <div class="popup" id="investPopup">
        <div class="popup-content">
            <div class="popup-header">
                <h3 id="popup-titre">Confirmer l'investissement</h3>
                <button class="popup-close" onclick="fermerPopup()">&times;</button>
            </div>
            <div class="popup-body">
                <div class="popup-details">
                    <div class="popup-detail">
                        <div class="popup-detail-valeur" id="popup-prix">0 FCFA</div>
                        <div class="popup-detail-label">Prix d'achat</div>
                    </div>
                    <div class="popup-detail">
                        <div class="popup-detail-valeur" id="popup-gain-journalier">0 FCFA</div>
                        <div class="popup-detail-label">Gain quotidien</div>
                    </div>
                    <div class="popup-detail">
                        <div class="popup-detail-valeur" id="popup-duree">0 jours</div>
                        <div class="popup-detail-label">Durée totale</div>
                    </div>
                    <div class="popup-detail">
                        <div class="popup-detail-valeur" id="popup-gain-total">0 FCFA</div>
                        <div class="popup-detail-label">Gain total</div>
                    </div>
                </div>
                <button class="popup-btn" id="confirmerInvestBtn">Confirmer l'achat</button>
            </div>
        </div>
    </div>

    <div class="floater-overlay" id="insufficientBalanceFloater">
        <div class="floater-content">
            <div class="floater-icon"><i class="fas fa-wallet"></i></div>
            <div class="floater-title">Solde Insuffisant</div>
            <div class="floater-message">Votre solde actuel est de <strong><%= solde.toLocaleString() %> FCFA</strong>. Veuillez recharger pour continuer.</div>
            <div class="floater-buttons">
                <button class="floater-btn floater-btn-primary" onclick="redirectToDepot()">Recharger</button>
                <button class="floater-btn floater-btn-secondary" onclick="closeFloater()">Annuler</button>
            </div>
        </div>
    </div>

    <script>
    let currentPlan = null;
    const soldeClient = <%= solde %>;

    document.querySelectorAll('.menu-btn').forEach(btn => {
        btn.addEventListener('click', function() {
            const target = this.getAttribute('data-menu');
            if (target === 'commande') {
                window.location.href = 'commandes.php';
                return;
            }
            document.querySelectorAll('.menu-btn').forEach(b => b.classList.remove('active'));
            document.querySelectorAll('.contenu-menu').forEach(c => c.classList.remove('active'));
            this.classList.add('active');
            document.getElementById(target + '-content').classList.add('active');
        });
    });

    document.querySelectorAll('.btn-investir').forEach(btn => {
        btn.addEventListener('click', function() {
            currentPlan = {
                id: this.dataset.planId,
                nom: this.dataset.nom,
                prix: parseInt(this.dataset.prix),
                gainJournalier: this.dataset.gainJournalier,
                duree: this.dataset.duree,
                gainTotal: this.dataset.gainTotal
            };
            if (soldeClient < currentPlan.prix) {
                document.getElementById('insufficientBalanceFloater').style.display = 'flex';
            } else {
                ouvrirPopup(currentPlan);
            }
        });
    });

    function ouvrirPopup(plan) {
        document.getElementById('popup-titre').textContent = plan.nom;
        document.getElementById('popup-prix').textContent = plan.prix.toLocaleString() + ' FCFA';
        document.getElementById('popup-gain-journalier').textContent = plan.gainJournalier.toLocaleString() + ' FCFA';
        document.getElementById('popup-duree').textContent = plan.duree + ' jours';
        document.getElementById('popup-gain-total').textContent = plan.gainTotal.toLocaleString() + ' FCFA';
        document.getElementById('investPopup').style.display = 'flex';
    }

    function fermerPopup() { document.getElementById('investPopup').style.display = 'none'; }
    function closeFloater() { document.getElementById('insufficientBalanceFloater').style.display = 'none'; }
    function redirectToDepot() { window.location.href = 'depot.php'; }

    document.getElementById('confirmerInvestBtn').addEventListener('click', function() {
        if (!currentPlan) return;
        this.disabled = true;
        this.textContent = 'Traitement...';
        
        fetch('process_investissement.php', {
            method: 'POST',
            headers: { 'Content-Type': 'application/x-www-form-urlencoded' },
            body: 'plan_id=' + currentPlan.id
        })
        .then(res => res.json())
        .then(data => {
            if (data.success) {
                window.location.href = 'commandes.php?success=1';
            } else {
                showAlert(data.message || 'Erreur lors de l\'investissement', 'error');
                fermerPopup();
                this.disabled = false;
                this.textContent = 'Confirmer l\'achat';
            }
        })
        .catch(() => {
            showAlert('Erreur de connexion', 'error');
            fermerPopup();
            this.disabled = false;
        });
    });

    function showAlert(message, type) {
        const alert = document.getElementById('alertMessage');
        alert.textContent = message;
        alert.className = 'alert-message alert-' + type;
        alert.style.display = 'block';
        setTimeout(() => alert.style.display = 'none', 5000);
    }
    </script>
</body>
</html>