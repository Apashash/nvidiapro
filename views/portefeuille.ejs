<!DOCTYPE html>
<html lang="fr">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0, maximum-scale=1.0, user-scalable=no">
    <title>Portefeuille - NVIDIA Technologie</title>
    <link href="https://fonts.googleapis.com/css2?family=Poppins:wght@300;400;500;600;700;800&display=swap" rel="stylesheet">
    <link rel="stylesheet" href="https://cdnjs.cloudflare.com/ajax/libs/font-awesome/6.5.0/css/all.min.css">
    <style>
        * { margin:0; padding:0; box-sizing:border-box; font-family:'Poppins','Segoe UI',sans-serif; }
        body { background:#F5EFE6; color:#3D2B1F; min-height:100vh; padding-bottom:90px; }
        .container { max-width:430px; margin:0 auto; }

        .page-header {
            background: linear-gradient(135deg, #D4921F, #A0631A);
            padding: 50px 20px 28px; display:flex; align-items:center; gap:14px;
        }
        .back-btn {
            width:36px; height:36px; border-radius:50%;
            background:rgba(255,255,255,0.2); display:flex; align-items:center;
            justify-content:center; color:#fff; text-decoration:none; font-size:16px; flex-shrink:0;
        }
        .header-txt h1 { font-size:20px; font-weight:700; color:#fff; }
        .header-txt p { font-size:13px; color:rgba(255,255,255,0.85); margin-top:2px; }

        .content { padding:16px; }

        .alert {
            padding:13px 16px; border-radius:12px; margin-bottom:16px;
            font-size:14px; display:flex; align-items:center; gap:9px;
        }
        .alert-error { background:#FFF0EE; border:1px solid #F5A9A0; color:#C0392B; }
        .alert-success { background:#F0FFF4; border:1px solid #86EFAC; color:#166534; }

        .section-card {
            background:#fff; border-radius:16px; border:1px solid #F0E0C8;
            padding:20px 18px; margin-bottom:16px;
            box-shadow:0 2px 10px rgba(196,125,30,0.08);
        }
        .section-card h3 {
            color:#C47D1E; font-size:15px; font-weight:700; margin-bottom:16px;
            display:flex; align-items:center; gap:9px; padding-bottom:12px;
            border-bottom:1px solid #F0E0C8;
        }
        .no-pin-warning {
            background:#FFF0EE; border:1px solid #F5A9A0; border-radius:10px;
            padding:12px 14px; margin-bottom:14px; color:#C0392B; font-size:13px;
            display:flex; align-items:center; gap:8px;
        }
        .form-group { margin-bottom:14px; }
        .form-label { display:block; font-size:12px; font-weight:600; color:#A87D50; margin-bottom:6px; }
        .form-input {
            width:100%; background:#FBF5EC; border:1.5px solid #E8D5B0;
            border-radius:11px; padding:12px 14px; color:#3D2B1F;
            font-size:14px; font-family:'Poppins',sans-serif; outline:none;
            transition:border-color 0.2s;
        }
        .form-input:focus { border-color:#C47D1E; box-shadow:0 0 0 3px rgba(196,125,30,0.10); }
        .form-input option { background:#fff; color:#3D2B1F; }
        .btn-submit {
            width:100%; background:linear-gradient(135deg,#D4921F,#B07018);
            color:#fff; border:none; border-radius:12px; padding:14px;
            font-weight:700; font-size:15px; cursor:pointer; margin-top:6px;
            font-family:'Poppins',sans-serif; box-shadow:0 4px 14px rgba(196,125,30,0.35);
            transition:transform 0.2s;
        }
        .btn-submit:hover { transform:translateY(-2px); }

        .wallet-grid {
            display:grid; grid-template-columns:1fr 1fr; gap:12px; margin-bottom:16px;
        }
        .wallet-item label {
            display:block; font-size:11px; font-weight:700;
            color:#A87D50; text-transform:uppercase; letter-spacing:0.5px;
        }
        .wallet-item span { display:block; color:#3D2B1F; font-weight:600; margin-top:4px; font-size:14px; }

        .pin-msg { margin-top:10px; font-size:13px; text-align:center; }
    </style>
</head>
<body>
<%- include('partials/menu', { page: 'compte' }) %>
<div class="container">
    <div class="page-header">
        <a href="/compte" class="back-btn"><i class="fas fa-chevron-left"></i></a>
        <div class="header-txt">
            <h1>Portefeuille</h1>
            <p>Configurez votre portefeuille de retrait</p>
        </div>
    </div>

    <div class="content">
        <% if (error) { %><div class="alert alert-error"><i class="fas fa-exclamation-triangle"></i> <%= error %></div><% } %>
        <% if (success) { %><div class="alert alert-success"><i class="fas fa-check-circle"></i> <%= success %></div><% } %>

        <!-- PIN Section -->
        <div class="section-card">
            <h3><i class="fas fa-lock"></i> Code PIN de Transaction</h3>
            <% if (!has_transaction_password) { %>
                <div class="no-pin-warning"><i class="fas fa-exclamation-circle"></i> Vous devez d'abord créer un code PIN avant de configurer votre portefeuille.</div>
            <% } %>
            <div class="form-group">
                <label class="form-label">Ancien PIN (vide si première création)</label>
                <input type="password" id="old_pin" maxlength="4" placeholder="****" inputmode="numeric" class="form-input">
            </div>
            <div class="form-group">
                <label class="form-label">Nouveau PIN (4 chiffres)</label>
                <input type="password" id="new_pin" maxlength="4" placeholder="****" inputmode="numeric" class="form-input">
            </div>
            <div class="form-group">
                <label class="form-label">Confirmer le nouveau PIN</label>
                <input type="password" id="confirm_pin" maxlength="4" placeholder="****" inputmode="numeric" class="form-input">
            </div>
            <button class="btn-submit" onclick="updatePin()"><i class="fas fa-save"></i> Enregistrer le PIN</button>
            <div class="pin-msg" id="pinMsg"></div>
        </div>

        <!-- Wallet Form -->
        <% if (has_transaction_password) { %>
        <div class="section-card">
            <h3><i class="fas fa-credit-card"></i> <%= has_wallet ? 'Modifier mon Portefeuille' : 'Créer mon Portefeuille' %></h3>

            <% if (has_wallet && wallet_data) { %>
            <div class="wallet-grid">
                <div class="wallet-item"><label>Nom</label><span><%= wallet_data.nom_portefeuille %></span></div>
                <div class="wallet-item"><label>Pays</label><span><%= wallet_data.pays %></span></div>
                <div class="wallet-item"><label>Méthode</label><span><%= wallet_data.methode_paiement %></span></div>
                <div class="wallet-item"><label>Numéro</label><span><%= wallet_data.numero_telephone %></span></div>
            </div>
            <% } %>

            <form action="/portefeuille" method="POST">
                <div class="form-group">
                    <label class="form-label">Nom du portefeuille</label>
                    <input type="text" name="nom_portefeuille"
                           value="<%= has_wallet && wallet_data ? wallet_data.nom_portefeuille : '' %>"
                           placeholder="Ex: Mon compte MTN" required class="form-input">
                </div>
                <div class="form-group">
                    <label class="form-label">Pays</label>
                    <select name="pays" id="paysSelect" onchange="updateMethods()" class="form-input">
                        <option value="">-- Sélectionner --</option>
                        <% Object.keys(pays_methodes).forEach(p => { %>
                            <option value="<%= p %>" <%= (has_wallet && wallet_data && wallet_data.pays === p) ? 'selected' : '' %>><%= p %></option>
                        <% }); %>
                    </select>
                </div>
                <div class="form-group">
                    <label class="form-label">Méthode de paiement</label>
                    <select name="methode_paiement" id="methodeSelect" class="form-input">
                        <option value="">-- Sélectionner d'abord un pays --</option>
                    </select>
                </div>
                <div class="form-group">
                    <label class="form-label">Numéro de téléphone</label>
                    <input type="tel" name="numero_telephone"
                           value="<%= has_wallet && wallet_data ? wallet_data.numero_telephone : '' %>"
                           placeholder="Ex: 699123456" inputmode="numeric" required class="form-input">
                </div>
                <div class="form-group">
                    <label class="form-label">Confirmer le numéro</label>
                    <input type="tel" name="confirm_telephone" placeholder="Répéter le numéro"
                           inputmode="numeric" required class="form-input">
                </div>
                <div class="form-group">
                    <label class="form-label">Code PIN de transaction</label>
                    <input type="password" name="transaction_password" maxlength="4"
                           placeholder="****" inputmode="numeric" required class="form-input">
                </div>
                <button type="submit" class="btn-submit">
                    <i class="fas fa-save"></i> <%= has_wallet ? 'Mettre à jour' : 'Créer le portefeuille' %>
                </button>
            </form>
        </div>
        <% } %>
    </div>
</div>

<script>
const paysMethodes = <%- JSON.stringify(pays_methodes) %>;
const methodeNoms = <%- JSON.stringify(methodes_noms) %>;

function updateMethods() {
    const pays = document.getElementById('paysSelect').value;
    const select = document.getElementById('methodeSelect');
    select.innerHTML = '<option value="">-- Sélectionner --</option>';
    if (pays && paysMethodes[pays]) {
        paysMethodes[pays].forEach(m => {
            const opt = document.createElement('option');
            opt.value = m;
            opt.textContent = methodeNoms[m] || m;
            <% if (has_wallet && wallet_data) { %>
            if (m === '<%= has_wallet && wallet_data ? wallet_data.methode_paiement : '' %>') opt.selected = true;
            <% } %>
            select.appendChild(opt);
        });
    }
}
window.addEventListener('DOMContentLoaded', () => {
    if (document.getElementById('paysSelect').value) updateMethods();
});
async function updatePin() {
    const old_pin = document.getElementById('old_pin').value;
    const new_pin = document.getElementById('new_pin').value;
    const confirm_pin = document.getElementById('confirm_pin').value;
    const msg = document.getElementById('pinMsg');
    try {
        const res = await fetch('/update_transaction_password', {
            method: 'POST',
            headers: { 'Content-Type': 'application/x-www-form-urlencoded' },
            body: `old_pin=${old_pin}&new_pin=${new_pin}&confirm_pin=${confirm_pin}`
        });
        const data = await res.json();
        msg.textContent = data.message;
        msg.style.color = data.success ? '#16A34A' : '#DC2626';
        if (data.success) {
            document.getElementById('old_pin').value = '';
            document.getElementById('new_pin').value = '';
            document.getElementById('confirm_pin').value = '';
            setTimeout(() => location.reload(), 1500);
        }
    } catch(e) { msg.textContent = 'Erreur réseau'; msg.style.color = '#DC2626'; }
}
</script>
</body>
</html>
