<% 
// Logic equivalent to PHP session and DB initialization
// user, filleuls_actifs, filleuls_inscrits, est_eligible, message_eligibilite,
// error, success are passed to the template; code_message is derived below.
const code_message = success
    ? `<div class="alert success">✅ ${success}</div>`
    : (error ? `<div class="alert error">❌ ${error}</div>` : '');
%>
<!DOCTYPE html>
<html lang="fr">
<head>
    <meta charset="UTF-8">
    <title>Cadeaux - Altiora Capital Africa</title>
    <meta name="viewport" content="width=device-width, initial-scale=1.0, maximum-scale=1.0, user-scalable=no">
    <link href="https://fonts.googleapis.com/css2?family=Poppins:wght@300;400;500;600;700;800&display=swap" rel="stylesheet">
    <link rel="stylesheet" href="https://cdnjs.cloudflare.com/ajax/libs/font-awesome/6.5.0/css/all.min.css">
    <style>
        * { margin:0; padding:0; box-sizing:border-box; font-family:'Poppins','Segoe UI',sans-serif; -webkit-tap-highlight-color:transparent; }
        body { background:#F5EFE6; color:#3D2B1F; min-height:100vh; padding-bottom:90px; }
        .container { max-width:430px; margin:0 auto; }

        .page-header {
            background: linear-gradient(135deg, #D4921F, #A0631A);
            padding: 50px 20px 28px; text-align:center; color:#fff;
        }
        .page-header h1 { font-size:22px; font-weight:800; margin-bottom:4px; }
        .page-header p { font-size:13px; color:rgba(255,255,255,0.85); }

        .content { padding:16px; }

        /* Choice cards */
        .choice-grid { display:flex; flex-direction:column; gap:14px; margin-bottom:14px; }
        .choice-card {
            background:#fff; border-radius:18px; padding:22px 18px;
            border:1px solid #F0E0C8; cursor:pointer; transition:all 0.2s;
            display:flex; align-items:center; gap:16px;
            box-shadow:0 4px 14px rgba(196,125,30,0.10);
        }
        .choice-card:hover { border-color:#C47D1E; transform:translateY(-3px); box-shadow:0 8px 24px rgba(196,125,30,0.18); }
        .choice-icon {
            width:56px; height:56px; border-radius:16px;
            background:linear-gradient(135deg,#D4921F,#B07018);
            display:flex; align-items:center; justify-content:center;
            color:#fff; font-size:22px; flex-shrink:0;
        }
        .choice-text h3 { color:#3D2B1F; font-size:16px; font-weight:700; margin-bottom:4px; }
        .choice-text p { color:#A87D50; font-size:13px; line-height:1.4; }

        /* Back btn */
        .back-btn {
            display:inline-flex; align-items:center; gap:8px;
            background:#FBF5EC; border:1.5px solid #E8D5B0; border-radius:20px;
            padding:9px 18px; font-size:13px; font-weight:600; color:#7D5A38;
            cursor:pointer; margin-bottom:16px; transition:background 0.2s;
        }
        .back-btn:hover { background:#F0E0C8; }

        /* Creation / Usage sections */
        .section-panel { display:none; }
        .section-panel.active { display:block; }

        .panel-card {
            background:#fff; border-radius:16px; border:1px solid #F0E0C8;
            padding:20px 18px; margin-bottom:14px;
            box-shadow:0 2px 10px rgba(196,125,30,0.08);
        }
        .panel-title { color:#C47D1E; font-size:16px; font-weight:700; margin-bottom:16px; text-align:center; }

        .eligibility-box {
            background:rgba(196,125,30,0.07); border:1px solid rgba(196,125,30,0.2);
            border-radius:12px; padding:16px; margin-bottom:16px;
        }
        .elig-title { font-size:14px; font-weight:700; color:#C47D1E; margin-bottom:8px;
            display:flex; align-items:center; gap:8px; }
        .elig-desc { font-size:13px; color:#7D5A38; line-height:1.5; margin-bottom:12px; }

        .stats-grid { display:grid; grid-template-columns:1fr 1fr; gap:12px; margin-bottom:14px; }
        .stat-cell {
            background:#FBF5EC; border-radius:11px; padding:14px; text-align:center;
            border:1px solid #F0E0C8;
        }
        .stat-val { font-size:20px; font-weight:800; color:#C47D1E; }
        .stat-lbl { font-size:11px; color:#A87D50; margin-top:3px; font-weight:600; }

        .alert { padding:12px 14px; border-radius:10px; font-size:13px; font-weight:500; margin-bottom:12px; }
        .alert.success { background:#F0FFF4; border:1px solid #86EFAC; color:#166534; }
        .alert.error { background:#FFF0EE; border:1px solid #F5A9A0; color:#C0392B; }
        .alert.info { background:rgba(196,125,30,0.08); border:1px solid rgba(196,125,30,0.2); color:#92660A; }

        .commission-box {
            background:#FBF5EC; border-radius:11px; padding:14px; margin-bottom:16px;
            border:1px solid #F0E0C8;
        }
        .comm-title { font-size:13px; font-weight:700; color:#C47D1E; margin-bottom:6px; display:flex; align-items:center; gap:7px; }
        .comm-desc { font-size:12px; color:#7D5A38; line-height:1.4; }

        .btn-primary {
            width:100%; background:linear-gradient(135deg,#D4921F,#B07018);
            color:#fff; border:none; border-radius:14px; padding:16px;
            font-size:15px; font-weight:700; cursor:pointer;
            box-shadow:0 5px 16px rgba(196,125,30,0.38); transition:transform 0.2s;
            font-family:'Poppins',sans-serif; display:flex; align-items:center;
            justify-content:center; gap:9px;
        }
        .btn-primary:hover:not(:disabled) { transform:translateY(-2px); }
        .btn-primary:disabled { background:#E8D5B0; color:#A87D50; cursor:not-allowed; transform:none; box-shadow:none; }

        .form-group { margin-bottom:14px; }
        .form-label { display:block; font-size:12px; font-weight:600; color:#A87D50; margin-bottom:6px; }
        .form-input {
            width:100%; background:#FBF5EC; border:1.5px solid #E8D5B0;
            border-radius:11px; padding:13px 14px; color:#3D2B1F; font-size:14px;
            font-family:'Poppins',sans-serif; outline:none; transition:border-color 0.2s;
        }
        .form-input:focus { border-color:#C47D1E; }
    </style>
</head>
<body>
<%- include('partials/menu', { page: 'compte' }) %>

<div class="container">
    <div class="page-header">
        <h1><i class="fas fa-gift"></i> Cadeaux</h1>
        <p>Utilisez un code cadeau</p>
    </div>

    <div class="content">
        <div class="panel-card">
            <div class="panel-title">Utiliser un code cadeau</div>
            <%- code_message %>
            <form method="POST">
                <div class="form-group">
                    <label class="form-label" for="code_cadeau">Code cadeau</label>
                    <input type="text" id="code_cadeau" name="code" class="form-input"
                           placeholder="Ex: ALTIORA2026" required>
                </div>
                <button type="submit" class="btn-primary"><i class="fas fa-gift"></i> Utiliser le code</button>
            </form>
        </div>
    </div>
</div>

<script>
document.addEventListener('wheel', e => { if (e.ctrlKey) e.preventDefault(); }, { passive: false });
document.addEventListener('gesturestart', e => e.preventDefault());
</script>
</body>
</html>
