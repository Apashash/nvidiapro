<!DOCTYPE html>
<html lang="fr">
<head>
  <meta charset="UTF-8">
  <meta name="viewport" content="width=device-width, initial-scale=1.0">
  <title><%= pageTitle %> — Administration</title>
  <link rel="stylesheet" href="https://cdnjs.cloudflare.com/ajax/libs/font-awesome/6.4.0/css/all.min.css">
  <% if (currentPage === 'dashboard') { %>
  <script src="https://cdn.jsdelivr.net/npm/chart.js@4.4.0/dist/chart.umd.min.js"></script>
  <% } %>
  <style>
    * { margin:0; padding:0; box-sizing:border-box; font-family:'Segoe UI','Helvetica Neue',Arial,sans-serif; }
    body { background:#F5F5F0; color:#1a1a1a; min-height:100vh; overflow-x:hidden; }

    /* ── Top bar ── */
    .topbar {
      background:#E8931A; padding:0 16px; height:56px;
      display:flex; align-items:center; justify-content:space-between;
      position:sticky; top:0; z-index:300;
    }
    .topbar-btn {
      width:40px; height:40px; background:rgba(255,255,255,0.2); border:none;
      border-radius:10px; color:#fff; font-size:1.1rem; cursor:pointer;
      display:flex; align-items:center; justify-content:center; text-decoration:none;
    }
    .topbar-title { color:#fff; font-size:1.05rem; font-weight:700; }

    /* ── Sidebar overlay ── */
    .overlay {
      position:fixed; inset:0; background:rgba(0,0,0,0.45); z-index:400;
      opacity:0; pointer-events:none; transition:opacity 0.25s;
    }
    .overlay.open { opacity:1; pointer-events:all; }

    .sidebar {
      position:fixed; top:0; left:0; width:290px; height:100%;
      background:#fff; z-index:500;
      transform:translateX(-100%); transition:transform 0.28s cubic-bezier(.4,0,.2,1);
      display:flex; flex-direction:column; overflow:hidden;
    }
    .sidebar.open { transform:translateX(0); }

    .sidebar-header { background:#E8931A; padding:22px 20px 18px; position:relative; flex-shrink:0; }
    .sidebar-close {
      position:absolute; top:14px; right:14px; width:32px; height:32px;
      background:rgba(255,255,255,0.25); border:none; border-radius:50%;
      color:#fff; font-size:1rem; cursor:pointer;
      display:flex; align-items:center; justify-content:center;
    }
    .sidebar-shield {
      width:50px; height:50px; background:rgba(255,255,255,0.25);
      border-radius:14px; display:flex; align-items:center; justify-content:center;
      margin-bottom:12px; font-size:1.4rem; color:#fff;
    }
    .sidebar-header h2 { color:#fff; font-size:1.15rem; font-weight:800; }
    .sidebar-header p  { color:rgba(255,255,255,0.8); font-size:0.78rem; margin-top:2px; }

    .sidebar-nav { flex:1; overflow-y:auto; padding:8px 0; }
    .nav-item {
      display:flex; align-items:center; gap:14px; padding:13px 20px;
      border-left:3px solid transparent; text-decoration:none; transition:background 0.15s;
    }
    .nav-item:hover { background:#FFF8F0; }
    .nav-item.active { background:#FFF3E0; border-left-color:#E8931A; }
    .nav-item.active .nav-label { color:#E8931A; font-weight:700; }
    .nav-icon {
      width:36px; height:36px; border-radius:10px;
      display:flex; align-items:center; justify-content:center;
      font-size:0.95rem; flex-shrink:0;
    }
    .nav-label { font-size:0.95rem; color:#2a2a2a; font-weight:500; }

    .sidebar-footer { padding:14px 16px; border-top:1px solid #f0f0f0; }
    .sidebar-footer a {
      display:flex; align-items:center; justify-content:center; gap:8px;
      background:#fff; border:1.5px solid #e0e0e0; border-radius:12px;
      padding:12px; color:#555; text-decoration:none;
      font-size:0.9rem; font-weight:600; transition:background 0.15s;
    }
    .sidebar-footer a:hover { background:#f5f5f5; }

    /* ── Main ── */
    .main { padding:16px; max-width:680px; margin:0 auto; }

    /* ── Stat cards ── */
    .stats-grid { display:grid; grid-template-columns:1fr 1fr; gap:12px; margin-bottom:16px; }
    .stat-card { background:#fff; border-radius:16px; padding:18px 16px; box-shadow:0 1px 6px rgba(0,0,0,0.07); }
    .stat-icon { width:42px; height:42px; border-radius:12px; display:flex; align-items:center; justify-content:center; margin-bottom:10px; font-size:1.15rem; }
    .stat-num  { font-size:1.65rem; font-weight:800; color:#1a1a1a; line-height:1; }
    .stat-sub  { font-size:0.7rem; color:#888; font-weight:600; margin-top:2px; }
    .stat-label{ font-size:0.82rem; color:#555; margin-top:4px; }

    /* ── Chart card ── */
    .chart-card { background:#fff; border-radius:16px; padding:18px 16px; box-shadow:0 1px 6px rgba(0,0,0,0.07); margin-bottom:16px; }
    .chart-head { display:flex; align-items:center; gap:10px; margin-bottom:4px; }
    .chart-icon { width:36px; height:36px; background:#FFF3E0; border-radius:10px; display:flex; align-items:center; justify-content:center; }
    .chart-icon i { color:#E8931A; }
    .chart-card h3 { font-size:1rem; font-weight:700; }
    .chart-card .sub { font-size:0.78rem; color:#888; margin-bottom:14px; }
    .chart-legend { display:flex; flex-wrap:wrap; gap:10px; margin-top:10px; }
    .legend-dot { width:10px; height:10px; border-radius:3px; }
    .legend-item { display:flex; align-items:center; gap:5px; font-size:0.75rem; color:#555; }

    /* Today vs Yesterday mini cards */
    .tvh-grid { display:grid; grid-template-columns:1fr 1fr; gap:10px; margin-top:12px; }
    .tvh-card { background:#fff; border-radius:12px; padding:12px 14px; border:1px solid #f0f0f0; }
    .tvh-label { font-size:0.72rem; color:#888; margin-bottom:4px; }
    .tvh-num   { font-size:1.15rem; font-weight:800; }
    .tvh-num small { font-size:0.72rem; font-weight:600; color:#888; }
    .tvh-diff  { font-size:0.72rem; margin-top:2px; }
    .tvh-diff.down { color:#ef4444; }
    .tvh-diff.up   { color:#22c55e; }

    /* ── Revenue card ── */
    .rev-card { background:#fff; border-radius:16px; padding:18px 16px; box-shadow:0 1px 6px rgba(0,0,0,0.07); margin-bottom:16px; }
    .rev-head { display:flex; align-items:center; gap:10px; margin-bottom:8px; }
    .rev-icon { width:40px; height:40px; background:#E8F5E9; border-radius:12px; display:flex; align-items:center; justify-content:center; }
    .rev-icon i { color:#22c55e; font-size:1.1rem; }
    .rev-card h3 { font-size:1rem; font-weight:700; }
    .rev-card .rev-sub { font-size:0.78rem; color:#888; }
    .rev-card p { font-size:0.85rem; color:#555; line-height:1.5; margin-bottom:14px; }
    .btn-rev {
      width:100%; background:#22c55e; color:#fff; border:none; border-radius:12px;
      padding:14px; font-size:0.95rem; font-weight:700; cursor:pointer;
      display:flex; align-items:center; justify-content:center; gap:8px; transition:background 0.2s;
    }
    .btn-rev:hover { background:#16a34a; }
    .btn-rev:disabled { background:#9ca3af; cursor:not-allowed; }

    /* ── Data card ── */
    .data-card { background:#fff; border-radius:16px; overflow:hidden; box-shadow:0 1px 6px rgba(0,0,0,0.07); margin-bottom:16px; }
    .data-head { padding:14px 16px; border-bottom:1px solid #f5f5f5; display:flex; align-items:center; justify-content:space-between; }
    .data-head h3 { font-size:0.95rem; font-weight:700; }
    .data-count { font-size:0.78rem; color:#888; background:#f5f5f5; padding:3px 10px; border-radius:20px; }
    .search-wrap { padding:12px 16px; border-bottom:1px solid #f5f5f5; }
    .search-wrap input {
      width:100%; background:#F5F5F0; border:1.5px solid #e8e8e8; border-radius:10px;
      padding:10px 14px; font-size:0.88rem; outline:none; color:#1a1a1a;
    }
    .search-wrap input:focus { border-color:#E8931A; }
    .scroll-x { overflow-x:auto; }
    table { width:100%; border-collapse:collapse; min-width:500px; }
    th { background:#FAFAF8; color:#888; font-size:0.72rem; text-transform:uppercase; letter-spacing:0.5px; padding:10px 14px; text-align:left; font-weight:700; border-bottom:1px solid #f0f0f0; }
    td { padding:10px 14px; border-bottom:1px solid #f9f9f9; font-size:0.85rem; vertical-align:middle; }
    tr:last-child td { border-bottom:none; }
    tr:hover td { background:#FAFAF8; }

    .badge { display:inline-block; padding:3px 10px; border-radius:20px; font-size:0.72rem; font-weight:700; }
    .badge-pending  { background:#FFF7ED; color:#EA580C; }
    .badge-valid    { background:#F0FDF4; color:#16a34a; }
    .badge-rejected { background:#FEF2F2; color:#dc2626; }
    .badge-admin    { background:#EEF2FF; color:#4f46e5; }
    .badge-vip      { background:#FFF7ED; color:#E8931A; }

    .btn-xs { padding:5px 11px; border-radius:7px; border:none; cursor:pointer; font-size:0.72rem; font-weight:700; margin:2px; white-space:nowrap; }
    .btn-v  { background:#F0FDF4; color:#16a34a; }
    .btn-r  { background:#FEF2F2; color:#dc2626; }
    .btn-e  { background:#EFF6FF; color:#2563eb; }
    .btn-v:hover { background:#dcfce7; }
    .btn-r:hover { background:#fee2e2; }
    .btn-e:hover { background:#dbeafe; }

    .empty { text-align:center; padding:40px; color:#aaa; font-size:0.9rem; }

    /* ── Modal ── */
    .modal-overlay {
      position:fixed; inset:0; background:rgba(0,0,0,0.5); z-index:600;
      display:flex; align-items:center; justify-content:center; padding:20px;
      opacity:0; pointer-events:none; transition:opacity 0.2s;
    }
    .modal-overlay.open { opacity:1; pointer-events:all; }
    .modal-box { background:#fff; border-radius:20px; padding:24px; width:100%; max-width:380px; box-shadow:0 20px 60px rgba(0,0,0,0.2); }
    .modal-box h3 { font-size:1rem; font-weight:700; margin-bottom:16px; }
    .modal-box label { display:block; font-size:0.8rem; color:#888; font-weight:600; margin:12px 0 5px; }
    .modal-box input { width:100%; background:#F5F5F0; border:1.5px solid #e8e8e8; border-radius:10px; padding:11px 14px; color:#1a1a1a; font-size:0.9rem; outline:none; }
    .modal-box input:focus { border-color:#E8931A; }
    .modal-btns { display:flex; gap:10px; margin-top:18px; }
    .modal-btns button { flex:1; padding:12px; border:none; border-radius:12px; cursor:pointer; font-weight:700; font-size:0.9rem; }
    .m-cancel  { background:#F5F5F0; color:#555; }
    .m-confirm { background:#E8931A; color:#fff; }

    /* ── Toast ── */
    .toast {
      position:fixed; bottom:24px; left:50%; transform:translateX(-50%) translateY(80px);
      background:#1a1a1a; color:#fff; padding:12px 22px; border-radius:12px;
      font-size:0.88rem; font-weight:600; z-index:700; transition:transform 0.3s;
      white-space:nowrap; box-shadow:0 4px 20px rgba(0,0,0,0.3);
    }
    .toast.show { transform:translateX(-50%) translateY(0); }
    .toast.ok  { background:#16a34a; }
    .toast.err { background:#dc2626; }

    @media(min-width:600px) {
      .main { padding:20px; }
      .stats-grid { grid-template-columns:repeat(4,1fr); }
    }
  </style>
</head>
<body>

<!-- Top bar -->
<div class="topbar">
  <button class="topbar-btn" id="menuBtn"><i class="fas fa-bars"></i></button>
  <span class="topbar-title"><%= pageTitle %></span>
  <a href="/adminxyz/logout" class="topbar-btn" title="Déconnexion"><i class="fas fa-sign-out-alt"></i></a>
</div>

<!-- Overlay -->
<div class="overlay" id="overlay" onclick="closeSidebar()"></div>

<!-- Sidebar -->
<aside class="sidebar" id="sidebar">
  <div class="sidebar-header">
    <button class="sidebar-close" onclick="closeSidebar()"><i class="fas fa-times"></i></button>
    <div class="sidebar-shield"><i class="fas fa-shield-halved"></i></div>
    <h2>Administration</h2>
    <p>NVIDIA Technology</p>
  </div>

  <nav class="sidebar-nav">
    <% const nav = [
      { page:'dashboard',    href:'/adminxyz/dashboard',    icon:'fas fa-chart-pie',          bg:'#FFF3E0', color:'#E8931A', label:'Tableau de bord' },
      { page:'plans',        href:'/adminxyz/plans',        icon:'fas fa-chart-line',          bg:'#F0FDF4', color:'#22c55e', label:'Plans VIP' },
      { page:'utilisateurs', href:'/adminxyz/utilisateurs', icon:'fas fa-users',               bg:'#EFF6FF', color:'#3b82f6', label:'Utilisateurs' },
      { page:'depots',       href:'/adminxyz/depots',       icon:'fas fa-arrow-down',          bg:'#F0FDF4', color:'#22c55e', label:'Dépôts' },
      { page:'retraits',     href:'/adminxyz/retraits',     icon:'fas fa-hand-holding-dollar', bg:'#EEF2FF', color:'#6366f1', label:'Retraits' },
      { page:'cadeaux',      href:'/adminxyz/cadeaux',      icon:'fas fa-gift',                bg:'#FFF7ED', color:'#E8931A', label:'Cadeaux VIP' },
      { page:'salaires',     href:'/adminxyz/salaires',     icon:'fas fa-money-bill-wave',     bg:'#F0FDF4', color:'#22c55e', label:'Salaires VIP' },
      { page:'transactions', href:'/adminxyz/transactions', icon:'fas fa-receipt',             bg:'#F5F3FF', color:'#7c3aed', label:'Transactions' },
      { page:'affiches',     href:'/adminxyz/affiches',     icon:'fas fa-image',               bg:'#FFF7ED', color:'#E8931A', label:'Affiches' },
      { page:'parametres',   href:'/adminxyz/parametres',   icon:'fas fa-gear',                bg:'#F5F5F0', color:'#6b7280', label:'Paramètres' },
    ]; %>
    <% nav.forEach(item => { %>
    <a href="<%= item.href %>" class="nav-item <%= currentPage === item.page ? 'active' : '' %>">
      <span class="nav-icon" style="background:<%= item.bg %>">
        <i class="<%= item.icon %>" style="color:<%= item.color %>"></i>
      </span>
      <span class="nav-label"><%= item.label %></span>
    </a>
    <% }); %>
  </nav>

  <div class="sidebar-footer">
    <a href="/"><i class="fas fa-house" style="color:#E8931A"></i> Retour à l'accueil</a>
  </div>
</aside>

<!-- ════ MAIN CONTENT ════ -->
<div class="main">

<%# ── DASHBOARD ──────────────────────────────────────────────────────── %>
<% if (currentPage === 'dashboard') { %>

  <div class="stats-grid">
    <div class="stat-card">
      <div class="stat-icon" style="background:#EFF6FF"><i class="fas fa-users" style="color:#3b82f6"></i></div>
      <div class="stat-num"><%= stats_users.total || 0 %></div>
      <div class="stat-label">Utilisateurs</div>
    </div>
    <div class="stat-card">
      <div class="stat-icon" style="background:#F0FDF4"><i class="fas fa-chart-line" style="color:#22c55e"></i></div>
      <div class="stat-num"><%= stats_plans_actifs.total || 0 %></div>
      <div class="stat-label">Plans actifs</div>
    </div>
    <div class="stat-card">
      <div class="stat-icon" style="background:#FFF7ED"><i class="fas fa-arrow-down" style="color:#E8931A"></i></div>
      <div class="stat-num"><%= (parseFloat(stats_depots.somme)||0).toLocaleString('fr-FR') %></div>
      <div class="stat-sub">FCFA</div>
      <div class="stat-label">Dépôts validés</div>
    </div>
    <div class="stat-card">
      <div class="stat-icon" style="background:#EEF2FF"><i class="fas fa-hand-holding-dollar" style="color:#6366f1"></i></div>
      <div class="stat-num"><%= (parseFloat(stats_retraits.somme)||0).toLocaleString('fr-FR') %></div>
      <div class="stat-sub">FCFA</div>
      <div class="stat-label">Retraits validés</div>
    </div>
    <div class="stat-card">
      <div class="stat-icon" style="background:#FFF7ED"><i class="fas fa-hourglass-half" style="color:#E8931A"></i></div>
      <div class="stat-num"><%= stats_pending_depots.total || 0 %></div>
      <div class="stat-label">Dépôts en attente</div>
    </div>
    <div class="stat-card">
      <div class="stat-icon" style="background:#FEF2F2"><i class="fas fa-clock" style="color:#ef4444"></i></div>
      <div class="stat-num"><%= stats_pending_retraits.total || 0 %></div>
      <div class="stat-label">Retraits en attente</div>
    </div>
    <div class="stat-card">
      <div class="stat-icon" style="background:#F0FDF4"><i class="fas fa-briefcase" style="color:#22c55e"></i></div>
      <div class="stat-num"><%= stats_avec_invest.total || 0 %></div>
      <div class="stat-label">Avec investissement</div>
    </div>
    <div class="stat-card">
      <div class="stat-icon" style="background:#EEF2FF"><i class="fas fa-user-check" style="color:#6366f1"></i></div>
      <div class="stat-num"><%= stats_users.total || 0 %></div>
      <div class="stat-label">Total inscrits</div>
    </div>
  </div>

  <!-- Today vs Yesterday -->
  <div class="chart-card">
    <div class="chart-head">
      <div class="chart-icon"><i class="fas fa-chart-bar"></i></div>
      <div style="flex:1">
        <h3>Aujourd'hui vs Hier</h3>
      </div>
      <div style="display:flex;gap:10px;font-size:0.75rem;color:#888">
        <span><span style="display:inline-block;width:10px;height:10px;background:#1a1a1a;border-radius:2px;margin-right:4px"></span>Auj.</span>
        <span><span style="display:inline-block;width:10px;height:10px;background:#ccc;border-radius:2px;margin-right:4px"></span>Hier</span>
      </div>
    </div>
    <p class="sub">Comparaison des transactions</p>
    <canvas id="tvhChart" height="160"></canvas>
    <div class="tvh-grid">
      <div class="tvh-card" style="border-left:3px solid #22c55e">
        <div class="tvh-label">Dépôts auj. <span style="color:#888">(<%= chartData.tvh.dep_today_count %>)</span></div>
        <div class="tvh-num"><%= chartData.tvh.dep_today_count %> <small>· <%= (chartData.tvh.dep_today||0).toLocaleString('fr-FR') %> FCFA</small></div>
        <% const depDiff = chartData.tvh.dep_today - chartData.tvh.dep_yesterday; %>
        <div class="tvh-diff <%= depDiff >= 0 ? 'up' : 'down' %>">
          <%= depDiff >= 0 ? '▲' : '▼' %> <%= Math.abs(depDiff).toLocaleString('fr-FR') %> vs hier
        </div>
      </div>
      <div class="tvh-card" style="border-left:3px solid #ef4444">
        <div class="tvh-label">Retraits auj. <span style="color:#888">(<%= chartData.tvh.ret_today_count %>)</span></div>
        <div class="tvh-num"><%= chartData.tvh.ret_today_count %> <small>· <%= (chartData.tvh.ret_today||0).toLocaleString('fr-FR') %> FCFA</small></div>
        <% const retDiff = chartData.tvh.ret_today - chartData.tvh.ret_yesterday; %>
        <div class="tvh-diff <%= retDiff >= 0 ? 'up' : 'down' %>">
          <%= retDiff >= 0 ? '▲' : '▼' %> <%= Math.abs(retDiff).toLocaleString('fr-FR') %> vs hier
        </div>
      </div>
      <div class="tvh-card" style="border-left:3px solid #22c55e">
        <div class="tvh-label">Dépôts hier</div>
        <div class="tvh-num"><%= (chartData.tvh.dep_yesterday||0).toLocaleString('fr-FR') %> <small>FCFA</small></div>
      </div>
      <div class="tvh-card" style="border-left:3px solid #ef4444">
        <div class="tvh-label">Retraits hier</div>
        <div class="tvh-num"><%= (chartData.tvh.ret_yesterday||0).toLocaleString('fr-FR') %> <small>FCFA</small></div>
      </div>
    </div>
  </div>

  <!-- 6-month activity -->
  <div class="chart-card">
    <div class="chart-head">
      <div class="chart-icon"><i class="fas fa-chart-bar"></i></div>
      <div><h3>Activité financière</h3></div>
    </div>
    <p class="sub">6 derniers mois</p>
    <canvas id="actChart" height="170"></canvas>
    <div class="chart-legend">
      <div class="legend-item"><div class="legend-dot" style="background:#22c55e"></div>Dép. validés</div>
      <div class="legend-item"><div class="legend-dot" style="background:#ef4444"></div>Dép. rejetés</div>
      <div class="legend-item"><div class="legend-dot" style="background:#3b82f6"></div>Ret. validés</div>
      <div class="legend-item"><div class="legend-dot" style="background:#f59e0b"></div>Ret. rejetés</div>
    </div>
  </div>

  <!-- Daily revenue -->
  <div class="rev-card">
    <div class="rev-head">
      <div class="rev-icon"><i class="fas fa-coins"></i></div>
      <div>
        <h3>Revenus journaliers</h3>
        <div class="rev-sub">Automatique chaque jour à 02h00 UTC</div>
      </div>
    </div>
    <p>Crédite le revenu journalier sur le solde de chaque investisseur ayant un plan actif. Les plans arrivés à échéance sont automatiquement clôturés.</p>
    <button class="btn-rev" id="btnRevenu" onclick="verserRevenus()">
      <i class="fas fa-paper-plane"></i> Verser les revenus maintenant
    </button>
  </div>

<%# ── PLANS VIP ─────────────────────────────────────────────────────── %>
<% } else if (currentPage === 'plans') { %>

  <div class="data-card">
    <div class="data-head">
      <h3>Plans VIP</h3>
      <span class="data-count"><%= plans.length %> plans</span>
    </div>
    <div class="scroll-x">
      <table>
        <thead><tr><th>#</th><th>Nom</th><th>Prix (FCFA)</th><th>Durée</th><th>Rendement/j</th><th>Actifs</th><th>Actions</th></tr></thead>
        <tbody>
        <% plans.forEach((p, i) => { %>
        <tr>
          <td>#<%= p.id %></td>
          <td><strong><%- p.nom %></strong></td>
          <td style="color:#E8931A;font-weight:700"><%= parseFloat(p.prix).toLocaleString('fr-FR') %></td>
          <td><%= p.duree_jours %>j</td>
          <td><%= parseFloat(p.rendement_journalier).toFixed(2) %>%</td>
          <td><span class="badge badge-valid"><%= counts[i] || 0 %></span></td>
          <td>
            <button class="btn-xs btn-e" onclick='openPlanModal(<%= p.id %>,<%= p.prix %>,<%= p.duree_jours %>,<%= p.rendement_journalier %>,"<%- (p.description||"").replace(/"/g,"&quot;") %>")'>
              <i class="fas fa-pen"></i> Modifier
            </button>
          </td>
        </tr>
        <% }); %>
        </tbody>
      </table>
    </div>
  </div>

<%# ── UTILISATEURS ───────────────────────────────────────────────────── %>
<% } else if (currentPage === 'utilisateurs') { %>

  <div class="data-card">
    <div class="data-head">
      <h3>Utilisateurs</h3>
      <span class="data-count"><%= users.length %></span>
    </div>
    <div class="search-wrap">
      <input type="text" placeholder="Rechercher…" oninput="filterRows('uTbody', this.value)">
    </div>
    <div class="scroll-x">
      <table>
        <thead><tr><th>#</th><th>Nom</th><th>Téléphone</th><th>Pays</th><th>Solde</th><th>VIP</th><th>Filleuls</th><th>Actions</th></tr></thead>
        <tbody id="uTbody">
        <% users.forEach(u => { %>
        <tr>
          <td>#<%= u.id %></td>
          <td>
            <strong><%- u.nom %></strong>
            <% if (u.is_admin) { %><br><span class="badge badge-admin">Admin</span><% } %>
          </td>
          <td><%- u.telephone %></td>
          <td><%- u.pays || '—' %></td>
          <td style="font-weight:700;color:#E8931A"><%= parseFloat(u.solde||0).toLocaleString('fr-FR') %> <small>FCFA</small></td>
          <td><% if (u.niveau_vip > 0) { %><span class="badge badge-vip">VIP <%= u.niveau_vip %></span><% } else { %>—<% } %></td>
          <td><%= u.nb_filleuls || 0 %> / <%= u.nb_commandes || 0 %> inv.</td>
          <td>
            <button class="btn-xs btn-e" onclick='openBalanceModal(<%= u.id %>,<%- JSON.stringify(u.nom) %>,<%= parseFloat(u.solde||0) %>)'>
              <i class="fas fa-coins"></i> Solde
            </button>
            <button class="btn-xs <%= u.is_admin ? 'btn-r' : 'btn-v' %>" onclick="doAction('toggle_admin',<%= u.id %>)">
              <% if (u.is_admin) { %><i class="fas fa-user-minus"></i> -Admin<% } else { %><i class="fas fa-user-shield"></i> +Admin<% } %>
            </button>
          </td>
        </tr>
        <% }); %>
        </tbody>
      </table>
      <% if (!users.length) { %><div class="empty">Aucun utilisateur</div><% } %>
    </div>
  </div>

<%# ── DÉPÔTS ──────────────────────────────────────────────────────────── %>
<% } else if (currentPage === 'depots') { %>

  <div class="data-card">
    <div class="data-head">
      <h3>Dépôts</h3>
      <span class="data-count"><%= depots.length %></span>
    </div>
    <div class="search-wrap">
      <input type="text" placeholder="Rechercher…" oninput="filterRows('dTbody', this.value)">
    </div>
    <div class="scroll-x">
      <table>
        <thead><tr><th>#</th><th>Utilisateur</th><th>Montant</th><th>Méthode</th><th>Date</th><th>Statut</th><th>Actions</th></tr></thead>
        <tbody id="dTbody">
        <% depots.forEach(d => { %>
        <tr>
          <td>#<%= d.id %></td>
          <td><strong><%- d.nom || '—' %></strong><br><small style="color:#888"><%- d.telephone || '' %></small></td>
          <td style="font-weight:700;color:#22c55e"><%= parseFloat(d.montant||0).toLocaleString('fr-FR') %> <small>FCFA</small></td>
          <td><%- d.methode || '—' %></td>
          <td style="color:#888;font-size:0.8rem"><%= d.date_depot ? new Date(d.date_depot).toLocaleDateString('fr-FR') : '—' %></td>
          <td>
            <% if (d.statut === 'en_attente') { %><span class="badge badge-pending">En attente</span>
            <% } else if (d.statut === 'valide') { %><span class="badge badge-valid">Validé</span>
            <% } else { %><span class="badge badge-rejected">Rejeté</span><% } %>
          </td>
          <td>
            <% if (d.statut === 'en_attente') { %>
            <button class="btn-xs btn-v" onclick="doAction('validate_deposit',<%= d.id %>)"><i class="fas fa-check"></i> Valider</button>
            <button class="btn-xs btn-r" onclick="doAction('reject_deposit',<%= d.id %>)"><i class="fas fa-times"></i> Rejeter</button>
            <% } %>
          </td>
        </tr>
        <% }); %>
        </tbody>
      </table>
      <% if (!depots.length) { %><div class="empty">Aucun dépôt</div><% } %>
    </div>
  </div>

<%# ── RETRAITS ────────────────────────────────────────────────────────── %>
<% } else if (currentPage === 'retraits') { %>

  <div class="data-card">
    <div class="data-head">
      <h3>Retraits</h3>
      <span class="data-count"><%= retraits.length %></span>
    </div>
    <div class="search-wrap">
      <input type="text" placeholder="Rechercher…" oninput="filterRows('rTbody', this.value)">
    </div>
    <div class="scroll-x">
      <table>
        <thead><tr><th>#</th><th>Utilisateur</th><th>Montant</th><th>Destination</th><th>Date</th><th>Statut</th><th>Actions</th></tr></thead>
        <tbody id="rTbody">
        <% retraits.forEach(r => { %>
        <tr>
          <td>#<%= r.id %></td>
          <td><strong><%- r.nom || '—' %></strong><br><small style="color:#888"><%- r.telephone || '' %></small></td>
          <td style="font-weight:700;color:#ef4444"><%= parseFloat(r.montant||0).toLocaleString('fr-FR') %> <small>FCFA</small></td>
          <td style="font-size:0.8rem"><%- r.methode || '—' %><% if (r.numero_compte) { %> — <%- r.numero_compte %><% } %></td>
          <td style="color:#888;font-size:0.8rem"><%= r.date_demande ? new Date(r.date_demande).toLocaleDateString('fr-FR') : '—' %></td>
          <td>
            <% if (r.statut === 'en_attente') { %><span class="badge badge-pending">En attente</span>
            <% } else if (r.statut === 'valide') { %><span class="badge badge-valid">Validé</span>
            <% } else { %><span class="badge badge-rejected">Rejeté</span><% } %>
          </td>
          <td>
            <% if (r.statut === 'en_attente') { %>
            <button class="btn-xs btn-v" onclick="doAction('validate_retrait',<%= r.id %>)"><i class="fas fa-check"></i> Valider</button>
            <button class="btn-xs btn-r" onclick="doAction('reject_retrait',<%= r.id %>)"><i class="fas fa-times"></i> Rejeter</button>
            <% } %>
          </td>
        </tr>
        <% }); %>
        </tbody>
      </table>
      <% if (!retraits.length) { %><div class="empty">Aucun retrait</div><% } %>
    </div>
  </div>

<%# ── CADEAUX VIP ─────────────────────────────────────────────────────── %>
<% } else if (currentPage === 'cadeaux') { %>

  <div class="data-card">
    <div class="data-head">
      <h3>Cadeaux VIP</h3>
      <span class="data-count"><%= codes.length %> codes utilisés</span>
    </div>
    <div class="scroll-x">
      <table>
        <thead><tr><th>#</th><th>Utilisateur</th><th>Code</th><th>Montant</th><th>Date</th></tr></thead>
        <tbody>
        <% codes.forEach(c => { %>
        <tr>
          <td>#<%= c.id %></td>
          <td><strong><%- c.nom || '—' %></strong><br><small style="color:#888"><%- c.telephone || '' %></small></td>
          <td><code style="background:#F5F5F0;padding:2px 8px;border-radius:6px"><%- c.code %></code></td>
          <td style="font-weight:700;color:#E8931A"><%= parseFloat(c.montant||0).toLocaleString('fr-FR') %> <small>FCFA</small></td>
          <td style="color:#888;font-size:0.8rem"><%= c.date_utilisation ? new Date(c.date_utilisation).toLocaleDateString('fr-FR') : '—' %></td>
        </tr>
        <% }); %>
        </tbody>
      </table>
      <% if (!codes.length) { %><div class="empty">Aucun code cadeau utilisé</div><% } %>
    </div>
  </div>

<%# ── SALAIRES VIP ────────────────────────────────────────────────────── %>
<% } else if (currentPage === 'salaires') { %>

  <% const salaireParNiveau = { 0:0, 1:700, 2:1200, 3:4000, 4:5000, 5:7500 }; %>
  <div class="data-card">
    <div class="data-head">
      <h3>Salaires VIP</h3>
      <span class="data-count"><%= salaires.length %> membres</span>
    </div>
    <div class="scroll-x">
      <table>
        <thead><tr><th>#</th><th>Nom</th><th>Téléphone</th><th>Niveau VIP</th><th>Invitations</th><th>Salaire/sem.</th><th>Solde</th></tr></thead>
        <tbody>
        <% salaires.forEach(s => { %>
        <tr>
          <td>#<%= s.id %></td>
          <td><strong><%- s.nom || '—' %></strong></td>
          <td><%- s.telephone || '—' %></td>
          <td><span class="badge badge-vip">VIP <%= s.niveau %></span></td>
          <td><%= s.invitations_actuelles %> / <%= s.invitations_requises %></td>
          <td style="font-weight:700;color:#22c55e"><%= (salaireParNiveau[s.niveau] || 0).toLocaleString('fr-FR') %> FCFA</td>
          <td style="font-weight:700;color:#E8931A"><%= parseFloat(s.solde||0).toLocaleString('fr-FR') %> FCFA</td>
        </tr>
        <% }); %>
        </tbody>
      </table>
      <% if (!salaires.length) { %><div class="empty">Aucun membre VIP avec salaire</div><% } %>
    </div>
  </div>

<%# ── TRANSACTIONS ────────────────────────────────────────────────────── %>
<% } else if (currentPage === 'transactions') { %>

  <% const typeLabels = { paiement_journalier:'Revenu journalier', parrainage:'Parrainage', bonus:'Bonus', cadeau:'Cadeau' }; %>
  <div class="data-card">
    <div class="data-head">
      <h3>Transactions</h3>
      <span class="data-count"><%= transactions.length %></span>
    </div>
    <div class="search-wrap">
      <input type="text" placeholder="Rechercher…" oninput="filterRows('tTbody', this.value)">
    </div>
    <div class="scroll-x">
      <table>
        <thead><tr><th>#</th><th>Utilisateur</th><th>Montant</th><th>Type</th><th>Date</th></tr></thead>
        <tbody id="tTbody">
        <% transactions.forEach(t => { %>
        <tr>
          <td>#<%= t.id %></td>
          <td><strong><%- t.nom || '—' %></strong><br><small style="color:#888"><%- t.telephone || '' %></small></td>
          <td style="font-weight:700;color:#22c55e">+<%= parseFloat(t.montant||0).toLocaleString('fr-FR') %> <small>FCFA</small></td>
          <td><span class="badge badge-valid"><%- typeLabels[t.type] || t.type || '—' %></span></td>
          <td style="color:#888;font-size:0.8rem"><%= t.date_creation ? new Date(t.date_creation).toLocaleDateString('fr-FR') : '—' %></td>
        </tr>
        <% }); %>
        </tbody>
      </table>
      <% if (!transactions.length) { %><div class="empty">Aucune transaction</div><% } %>
    </div>
  </div>

<%# ── AFFICHES ────────────────────────────────────────────────────────── %>
<% } else if (currentPage === 'affiches') { %>

  <div class="data-card">
    <div class="data-head">
      <h3>Affiches</h3>
      <span class="data-count"><%= posts.length %></span>
    </div>
    <div class="scroll-x">
      <table>
        <thead><tr><th>#</th><th>Auteur</th><th>Message</th><th>Image</th><th>Date</th><th>Statut</th><th>Actions</th></tr></thead>
        <tbody>
        <% posts.forEach(p => { %>
        <tr>
          <td>#<%= p.id %></td>
          <td><%- p.nom || '—' %></td>
          <td style="max-width:160px;overflow:hidden;text-overflow:ellipsis;white-space:nowrap;font-size:0.82rem"><%- p.message || '—' %></td>
          <td>
            <% if (p.image) { %>
            <a href="/uploads/<%- p.image %>" target="_blank" style="color:#E8931A;font-size:0.8rem"><i class="fas fa-image"></i> Voir</a>
            <% } else { %>—<% } %>
          </td>
          <td style="color:#888;font-size:0.8rem"><%= p.date_creation ? new Date(p.date_creation).toLocaleDateString('fr-FR') : '—' %></td>
          <td>
            <% if (p.statut === 'en_attente') { %><span class="badge badge-pending">En attente</span>
            <% } else if (p.statut === 'valide') { %><span class="badge badge-valid">Validé</span>
            <% } else { %><span class="badge badge-rejected">Refusé</span><% } %>
          </td>
          <td>
            <% if (p.statut === 'en_attente') { %>
            <button class="btn-xs btn-v" onclick="doAction('validate_post',<%= p.id %>)"><i class="fas fa-check"></i></button>
            <button class="btn-xs btn-r" onclick="doAction('reject_post',<%= p.id %>)"><i class="fas fa-times"></i></button>
            <% } %>
          </td>
        </tr>
        <% }); %>
        </tbody>
      </table>
      <% if (!posts.length) { %><div class="empty">Aucune affiche</div><% } %>
    </div>
  </div>

<%# ── PARAMÈTRES ──────────────────────────────────────────────────────── %>
<% } else if (currentPage === 'parametres') { %>

  <div class="data-card">
    <div class="data-head"><h3>Paramètres</h3></div>
    <div style="padding:20px">
      <div style="margin-bottom:20px">
        <div style="font-size:0.9rem;font-weight:600;margin-bottom:8px;color:#555">Sécurité</div>
        <div style="font-size:0.85rem;color:#555;background:#F5F5F0;padding:14px;border-radius:10px;line-height:1.6">
          Le code administrateur est défini via la variable d'environnement
          <code style="background:#e8e8e8;padding:2px 6px;border-radius:4px">ADMIN_CODE</code>.
          La session expire automatiquement après 30 minutes d'inactivité.
        </div>
      </div>
      <a href="/adminxyz/logout" style="display:inline-flex;align-items:center;gap:8px;background:#FEF2F2;color:#dc2626;padding:12px 20px;border-radius:12px;text-decoration:none;font-weight:700;font-size:0.9rem">
        <i class="fas fa-sign-out-alt"></i> Se déconnecter
      </a>
    </div>
  </div>

<% } %>
</div><!-- /main -->

<!-- Balance Modal -->
<div class="modal-overlay" id="balanceModal">
  <div class="modal-box">
    <h3><i class="fas fa-coins" style="color:#E8931A"></i> Modifier le solde</h3>
    <p id="balanceName" style="color:#888;font-size:0.85rem"></p>
    <input type="hidden" id="balanceUserId">
    <label>Nouveau solde (FCFA)</label>
    <input type="number" id="balanceAmt" step="100" placeholder="0">
    <div class="modal-btns">
      <button class="m-cancel" onclick="closeModal('balanceModal')">Annuler</button>
      <button class="m-confirm" onclick="saveBalance()">Mettre à jour</button>
    </div>
  </div>
</div>

<!-- Plan Modal -->
<div class="modal-overlay" id="planModal">
  <div class="modal-box">
    <h3><i class="fas fa-chart-line" style="color:#22c55e"></i> Modifier le plan</h3>
    <input type="hidden" id="planId">
    <label>Prix (FCFA)</label>
    <input type="number" id="planPrix" step="100">
    <label>Durée (jours)</label>
    <input type="number" id="planDuree">
    <label>Rendement journalier (%)</label>
    <input type="number" id="planRend" step="0.01">
    <label>Description</label>
    <input type="text" id="planDesc">
    <div class="modal-btns">
      <button class="m-cancel" onclick="closeModal('planModal')">Annuler</button>
      <button class="m-confirm" onclick="savePlan()">Enregistrer</button>
    </div>
  </div>
</div>

<!-- Toast -->
<div class="toast" id="toast"></div>

<script>
// ── Sidebar ────────────────────────────────────────────────────────────
document.getElementById('menuBtn').addEventListener('click', () => {
  document.getElementById('sidebar').classList.add('open');
  document.getElementById('overlay').classList.add('open');
});
function closeSidebar() {
  document.getElementById('sidebar').classList.remove('open');
  document.getElementById('overlay').classList.remove('open');
}

// ── Toast ──────────────────────────────────────────────────────────────
function toast(msg, type = '') {
  const el = document.getElementById('toast');
  el.textContent = msg;
  el.className = 'toast show' + (type ? ' ' + type : '');
  setTimeout(() => el.classList.remove('show'), 3000);
}

// ── Modals ─────────────────────────────────────────────────────────────
function openModal(id)  { document.getElementById(id).classList.add('open'); }
function closeModal(id) { document.getElementById(id).classList.remove('open'); }

// ── Search filter ──────────────────────────────────────────────────────
function filterRows(tbodyId, q) {
  q = q.toLowerCase();
  document.querySelectorAll('#' + tbodyId + ' tr').forEach(tr => {
    tr.style.display = tr.textContent.toLowerCase().includes(q) ? '' : 'none';
  });
}

// ── AJAX action → reload page ──────────────────────────────────────────
const actionLabels = {
  validate_deposit:'Valider ce dépôt ?', reject_deposit:'Rejeter ce dépôt ?',
  validate_retrait:'Valider ce retrait ?', reject_retrait:'Rejeter ce retrait ?',
  validate_post:'Valider cette affiche ?', reject_post:'Rejeter cette affiche ?',
  toggle_admin:'Changer le statut administrateur ?'
};
async function doAction(action, id) {
  if (!confirm(actionLabels[action] || action + ' ?')) return;
  try {
    const r = await fetch('/adminxyz/action', {
      method:'POST', body: new URLSearchParams({ action, id })
    });
    if (!r.ok) throw new Error('HTTP ' + r.status);
    const d = await r.json();
    if (d.success) { toast('✓ Action effectuée', 'ok'); setTimeout(() => location.reload(), 900); }
    else toast('✗ ' + (d.message || 'Erreur'), 'err');
  } catch(e) { toast('✗ ' + e.message, 'err'); }
}

// ── Balance ────────────────────────────────────────────────────────────
function openBalanceModal(uid, name, solde) {
  document.getElementById('balanceUserId').value = uid;
  document.getElementById('balanceName').textContent = name + ' — Solde actuel : ' + parseFloat(solde).toLocaleString('fr-FR') + ' FCFA';
  document.getElementById('balanceAmt').value = solde;
  openModal('balanceModal');
}
async function saveBalance() {
  const user_id = document.getElementById('balanceUserId').value;
  const montant = document.getElementById('balanceAmt').value;
  try {
    const r = await fetch('/adminxyz/action', {
      method:'POST', body: new URLSearchParams({ action:'update_balance', user_id, montant })
    });
    const d = await r.json();
    if (d.success) { closeModal('balanceModal'); toast('✓ Solde mis à jour', 'ok'); setTimeout(() => location.reload(), 900); }
    else toast('✗ ' + (d.message || 'Erreur'), 'err');
  } catch(e) { toast('✗ ' + e.message, 'err'); }
}

// ── Plan edit ──────────────────────────────────────────────────────────
function openPlanModal(id, prix, duree, rend, desc) {
  document.getElementById('planId').value    = id;
  document.getElementById('planPrix').value  = prix;
  document.getElementById('planDuree').value = duree;
  document.getElementById('planRend').value  = rend;
  document.getElementById('planDesc').value  = desc;
  openModal('planModal');
}
async function savePlan() {
  const body = new URLSearchParams({
    action:'update_plan',
    id: document.getElementById('planId').value,
    prix: document.getElementById('planPrix').value,
    duree_jours: document.getElementById('planDuree').value,
    rendement_journalier: document.getElementById('planRend').value,
    description: document.getElementById('planDesc').value,
  });
  try {
    const r = await fetch('/adminxyz/action', { method:'POST', body });
    const d = await r.json();
    if (d.success) { closeModal('planModal'); toast('✓ Plan mis à jour', 'ok'); setTimeout(() => location.reload(), 900); }
    else toast('✗ ' + (d.message || 'Erreur'), 'err');
  } catch(e) { toast('✗ ' + e.message, 'err'); }
}

// ── Verser revenus ─────────────────────────────────────────────────────
<% if (currentPage === 'dashboard') { %>
async function verserRevenus() {
  const btn = document.getElementById('btnRevenu');
  btn.disabled = true;
  btn.innerHTML = '<i class="fas fa-spinner fa-spin"></i> Versement en cours…';
  try {
    const r = await fetch('/adminxyz/verser-revenus', { method:'POST' });
    const d = await r.json();
    if (d.success) toast('✓ ' + d.message, 'ok');
    else toast('✗ ' + (d.message || 'Erreur'), 'err');
  } catch(e) { toast('✗ ' + e.message, 'err'); }
  btn.disabled = false;
  btn.innerHTML = '<i class="fas fa-paper-plane"></i> Verser les revenus maintenant';
}

// ── Charts ─────────────────────────────────────────────────────────────
const CD = <%- JSON.stringify(chartData) %>;

// Today vs Yesterday
new Chart(document.getElementById('tvhChart').getContext('2d'), {
  type:'bar',
  data:{
    labels:['Dépôts','Retraits'],
    datasets:[
      { label:'Auj.',  data:[CD.tvh.dep_today,  CD.tvh.ret_today],     backgroundColor:['rgba(34,197,94,0.85)','rgba(239,68,68,0.85)'],  borderRadius:6, barPercentage:0.4 },
      { label:'Hier',  data:[CD.tvh.dep_yesterday,CD.tvh.ret_yesterday],backgroundColor:['rgba(34,197,94,0.25)','rgba(239,68,68,0.25)'],  borderRadius:6, barPercentage:0.4 }
    ]
  },
  options:{ responsive:true, plugins:{legend:{display:false}}, scales:{x:{grid:{display:false},ticks:{color:'#888',font:{size:11}}},y:{grid:{color:'#f0f0f0'},ticks:{color:'#aaa',font:{size:10}}}} }
});

// 6-month activity
new Chart(document.getElementById('actChart').getContext('2d'), {
  type:'bar',
  data:{
    labels: CD.months,
    datasets:[
      { label:'Dép. validés', data:CD.monthly.map(m=>m.dep_valides), backgroundColor:'rgba(34,197,94,0.8)',  borderRadius:4, barPercentage:0.6 },
      { label:'Dép. rejetés', data:CD.monthly.map(m=>m.dep_rejetes), backgroundColor:'rgba(239,68,68,0.8)',  borderRadius:4, barPercentage:0.6 },
      { label:'Ret. validés', data:CD.monthly.map(m=>m.ret_valides), backgroundColor:'rgba(59,130,246,0.8)', borderRadius:4, barPercentage:0.6 },
      { label:'Ret. rejetés', data:CD.monthly.map(m=>m.ret_rejetes), backgroundColor:'rgba(245,158,11,0.8)', borderRadius:4, barPercentage:0.6 }
    ]
  },
  options:{ responsive:true, plugins:{legend:{display:false}}, scales:{x:{grid:{display:false},ticks:{color:'#888',font:{size:11}}},y:{beginAtZero:true,grid:{color:'#f0f0f0'},ticks:{color:'#aaa',font:{size:10}}}} }
});
<% } %>
</script>
</body>
</html>
