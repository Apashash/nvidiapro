<!DOCTYPE html>
<html lang="fr">
<head>
  <meta charset="UTF-8">
  <meta name="viewport" content="width=device-width, initial-scale=1.0">
  <title><%= pageTitle %> — Administration</title>
  <link rel="stylesheet" href="https://cdnjs.cloudflare.com/ajax/libs/font-awesome/6.4.0/css/all.min.css">
  <% if (currentPage === 'dashboard') { %>
  <script src="https://cdn.jsdelivr.net/npm/chart.js@4.4.0/dist/chart.umd.min.js"></script>
  <% } %>
  <style>
    * { margin:0; padding:0; box-sizing:border-box; font-family:'Segoe UI','Helvetica Neue',Arial,sans-serif; }
    body { background:#F5F5F0; color:#1a1a1a; min-height:100vh; overflow-x:hidden; }

    /* ── Top bar ── */
    .topbar {
      background:#E8931A; padding:0 16px; height:56px;
      display:flex; align-items:center; justify-content:space-between;
      position:sticky; top:0; z-index:300;
    }
    .topbar-btn {
      width:40px; height:40px; background:rgba(255,255,255,0.2); border:none;
      border-radius:10px; color:#fff; font-size:1.1rem; cursor:pointer;
      display:flex; align-items:center; justify-content:center; text-decoration:none;
    }
    .topbar-title { color:#fff; font-size:1.05rem; font-weight:700; }

    /* ── Notification bell ── */
    .bell-wrap { position:relative; }
    .notif-badge {
      position:absolute; top:-4px; right:-4px; min-width:18px; height:18px;
      background:#dc2626; color:#fff; border-radius:20px; font-size:0.68rem;
      font-weight:800; display:flex; align-items:center; justify-content:center;
      padding:0 4px; border:2px solid #E8931A;
    }
    .notif-dropdown {
      position:absolute; top:52px; right:16px; width:270px; background:#fff;
      border-radius:14px; box-shadow:0 12px 32px rgba(0,0,0,0.18); z-index:600;
      overflow:hidden; display:none;
    }
    .notif-dropdown.open { display:block; }
    .notif-dropdown-header { padding:14px 16px; background:#FFF7ED; font-weight:800; font-size:0.9rem; color:#333; }
    .notif-item {
      display:flex; align-items:center; justify-content:space-between; gap:10px;
      padding:12px 16px; text-decoration:none; color:#333; border-top:1px solid #f2f2f2;
      font-size:0.85rem; font-weight:600;
    }
    .notif-item:hover { background:#FFF8F0; }
    .notif-count { background:#dc2626; color:#fff; border-radius:12px; padding:2px 9px; font-size:0.75rem; font-weight:800; }
    .notif-empty { padding:20px 16px; text-align:center; color:#aaa; font-size:0.85rem; }

    /* ── Sidebar ── */
    .overlay { position:fixed; inset:0; background:rgba(0,0,0,0.45); z-index:400; opacity:0; pointer-events:none; transition:opacity 0.25s; }
    .overlay.open { opacity:1; pointer-events:all; }
    .sidebar { position:fixed; top:0; left:0; width:290px; height:100%; background:#fff; z-index:500; transform:translateX(-100%); transition:transform 0.28s cubic-bezier(.4,0,.2,1); display:flex; flex-direction:column; overflow:hidden; }
    .sidebar.open { transform:translateX(0); }
    .sidebar-header { background:#E8931A; padding:22px 20px 18px; position:relative; flex-shrink:0; }
    .sidebar-close { position:absolute; top:14px; right:14px; width:32px; height:32px; background:rgba(255,255,255,0.25); border:none; border-radius:50%; color:#fff; font-size:1rem; cursor:pointer; display:flex; align-items:center; justify-content:center; }
    .sidebar-shield { width:50px; height:50px; background:rgba(255,255,255,0.25); border-radius:14px; display:flex; align-items:center; justify-content:center; margin-bottom:12px; font-size:1.4rem; color:#fff; }
    .sidebar-header h2 { color:#fff; font-size:1.15rem; font-weight:800; }
    .sidebar-header p  { color:rgba(255,255,255,0.8); font-size:0.78rem; margin-top:2px; }
    .sidebar-nav { flex:1; overflow-y:auto; padding:8px 0; }
    .nav-item { display:flex; align-items:center; gap:14px; padding:13px 20px; border-left:3px solid transparent; text-decoration:none; transition:background 0.15s; }
    .nav-item:hover { background:#FFF8F0; }
    .nav-item.active { background:#FFF3E0; border-left-color:#E8931A; }
    .nav-item.active .nav-label { color:#E8931A; font-weight:700; }
    .nav-icon { width:36px; height:36px; border-radius:10px; display:flex; align-items:center; justify-content:center; font-size:0.95rem; flex-shrink:0; }
    .nav-label { font-size:0.95rem; color:#2a2a2a; font-weight:500; flex:1; }
    .nav-badge { min-width:20px; height:20px; padding:0 6px; border-radius:10px; background:#E8931A; color:#fff; font-size:0.72rem; font-weight:700; display:none; align-items:center; justify-content:center; flex-shrink:0; }
    .nav-badge.show { display:flex; }
    .sidebar-footer { padding:14px 16px; border-top:1px solid #f0f0f0; }
    .sidebar-footer a { display:flex; align-items:center; justify-content:center; gap:8px; background:#fff; border:1.5px solid #e0e0e0; border-radius:12px; padding:12px; color:#555; text-decoration:none; font-size:0.9rem; font-weight:600; transition:background 0.15s; }
    .sidebar-footer a:hover { background:#f5f5f5; }

    /* ── Main ── */
    .main { padding:16px; max-width:680px; margin:0 auto; }

    /* ── Page header ── */
    .page-header { display:flex; align-items:center; justify-content:space-between; margin-bottom:16px; }
    .page-header-left { display:flex; align-items:center; gap:12px; }
    .page-icon { width:44px; height:44px; background:#E8931A; border-radius:12px; display:flex; align-items:center; justify-content:center; color:#fff; font-size:1.1rem; }
    .page-title { font-size:1.2rem; font-weight:800; }
    .page-count { font-size:0.8rem; color:#888; margin-top:1px; }
    .btn-add { background:#E8931A; color:#fff; border:none; border-radius:20px; padding:10px 18px; font-size:0.88rem; font-weight:700; cursor:pointer; display:flex; align-items:center; gap:6px; text-decoration:none; }
    .btn-add:hover { background:#d4820e; }

    /* ── Search ── */
    .search-box { background:#fff; border-radius:12px; padding:12px 16px; margin-bottom:14px; display:flex; align-items:center; gap:10px; box-shadow:0 1px 4px rgba(0,0,0,0.06); }
    .search-box i { color:#bbb; }
    .search-box input { border:none; outline:none; flex:1; font-size:0.9rem; background:transparent; color:#1a1a1a; }
    .search-box input::placeholder { color:#bbb; }

    /* ── Cards ── */
    .card { background:#fff; border-radius:16px; padding:16px; margin-bottom:12px; box-shadow:0 1px 6px rgba(0,0,0,0.06); position:relative; }
    .card-row { display:flex; align-items:center; justify-content:space-between; }
    .card-actions { display:flex; gap:8px; }

    /* Plan cards */
    .plan-card { background:#fff; border-radius:16px; padding:16px; margin-bottom:12px; box-shadow:0 1px 6px rgba(0,0,0,0.06); display:flex; align-items:flex-start; justify-content:space-between; }
    .plan-body { flex:1; }
    .plan-name { font-size:1rem; font-weight:800; margin-bottom:4px; }
    .plan-meta { font-size:0.82rem; color:#555; margin-bottom:6px; }
    .plan-meta strong { color:#1a1a1a; }
    .plan-rend { font-size:0.88rem; font-weight:700; margin-bottom:2px; }
    .plan-gain { font-size:0.8rem; color:#555; }
    .icon-btn { width:36px; height:36px; border:none; border-radius:10px; cursor:pointer; display:flex; align-items:center; justify-content:center; font-size:0.9rem; }
    .icon-btn-edit { background:#EFF6FF; color:#3b82f6; }
    .icon-btn-del  { background:#FEF2F2; color:#ef4444; }
    .icon-btn-edit:hover { background:#dbeafe; }
    .icon-btn-del:hover  { background:#fee2e2; }

    /* User cards */
    .avatar { width:44px; height:44px; border-radius:12px; background:#E8931A; color:#fff; font-size:1.1rem; font-weight:800; display:flex; align-items:center; justify-content:center; flex-shrink:0; }
    .user-name { font-size:0.95rem; font-weight:700; }
    .user-sub  { font-size:0.78rem; color:#888; margin-top:1px; }
    .user-balance { font-size:0.95rem; font-weight:800; color:#E8931A; margin-top:4px; }
    .ref-row { display:flex; align-items:center; gap:8px; margin-top:6px; flex-wrap:wrap; }
    .ref-code { font-size:0.78rem; font-weight:700; color:#6366f1; background:#EEF2FF; padding:3px 10px; border-radius:20px; }
    .copy-btn { background:#EFF6FF; border:none; border-radius:6px; padding:3px 10px; font-size:0.75rem; color:#3b82f6; cursor:pointer; display:flex; align-items:center; gap:4px; font-weight:600; }
    .copy-btn:hover { background:#dbeafe; }
    .menu-btn { width:36px; height:36px; background:#FFF3E0; border:none; border-radius:10px; cursor:pointer; color:#E8931A; font-size:1rem; display:flex; align-items:center; justify-content:center; }

    /* Depot / Retrait cards */
    .dep-amount { font-size:1.1rem; font-weight:800; color:#E8931A; margin:4px 0; }
    .dep-ref { font-size:0.78rem; font-weight:700; color:#E8931A; background:#FFF3E0; padding:3px 10px; border-radius:20px; cursor:pointer; }
    .dep-meta { font-size:0.8rem; color:#888; }

    /* Retrait amount blue */
    .ret-amount { font-size:1.1rem; font-weight:800; color:#3b82f6; margin:4px 0; }

    /* Transaction cards */
    .tx-type { font-size:0.88rem; font-weight:700; }
    .tx-user { font-size:0.78rem; color:#888; }
    .tx-date { font-size:0.75rem; color:#aaa; }
    .tx-amount { font-size:1rem; font-weight:800; color:#22c55e; }

    /* Status badges */
    .badge { display:inline-block; padding:4px 12px; border-radius:20px; font-size:0.75rem; font-weight:700; }
    .badge-pending  { background:#FFF7ED; color:#EA580C; }
    .badge-valid    { background:#F0FDF4; color:#16a34a; border:1px solid #bbf7d0; }
    .badge-rejected { background:#FEF2F2; color:#dc2626; border:1px solid #fecaca; }
    .badge-admin    { background:#EEF2FF; color:#4f46e5; }

    /* Stat cards dashboard */
    .stats-grid { display:grid; grid-template-columns:1fr 1fr; gap:12px; margin-bottom:16px; }
    .stat-card { background:#fff; border-radius:16px; padding:18px 16px; box-shadow:0 1px 6px rgba(0,0,0,0.07); }
    .stat-icon { width:42px; height:42px; border-radius:12px; display:flex; align-items:center; justify-content:center; margin-bottom:10px; font-size:1.15rem; }
    .stat-num  { font-size:1.65rem; font-weight:800; color:#1a1a1a; line-height:1; }
    .stat-sub  { font-size:0.7rem; color:#888; font-weight:600; margin-top:2px; }
    .stat-label{ font-size:0.82rem; color:#555; margin-top:4px; }

    /* Chart */
    .chart-card { background:#fff; border-radius:16px; padding:18px 16px; box-shadow:0 1px 6px rgba(0,0,0,0.07); margin-bottom:16px; }
    .chart-head { display:flex; align-items:center; gap:10px; margin-bottom:4px; }
    .chart-icon { width:36px; height:36px; background:#FFF3E0; border-radius:10px; display:flex; align-items:center; justify-content:center; }
    .chart-icon i { color:#E8931A; }
    .chart-card h3 { font-size:1rem; font-weight:700; }
    .chart-card .sub { font-size:0.78rem; color:#888; margin-bottom:14px; }
    .chart-legend { display:flex; flex-wrap:wrap; gap:10px; margin-top:10px; }
    .legend-dot { width:10px; height:10px; border-radius:3px; }
    .legend-item { display:flex; align-items:center; gap:5px; font-size:0.75rem; color:#555; }
    .tvh-grid { display:grid; grid-template-columns:1fr 1fr; gap:10px; margin-top:12px; }
    .tvh-card { background:#fff; border-radius:12px; padding:12px 14px; border:1px solid #f0f0f0; }
    .tvh-label { font-size:0.72rem; color:#888; margin-bottom:4px; }
    .tvh-num   { font-size:1.15rem; font-weight:800; }
    .tvh-num small { font-size:0.72rem; font-weight:600; color:#888; }
    .tvh-diff  { font-size:0.72rem; margin-top:2px; }
    .tvh-diff.down { color:#ef4444; }
    .tvh-diff.up   { color:#22c55e; }
    .rev-card { background:#fff; border-radius:16px; padding:18px 16px; box-shadow:0 1px 6px rgba(0,0,0,0.07); margin-bottom:16px; }
    .rev-head { display:flex; align-items:center; gap:10px; margin-bottom:8px; }
    .rev-icon { width:40px; height:40px; background:#E8F5E9; border-radius:12px; display:flex; align-items:center; justify-content:center; }
    .rev-icon i { color:#22c55e; font-size:1.1rem; }
    .rev-card h3 { font-size:1rem; font-weight:700; }
    .rev-card .rev-sub { font-size:0.78rem; color:#888; }
    .rev-card p { font-size:0.85rem; color:#555; line-height:1.5; margin-bottom:14px; }
    .btn-rev { width:100%; background:#22c55e; color:#fff; border:none; border-radius:12px; padding:14px; font-size:0.95rem; font-weight:700; cursor:pointer; display:flex; align-items:center; justify-content:center; gap:8px; transition:background 0.2s; }
    .btn-rev:hover { background:#16a34a; }
    .btn-rev:disabled { background:#9ca3af; cursor:not-allowed; }

    /* Filter row */
    .filter-row { display:flex; gap:10px; margin-bottom:14px; }
    .filter-sel { flex:1; background:#fff; border:1.5px solid #e8e8e8; border-radius:10px; padding:10px 12px; font-size:0.85rem; color:#1a1a1a; outline:none; cursor:pointer; }
    .filter-sel:focus { border-color:#E8931A; }

    /* Salaires config */
    .salaire-card { background:#fff; border-radius:16px; padding:18px; margin-bottom:14px; box-shadow:0 1px 6px rgba(0,0,0,0.06); }
    .salaire-head { display:flex; align-items:center; justify-content:space-between; margin-bottom:14px; }
    .salaire-title { font-size:0.95rem; font-weight:700; }
    .salaire-sub   { font-size:0.75rem; color:#888; }
    .vip-star { width:32px; height:32px; background:#F0FDF4; border-radius:8px; display:flex; align-items:center; justify-content:center; color:#22c55e; }
    .form-grid { display:grid; grid-template-columns:1fr 1fr; gap:12px; margin-bottom:12px; }
    .form-group label { display:block; font-size:0.75rem; color:#888; font-weight:600; margin-bottom:5px; }
    .form-group input { width:100%; background:#F5F5F0; border:1.5px solid #e8e8e8; border-radius:10px; padding:11px 14px; font-size:0.9rem; color:#1a1a1a; outline:none; }
    .form-group input:focus { border-color:#E8931A; }
    .form-group input[readonly] { color:#888; cursor:not-allowed; }
    .btn-save { width:100%; background:#E8931A; color:#fff; border:none; border-radius:12px; padding:13px; font-size:0.92rem; font-weight:700; cursor:pointer; display:flex; align-items:center; justify-content:center; gap:8px; }
    .btn-save:hover { background:#d4820e; }

    /* Paramètres */
    .param-card { background:#fff; border-radius:16px; padding:18px; margin-bottom:14px; box-shadow:0 1px 6px rgba(0,0,0,0.06); }
    .param-head { display:flex; align-items:center; gap:12px; margin-bottom:14px; }
    .param-icon { width:40px; height:40px; border-radius:12px; display:flex; align-items:center; justify-content:center; font-size:1rem; }
    .param-head-text h3 { font-size:0.95rem; font-weight:700; }
    .param-head-text p  { font-size:0.75rem; color:#888; margin-top:2px; }
    .toggle-row { display:flex; align-items:center; justify-content:space-between; padding:14px 16px; border-radius:12px; margin-bottom:14px; }
    .toggle-row.green { background:#F0FDF4; }
    .toggle-row.red   { background:#FEF2F2; }
    .toggle-label { font-size:0.9rem; font-weight:700; }
    .toggle-label span { display:block; font-size:0.75rem; font-weight:400; color:#555; margin-top:2px; }
    .toggle-switch { position:relative; width:48px; height:26px; }
    .toggle-switch input { opacity:0; width:0; height:0; }
    .toggle-slider { position:absolute; cursor:pointer; inset:0; background:#ccc; border-radius:26px; transition:0.3s; }
    .toggle-slider:before { position:absolute; content:""; height:20px; width:20px; left:3px; bottom:3px; background:#fff; border-radius:50%; transition:0.3s; }
    input:checked + .toggle-slider { background:#22c55e; }
    input:checked + .toggle-slider:before { transform:translateX(22px); }
    .param-input { width:100%; background:#F5F5F0; border:1.5px solid #e8e8e8; border-radius:10px; padding:11px 14px; font-size:0.9rem; color:#1a1a1a; outline:none; margin-bottom:12px; }
    .param-input:focus { border-color:#E8931A; }
    .param-textarea { width:100%; background:#F5F5F0; border:1.5px solid #e8e8e8; border-radius:10px; padding:11px 14px; font-size:0.9rem; color:#1a1a1a; outline:none; resize:vertical; min-height:100px; font-family:inherit; margin-bottom:12px; }
    .param-textarea:focus { border-color:#E8931A; }
    .param-label { font-size:0.78rem; color:#555; font-weight:600; margin-bottom:6px; display:flex; align-items:center; gap:6px; }
    .days-row { display:flex; flex-wrap:wrap; gap:8px; margin-bottom:14px; }
    .day-chip { padding:7px 14px; border-radius:20px; font-size:0.82rem; font-weight:600; border:none; cursor:pointer; background:#e8e8e8; color:#555; }
    .day-chip.active { background:#3b82f6; color:#fff; }
    .hours-grid { display:grid; grid-template-columns:1fr 1fr; gap:10px; margin-bottom:14px; }
    .comm-grid { display:grid; grid-template-columns:1fr 1fr 1fr; gap:10px; margin-bottom:14px; }

    /* Modal */
    .modal-overlay { position:fixed; inset:0; background:rgba(0,0,0,0.5); z-index:600; display:flex; align-items:center; justify-content:center; padding:20px; opacity:0; pointer-events:none; transition:opacity 0.2s; }
    .modal-overlay.open { opacity:1; pointer-events:all; }
    .modal-box { background:#fff; border-radius:20px; padding:24px; width:100%; max-width:380px; box-shadow:0 20px 60px rgba(0,0,0,0.2); }
    .modal-box h3 { font-size:1rem; font-weight:700; margin-bottom:16px; }
    .modal-box label { display:block; font-size:0.8rem; color:#888; font-weight:600; margin:12px 0 5px; }
    .modal-box input { width:100%; background:#F5F5F0; border:1.5px solid #e8e8e8; border-radius:10px; padding:11px 14px; color:#1a1a1a; font-size:0.9rem; outline:none; }
    .modal-box input:focus { border-color:#E8931A; }
    .modal-btns { display:flex; gap:10px; margin-top:18px; }
    .modal-btns button { flex:1; padding:12px; border:none; border-radius:12px; cursor:pointer; font-weight:700; font-size:0.9rem; }
    .m-cancel  { background:#F5F5F0; color:#555; }
    .m-confirm { background:#E8931A; color:#fff; }
    .m-danger  { background:#ef4444; color:#fff; }

    /* Dropdown menu */
    .dropdown { position:relative; }
    .dropdown-menu { position:absolute; right:0; top:42px; background:#fff; border-radius:12px; box-shadow:0 8px 30px rgba(0,0,0,0.15); min-width:160px; z-index:50; display:none; overflow:hidden; }
    .dropdown-menu.open { display:block; }
    .dropdown-item { padding:11px 16px; font-size:0.88rem; cursor:pointer; display:flex; align-items:center; gap:10px; border:none; width:100%; background:transparent; text-align:left; }
    .dropdown-item:hover { background:#F5F5F0; }
    .dropdown-item.danger { color:#ef4444; }

    /* Toast */
    .toast { position:fixed; bottom:24px; left:50%; transform:translateX(-50%) translateY(80px); background:#1a1a1a; color:#fff; padding:12px 22px; border-radius:12px; font-size:0.88rem; font-weight:600; z-index:700; transition:transform 0.3s; white-space:nowrap; box-shadow:0 4px 20px rgba(0,0,0,0.3); }
    .toast.show { transform:translateX(-50%) translateY(0); }
    .toast.ok  { background:#16a34a; }
    .toast.err { background:#dc2626; }

    .empty { text-align:center; padding:40px; color:#aaa; font-size:0.9rem; }

    .btn-xs { padding:5px 11px; border-radius:7px; border:none; cursor:pointer; font-size:0.72rem; font-weight:700; margin:2px; }
    .btn-v  { background:#F0FDF4; color:#16a34a; }
    .btn-r  { background:#FEF2F2; color:#dc2626; }
    .btn-e  { background:#EFF6FF; color:#2563eb; }

    @media(min-width:600px) {
      .main { padding:20px; }
      .stats-grid { grid-template-columns:repeat(4,1fr); }
    }
  </style>
</head>
<body>

<!-- Top bar -->
<div class="topbar">
  <button class="topbar-btn" id="menuBtn"><i class="fas fa-bars"></i></button>
  <span class="topbar-title"><%= pageTitle %></span>
  <div class="bell-wrap">
    <button class="topbar-btn" id="bellBtn" onclick="toggleNotifDropdown()" title="Notifications">
      <i class="fas fa-bell"></i>
      <span class="notif-badge" id="notifBadge" style="display:none;">0</span>
    </button>
    <div class="notif-dropdown" id="notifDropdown">
      <div class="notif-dropdown-header">Notifications</div>
      <div id="notifList"></div>
    </div>
  </div>
</div>

<div class="overlay" id="overlay" onclick="closeSidebar()"></div>

<aside class="sidebar" id="sidebar">
  <div class="sidebar-header">
    <button class="sidebar-close" onclick="closeSidebar()"><i class="fas fa-times"></i></button>
    <div class="sidebar-shield"><i class="fas fa-shield-halved"></i></div>
    <h2>Administration</h2>
    <p>Altiora Capital Africa</p>
  </div>
  <nav class="sidebar-nav">
    <% const nav = [
      { page:'dashboard',    href:'/adminxyz/dashboard',    icon:'fas fa-chart-pie',          bg:'#FFF3E0', color:'#E8931A', label:'Tableau de bord' },
      { page:'plans',        href:'/adminxyz/plans',        icon:'fas fa-chart-line',          bg:'#F0FDF4', color:'#22c55e', label:'Plans VIP' },
      { page:'utilisateurs', href:'/adminxyz/utilisateurs', icon:'fas fa-users',               bg:'#EFF6FF', color:'#3b82f6', label:'Utilisateurs' },
      { page:'depots',       href:'/adminxyz/depots',       icon:'fas fa-arrow-down',          bg:'#F0FDF4', color:'#22c55e', label:'Dépôts',       countKey:'depots' },
      { page:'retraits',     href:'/adminxyz/retraits',     icon:'fas fa-hand-holding-dollar', bg:'#EEF2FF', color:'#6366f1', label:'Retraits',     countKey:'retraits' },
      { page:'cadeaux',      href:'/adminxyz/cadeaux',      icon:'fas fa-gift',                bg:'#FFF7ED', color:'#E8931A', label:'Cadeaux VIP' },
      { page:'salaires',     href:'/adminxyz/salaires',     icon:'fas fa-money-bill-wave',     bg:'#F0FDF4', color:'#22c55e', label:'Salaires VIP' },
      { page:'transactions', href:'/adminxyz/transactions', icon:'fas fa-receipt',             bg:'#F5F3FF', color:'#7c3aed', label:'Transactions' },
      { page:'affiches',     href:'/adminxyz/affiches',     icon:'fas fa-image',               bg:'#FFF7ED', color:'#E8931A', label:'Affiches',     countKey:'affiches' },
      { page:'tuto',         href:'/adminxyz/tuto',         icon:'fas fa-video',               bg:'#FDF2F8', color:'#db2777', label:'Tuto' },
      { page:'parametres',   href:'/adminxyz/parametres',   icon:'fas fa-gear',                bg:'#F5F5F0', color:'#6b7280', label:'Paramètres' },
    ]; %>
    <% nav.forEach(item => {
      const n = item.countKey ? (pendingCounts && pendingCounts[item.countKey] || 0) : 0;
    %>
    <a href="<%= item.href %>" class="nav-item <%= currentPage === item.page ? 'active' : '' %>">
      <span class="nav-icon" style="background:<%= item.bg %>"><i class="<%= item.icon %>" style="color:<%= item.color %>"></i></span>
      <span class="nav-label"><%= item.label %></span>
      <% if (item.countKey) { %>
      <span class="nav-badge <%= n > 0 ? 'show' : '' %>" data-nav-count="<%= item.countKey %>"><%= n > 99 ? '99+' : n %></span>
      <% } %>
    </a>
    <% }); %>
  </nav>
  <div class="sidebar-footer">
    <a href="/adminxyz/logout"><i class="fas fa-sign-out-alt" style="color:#ef4444"></i> Déconnexion</a>
  </div>
</aside>

<div class="main">

<%# ══════════════════ DASHBOARD ══════════════════ %>
<% if (currentPage === 'dashboard') { %>

  <div class="stats-grid">
    <div class="stat-card">
      <div class="stat-icon" style="background:#EFF6FF"><i class="fas fa-users" style="color:#3b82f6"></i></div>
      <div class="stat-num"><%= stats_users.total || 0 %></div>
      <div class="stat-label">Utilisateurs</div>
    </div>
    <div class="stat-card">
      <div class="stat-icon" style="background:#F0FDF4"><i class="fas fa-chart-line" style="color:#22c55e"></i></div>
      <div class="stat-num"><%= stats_plans_actifs.total || 0 %></div>
      <div class="stat-label">Plans actifs</div>
    </div>
    <div class="stat-card">
      <div class="stat-icon" style="background:#FFF7ED"><i class="fas fa-arrow-down" style="color:#E8931A"></i></div>
      <div class="stat-num"><%= (parseFloat(stats_depots.somme)||0).toLocaleString('fr-FR') %></div>
      <div class="stat-sub">FCFA</div>
      <div class="stat-label">Dépôts validés</div>
    </div>
    <div class="stat-card">
      <div class="stat-icon" style="background:#EEF2FF"><i class="fas fa-hand-holding-dollar" style="color:#6366f1"></i></div>
      <div class="stat-num"><%= (parseFloat(stats_retraits.somme)||0).toLocaleString('fr-FR') %></div>
      <div class="stat-sub">FCFA</div>
      <div class="stat-label">Retraits validés</div>
    </div>
    <div class="stat-card">
      <div class="stat-icon" style="background:#FFF7ED"><i class="fas fa-hourglass-half" style="color:#E8931A"></i></div>
      <div class="stat-num"><%= stats_pending_depots.total || 0 %></div>
      <div class="stat-label">Dépôts en attente</div>
    </div>
    <div class="stat-card">
      <div class="stat-icon" style="background:#FEF2F2"><i class="fas fa-clock" style="color:#ef4444"></i></div>
      <div class="stat-num"><%= stats_pending_retraits.total || 0 %></div>
      <div class="stat-label">Retraits en attente</div>
    </div>
    <div class="stat-card">
      <div class="stat-icon" style="background:#F0FDF4"><i class="fas fa-briefcase" style="color:#22c55e"></i></div>
      <div class="stat-num"><%= stats_avec_invest.total || 0 %></div>
      <div class="stat-label">Avec investissement</div>
    </div>
    <div class="stat-card">
      <div class="stat-icon" style="background:#EEF2FF"><i class="fas fa-user-check" style="color:#6366f1"></i></div>
      <div class="stat-num"><%= stats_users.total || 0 %></div>
      <div class="stat-label">Total inscrits</div>
    </div>
  </div>

  <div class="chart-card">
    <div class="chart-head">
      <div class="chart-icon"><i class="fas fa-chart-bar"></i></div>
      <div style="flex:1"><h3>Aujourd'hui vs Hier</h3></div>
    </div>
    <p class="sub">Comparaison des transactions</p>
    <canvas id="tvhChart" height="160"></canvas>
    <div class="tvh-grid">
      <div class="tvh-card" style="border-left:3px solid #22c55e">
        <div class="tvh-label">Dépôts auj.</div>
        <div class="tvh-num"><%= chartData.tvh.dep_today_count %> <small>· <%= (chartData.tvh.dep_today||0).toLocaleString('fr-FR') %> FCFA</small></div>
        <% const depDiff = chartData.tvh.dep_today - chartData.tvh.dep_yesterday; %>
        <div class="tvh-diff <%= depDiff >= 0 ? 'up' : 'down' %>"><%= depDiff >= 0 ? '▲' : '▼' %> <%= Math.abs(depDiff).toLocaleString('fr-FR') %> vs hier</div>
      </div>
      <div class="tvh-card" style="border-left:3px solid #ef4444">
        <div class="tvh-label">Retraits auj.</div>
        <div class="tvh-num"><%= chartData.tvh.ret_today_count %> <small>· <%= (chartData.tvh.ret_today||0).toLocaleString('fr-FR') %> FCFA</small></div>
        <% const retDiff = chartData.tvh.ret_today - chartData.tvh.ret_yesterday; %>
        <div class="tvh-diff <%= retDiff >= 0 ? 'up' : 'down' %>"><%= retDiff >= 0 ? '▲' : '▼' %> <%= Math.abs(retDiff).toLocaleString('fr-FR') %> vs hier</div>
      </div>
    </div>
  </div>

  <div class="chart-card">
    <div class="chart-head">
      <div class="chart-icon"><i class="fas fa-chart-bar"></i></div>
      <div><h3>Activité financière</h3></div>
    </div>
    <p class="sub">6 derniers mois</p>
    <canvas id="actChart" height="170"></canvas>
    <div class="chart-legend">
      <div class="legend-item"><div class="legend-dot" style="background:#22c55e"></div>Dép. validés</div>
      <div class="legend-item"><div class="legend-dot" style="background:#ef4444"></div>Dép. rejetés</div>
      <div class="legend-item"><div class="legend-dot" style="background:#3b82f6"></div>Ret. validés</div>
      <div class="legend-item"><div class="legend-dot" style="background:#f59e0b"></div>Ret. rejetés</div>
    </div>
  </div>

  <div class="rev-card">
    <div class="rev-head">
      <div class="rev-icon"><i class="fas fa-coins"></i></div>
      <div>
        <h3>Revenus journaliers</h3>
        <div class="rev-sub">Automatique chaque jour à 02h00 UTC</div>
      </div>
    </div>
    <p>Crédite le revenu journalier sur le solde de chaque investisseur ayant un plan actif.</p>
    <button class="btn-rev" id="btnRevenu" onclick="verserRevenus()">
      <i class="fas fa-paper-plane"></i> Verser les revenus maintenant
    </button>
  </div>

<%# ══════════════════ PLANS VIP ══════════════════ %>
<% } else if (currentPage === 'plans') { %>

  <div class="page-header">
    <div class="page-header-left">
      <div class="page-icon"><i class="fas fa-chart-line"></i></div>
      <div>
        <div class="page-title">Plans VIP (<%= plans.length %>)</div>
      </div>
    </div>
    <button class="btn-add" onclick="openAddPlanModal()"><i class="fas fa-plus"></i> Ajouter</button>
  </div>

  <% const planColors = ['#E8931A','#3b82f6','#22c55e','#7c3aed','#ef4444','#0891b2','#16a34a','#d97706','#6366f1','#ec4899','#14b8a6']; %>
  <% plans.forEach((p, i) => { %>
  <%
    const gain = (parseFloat(p.prix) * parseFloat(p.rendement_journalier) / 100);
    const color = planColors[i % planColors.length];
  %>
  <div class="plan-card" style="border-left:4px solid <%= color %><% if (p.bloque) { %>;opacity:0.75<% } %>">
    <div class="plan-body">
      <div class="plan-name" style="color:<%= color %>"><%- p.nom %> <% if (p.bloque) { %><span style="font-size:0.68rem;background:#FEF2F2;color:#dc2626;padding:2px 8px;border-radius:10px;font-weight:700;vertical-align:middle"><i class="fas fa-lock"></i> Bloqué</span><% } %></div>
      <div class="plan-meta">Prix : <strong><%= parseFloat(p.prix).toLocaleString('fr-FR') %> FCFA</strong> &nbsp; Durée : <strong><%= p.duree_jours %>j</strong></div>
      <div class="plan-rend" style="color:<%= color %>">Rend. : <%= parseFloat(p.rendement_journalier).toFixed(2) %>%/j</div>
      <div class="plan-gain">+<%= gain.toLocaleString('fr-FR',{maximumFractionDigits:0}) %> FCFA/jour</div>
    </div>
    <div class="card-actions">
      <button class="icon-btn <%= p.bloque ? 'icon-btn-del' : 'icon-btn-edit' %>"
        data-pid="<%= p.id %>"
        title="<%= p.bloque ? 'Débloquer ce plan' : 'Bloquer ce plan' %>"
        onclick="togglePlanLockBtn(this)">
        <i class="fas <%= p.bloque ? 'fa-lock' : 'fa-lock-open' %>"></i>
      </button>
      <button class="icon-btn icon-btn-edit"
        data-pid="<%= p.id %>"
        data-nom="<%- (p.nom||'').replace(/&/g,'&amp;').replace(/"/g,'&quot;') %>"
        data-prix="<%= p.prix %>"
        data-duree="<%= p.duree_jours %>"
        data-rend="<%= p.rendement_journalier %>"
        data-image="<%- (p.image_url||'').replace(/&/g,'&amp;').replace(/"/g,'&quot;') %>"
        data-desc="<%- (p.description||'').replace(/&/g,'&amp;').replace(/"/g,'&quot;') %>"
        onclick="openPlanModalBtn(this)">
        <i class="fas fa-pen"></i>
      </button>
      <button class="icon-btn icon-btn-del"
        data-pid="<%= p.id %>"
        data-nom="<%- (p.nom||'').replace(/&/g,'&amp;').replace(/"/g,'&quot;') %>"
        onclick="deletePlanBtn(this)">
        <i class="fas fa-trash"></i>
      </button>
    </div>
  </div>
  <% }); %>
  <% if (!plans.length) { %><div class="empty">Aucun plan VIP</div><% } %>

<%# ══════════════════ UTILISATEURS ══════════════════ %>
<% } else if (currentPage === 'utilisateurs') { %>

  <div class="page-header">
    <div class="page-header-left">
      <div class="page-icon"><i class="fas fa-users"></i></div>
      <div>
        <div class="page-title">Utilisateurs (<%= users.length %>)</div>
      </div>
    </div>
  </div>

  <div class="search-box">
    <i class="fas fa-search"></i>
    <input type="text" id="userSearch" placeholder="Rechercher par nom ou numéro..." oninput="filterCards('userList', this.value)">
  </div>

  <div id="userList">
  <% users.forEach(u => { %>
  <div class="card" data-search="<%= (u.nom+' '+u.telephone+' '+(u.pays||'')+' '+(u.code_parrainage||'')).toLowerCase() %>">
    <div class="card-row">
      <div style="display:flex;align-items:center;gap:12px;flex:1;min-width:0">
        <div class="avatar"><%= (u.nom||'?')[0].toUpperCase() %></div>
        <div style="min-width:0">
          <div class="user-name"><%- u.nom %><% if (u.is_admin) { %> <span style="font-size:0.7rem;background:#EEF2FF;color:#4f46e5;padding:2px 7px;border-radius:10px;font-weight:700">Admin</span><% } %></div>
          <div class="user-sub"><%- u.telephone %> · <%- u.pays || '—' %></div>
          <div class="user-balance"><%= parseFloat(u.solde||0).toLocaleString('fr-FR') %> FCFA</div>
          <div class="ref-row">
            <span class="ref-code"><%= u.code_parrainage || '—' %></span>
            <button class="copy-btn" onclick="copyText('<%- u.code_parrainage || "" %>')"><i class="fas fa-copy"></i> Copier</button>
          </div>
        </div>
      </div>
      <a href="/adminxyz/utilisateurs/<%= u.id %>" class="menu-btn" style="text-decoration:none;flex-shrink:0">
        <i class="fas fa-ellipsis-v"></i>
      </a>
    </div>
  </div>
  <% }); %>
  </div>
  <% if (!users.length) { %><div class="empty">Aucun utilisateur</div><% } %>

<%# ══════════════════ DÉPÔTS ══════════════════ %>
<% } else if (currentPage === 'depots') { %>

  <div class="page-header">
    <div class="page-header-left">
      <div class="page-icon"><i class="fas fa-arrow-down"></i></div>
      <div><div class="page-title">Dépôts (<%= depots.length %>)</div></div>
    </div>
  </div>

  <div class="search-box">
    <i class="fas fa-search"></i>
    <input type="text" placeholder="Référence ou numéro de téléphone..." oninput="filterCards('depotList', this.value)">
  </div>

  <div id="depotList">
  <% depots.forEach(d => { %>
  <%
    const refRaw = (d.numero_transaction||'');
    const refDisplay = refRaw.includes('|') ? refRaw.split('|')[0] : refRaw.substring(0,15);
  %>
  <div class="card" data-search="<%= (d.nom+' '+(d.telephone||'')+' '+refRaw+' '+(d.pays||'')).toLowerCase() %>">
    <div class="card-row" style="align-items:flex-start">
      <div style="flex:1">
        <div style="font-weight:700"><%- d.nom || '—' %></div>
        <div class="dep-meta"><%- d.telephone || '—' %> · <%- d.pays || '—' %></div>
        <div class="dep-amount"><%= parseFloat(d.montant||0).toLocaleString('fr-FR') %> FCFA</div>
        <div class="dep-meta" style="margin-bottom:6px"><%- d.methode || '—' %> · <%= d.date_depot ? new Date(d.date_depot).toLocaleDateString('fr-FR') : '—' %></div>
        <% if (refDisplay) { %>
        <span class="dep-ref" onclick="copyText('<%- refRaw %>')"><%- refDisplay %> <i class="fas fa-copy" style="font-size:0.7rem"></i></span>
        <% } %>
        <% if (d.statut === 'en_attente') { %>
        <div style="margin-top:10px;display:flex;gap:8px">
          <button class="btn-xs btn-v" onclick="doAction('validate_deposit',<%= d.id %>)"><i class="fas fa-check"></i> Valider</button>
          <button class="btn-xs btn-r" onclick="doAction('reject_deposit',<%= d.id %>)"><i class="fas fa-times"></i> Rejeter</button>
        </div>
        <% } %>
      </div>
      <div>
        <% if (d.statut === 'en_attente') { %><span class="badge badge-pending">En attente</span>
        <% } else if (d.statut === 'valide') { %><span class="badge badge-valid">Validé</span>
        <% } else { %><span class="badge badge-rejected">Rejeté</span><% } %>
      </div>
    </div>
  </div>
  <% }); %>
  </div>
  <% if (!depots.length) { %><div class="empty">Aucun dépôt</div><% } %>

<%# ══════════════════ RETRAITS ══════════════════ %>
<% } else if (currentPage === 'retraits') { %>

  <div class="page-header">
    <div class="page-header-left">
      <div class="page-icon"><i class="fas fa-hand-holding-dollar"></i></div>
      <div><div class="page-title">Retraits (<%= retraits.length %>)</div></div>
    </div>
  </div>

  <div class="search-box">
    <i class="fas fa-search"></i>
    <input type="text" placeholder="Référence ou numéro de téléphone..." oninput="filterCards('retraitList', this.value)">
  </div>

  <div id="retraitList">
  <% retraits.forEach(r => { %>
  <div class="card" data-search="<%= (r.nom+' '+(r.telephone||'')+' '+(r.numero_compte||'')).toLowerCase() %>">
    <div class="card-row" style="align-items:flex-start">
      <div style="flex:1">
        <div style="font-weight:700"><%- r.nom || '—' %></div>
        <div class="dep-meta"><%- r.telephone || '—' %></div>
        <div class="ret-amount"><%= parseFloat(r.montant||0).toLocaleString('fr-FR') %> FCFA</div>
        <div class="dep-meta" style="margin-bottom:6px"><%- r.methode || '—' %> · <%= r.date_demande ? new Date(r.date_demande).toLocaleDateString('fr-FR') : '—' %></div>
        <% if (r.numero_compte) { %>
        <div style="margin-bottom:4px">
          <span style="font-weight:700;font-size:0.85rem;text-decoration:underline"><%- r.numero_compte %></span>
          <button class="copy-btn" style="display:inline-flex;margin-left:6px" onclick="copyText('<%- r.numero_compte %>')"><i class="fas fa-copy"></i></button>
        </div>
        <% } %>
        <% if (r.statut === 'en_attente') { %>
        <div style="margin-top:10px;display:flex;gap:8px">
          <button class="btn-xs btn-v" onclick="doAction('validate_retrait',<%= r.id %>)"><i class="fas fa-check"></i> Valider</button>
          <button class="btn-xs btn-r" onclick="doAction('reject_retrait',<%= r.id %>)"><i class="fas fa-times"></i> Rejeter</button>
        </div>
        <% } %>
      </div>
      <div>
        <% if (r.statut === 'en_attente') { %><span class="badge badge-pending">En attente</span>
        <% } else if (r.statut === 'valide') { %><span class="badge badge-valid">Validé</span>
        <% } else { %><span class="badge badge-rejected">Rejeté</span><% } %>
      </div>
    </div>
  </div>
  <% }); %>
  </div>
  <% if (!retraits.length) { %><div class="empty">Aucun retrait</div><% } %>

<%# ══════════════════ CADEAUX VIP ══════════════════ %>
<% } else if (currentPage === 'cadeaux') { %>

  <div class="page-header">
    <div class="page-header-left">
      <div class="page-icon"><i class="fas fa-gift"></i></div>
      <div><div class="page-title">Cadeaux VIP (<%= codes.length %>)</div></div>
    </div>
  </div>

  <% codes.forEach(c => { %>
  <div class="card">
    <div class="card-row">
      <div style="flex:1">
        <div style="font-weight:700"><%- c.nom || '—' %></div>
        <div class="dep-meta"><%- c.telephone || '—' %></div>
        <div class="dep-amount"><%= parseFloat(c.montant||0).toLocaleString('fr-FR') %> FCFA</div>
        <div class="ref-row">
          <span class="ref-code"><%- c.code %></span>
          <button class="copy-btn" onclick="copyText('<%- c.code %>')"><i class="fas fa-copy"></i> Copier</button>
        </div>
      </div>
      <div class="dep-meta" style="text-align:right"><%= c.date_utilisation ? new Date(c.date_utilisation).toLocaleDateString('fr-FR') : '—' %></div>
    </div>
  </div>
  <% }); %>
  <% if (!codes.length) { %><div class="empty">Aucun code cadeau utilisé</div><% } %>

<%# ══════════════════ SALAIRES VIP ══════════════════ %>
<% } else if (currentPage === 'salaires') { %>

  <div class="page-header">
    <div class="page-header-left">
      <div class="page-icon"><i class="fas fa-money-bill-wave"></i></div>
      <div><div class="page-title">Salaires VIP</div></div>
    </div>
  </div>

  <% paliers.forEach(p => { %>
  <div class="salaire-card">
    <div class="salaire-head">
      <div style="display:flex;align-items:center;gap:10px">
        <div class="vip-star"><i class="fas fa-star"></i></div>
        <div>
          <div class="salaire-title">Niveau VIP <%= p.niveau %></div>
          <div class="salaire-sub">Configuration du palier</div>
        </div>
      </div>
      <button class="icon-btn icon-btn-del" onclick="deletePalier(<%= p.id %>, <%= p.niveau %>)"><i class="fas fa-trash"></i></button>
    </div>
    <form onsubmit="savePalier(event, <%= p.id %>)">
      <div class="form-grid">
        <div class="form-group">
          <label>Label (nom affiché)</label>
          <input type="text" name="label" value="<%- p.label %>" placeholder="Ex: Leadeur basic">
        </div>
        <div class="form-group">
          <label>Niveau (numéro)</label>
          <input type="number" value="<%= p.niveau %>" readonly>
        </div>
      </div>
      <div class="form-grid">
        <div class="form-group">
          <label>Filleuls requis</label>
          <input type="number" name="filleuls_requis" value="<%= p.filleuls_requis %>" min="0">
        </div>
        <div class="form-group">
          <label>Montant cadeau (FCFA)</label>
          <input type="number" name="montant_cadeau" value="<%= parseFloat(p.montant_cadeau).toFixed(2) %>" step="0.01" min="0">
        </div>
      </div>
      <button type="submit" class="btn-save"><i class="fas fa-save"></i> Enregistrer</button>
    </form>
  </div>
  <% }); %>

  <button class="btn-save" style="margin-top:4px" onclick="openAddPalierModal()"><i class="fas fa-plus"></i> Ajouter un palier VIP</button>

<%# ══════════════════ TRANSACTIONS ══════════════════ %>
<% } else if (currentPage === 'transactions') { %>

  <div class="page-header">
    <div class="page-header-left">
      <div class="page-icon"><i class="fas fa-receipt"></i></div>
      <div><div class="page-title">Transactions (<%= transactions.length %>)</div></div>
    </div>
  </div>

  <div class="search-box">
    <i class="fas fa-search"></i>
    <input type="text" placeholder="Référence, nom ou numéro de téléphone..." oninput="filterCards('txList', this.value)">
  </div>

  <div class="filter-row">
    <select class="filter-sel" id="txTypeFilter" onchange="filterTx()">
      <option value="">Tous les types</option>
      <option value="paiement_journalier">Revenu investissement</option>
      <option value="parrainage">Parrainage</option>
      <option value="bonus">Bonus</option>
      <option value="cadeau">Cadeau</option>
    </select>
