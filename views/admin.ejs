<!-- Toast -->
<div class="toast" id="toast"></div>

<script>
// ── XSS-safe escape ───────────────────────────────────────────────────
function esc(s) {
  if (s === null || s === undefined) return '';
  return String(s).replace(/&/g,'&amp;').replace(/</g,'&lt;').replace(/>/g,'&gt;')
                  .replace(/"/g,'&quot;').replace(/'/g,'&#39;');
}

// ── Sidebar ────────────────────────────────────────────────────────────
function openSidebar() {
  document.getElementById('sidebar').classList.add('open');
  document.getElementById('overlay').classList.add('open');
}
function closeSidebar() {
  document.getElementById('sidebar').classList.remove('open');
  document.getElementById('overlay').classList.remove('open');
}
document.getElementById('menuBtn').addEventListener('click', openSidebar);

// ── Navigation ─────────────────────────────────────────────────────────
const sectionLoaded = {};

function navigate(el, title) {
  const section = el.getAttribute('data-section');
  document.querySelectorAll('.nav-item').forEach(i => i.classList.remove('active'));
  el.classList.add('active');
  document.getElementById('topbarTitle').textContent = title;
  document.querySelectorAll('.section').forEach(s => s.classList.remove('active'));
  document.getElementById('section-' + section).classList.add('active');
  closeSidebar();
  if (!sectionLoaded[section]) {
    loadSection(section);
    sectionLoaded[section] = true;
  }
}

// ── Toast ──────────────────────────────────────────────────────────────
function showToast(msg, type = '') {
  const t = document.getElementById('toast');
  t.textContent = msg;
  t.className = 'toast show' + (type ? ' ' + type : '');
  setTimeout(() => t.classList.remove('show'), 3000);
}

// ── Modal helpers ──────────────────────────────────────────────────────
function openModal(id)  { document.getElementById(id).classList.add('open'); }
function closeModal(id) { document.getElementById(id).classList.remove('open'); }

// ── Admin action ───────────────────────────────────────────────────────
async function adminAction(action, id, extra = {}) {
  const labels = { validate_deposit:'Valider ce dépôt', reject_deposit:'Rejeter ce dépôt',
                   validate_retrait:'Valider ce retrait', reject_retrait:'Rejeter ce retrait',
                   validate_post:'Valider cette affiche', reject_post:'Rejeter cette affiche',
                   toggle_admin:'Changer le statut admin', delete_user:'Supprimer cet utilisateur' };
  if (!confirm((labels[action] || action) + ' ?')) return;
  try {
    const body = new URLSearchParams({ action, id, ...extra });
    const res = await fetch('/adminxyz/action', { method:'POST', body });
    if (!res.ok) throw new Error('HTTP ' + res.status);
    const data = await res.json();
    if (data.success) {
      showToast('✓ Action effectuée', 'success');
      Object.keys(sectionLoaded).forEach(k => delete sectionLoaded[k]);
      setTimeout(() => loadCurrentSection(), 700);
    } else {
      showToast('✗ ' + (data.message || 'Erreur'), 'error');
    }
  } catch(e) { showToast('✗ Erreur réseau: ' + e.message, 'error'); }
}

function loadCurrentSection() {
  const active = document.querySelector('.nav-item.active');
  if (active) { const s = active.getAttribute('data-section'); loadSection(s); }
}

// ── Balance modal ──────────────────────────────────────────────────────
function showBalanceModal(userId, name, solde) {
  document.getElementById('balanceUserId').value = userId;
  document.getElementById('balanceUserName').textContent = name + ' — Solde: ' + parseFloat(solde).toLocaleString('fr-FR') + ' FCFA';
  document.getElementById('balanceAmount').value = solde;
  openModal('balanceModal');
}
async function updateBalance() {
  const user_id = document.getElementById('balanceUserId').value;
  const montant = document.getElementById('balanceAmount').value;
  const res = await fetch('/adminxyz/action', {
    method:'POST', body: new URLSearchParams({ action:'update_balance', user_id, montant })
  });
  const data = await res.json();
  if (data.success) {
    closeModal('balanceModal'); showToast('✓ Solde mis à jour', 'success');
    delete sectionLoaded['utilisateurs']; loadSection('utilisateurs');
  } else { showToast('✗ ' + (data.message||'Erreur'), 'error'); }
}

// ── Plan edit modal ────────────────────────────────────────────────────
function showPlanModal(id, prix, duree, rendement, desc) {
  document.getElementById('planId').value = id;
  document.getElementById('planPrix').value = prix;
  document.getElementById('planDuree').value = duree;
  document.getElementById('planRendement').value = rendement;
  document.getElementById('planDesc').value = desc;
  openModal('planModal');
}
async function updatePlan() {
  const id = document.getElementById('planId').value;
  const prix = document.getElementById('planPrix').value;
  const duree_jours = document.getElementById('planDuree').value;
  const rendement_journalier = document.getElementById('planRendement').value;
  const description = document.getElementById('planDesc').value;
  const res = await fetch('/adminxyz/action', {
    method:'POST', body: new URLSearchParams({ action:'update_plan', id, prix, duree_jours, rendement_journalier, description })
  });
  const data = await res.json();
  if (data.success) {
    closeModal('planModal'); showToast('✓ Plan mis à jour', 'success');
    delete sectionLoaded['plans']; loadSection('plans');
  } else { showToast('✗ ' + (data.message||'Erreur'), 'error'); }
}

// ── Verser revenus ─────────────────────────────────────────────────────
async function verserRevenus() {
  const btn = document.getElementById('btnRevenu');
  btn.disabled = true; btn.innerHTML = '<div class="spinner" style="width:18px;height:18px;border-width:2px"></div> Versement…';
  const res = await fetch('/adminxyz/verser-revenus', { method:'POST' });
  const data = await res.json();
  btn.disabled = false; btn.innerHTML = '<i class="fas fa-paper-plane"></i> Verser les revenus maintenant';
  if (data.success) showToast('✓ ' + data.message, 'success');
  else showToast('✗ ' + (data.message||'Erreur'), 'error');
}

// ── Table filter ───────────────────────────────────────────────────────
function filterTable(tbodyId, query) {
  const q = query.toLowerCase();
  document.querySelectorAll('#' + tbodyId + ' tr').forEach(tr => {
    tr.style.display = tr.textContent.toLowerCase().includes(q) ? '' : 'none';
  });
}

// ── Format helpers ─────────────────────────────────────────────────────
function fmt(n) { return (parseFloat(n)||0).toLocaleString('fr-FR'); }
function fmtDate(d) { return d ? new Date(d).toLocaleDateString('fr-FR') : '—'; }
function badge(statut) {
  if (!statut) return '—';
  const map = { en_attente:'pending', valide:'valid', rejete:'rejected', refuse:'rejected', actif:'valid', termine:'rejected' };
  const cls = map[statut] || 'pending';
  const labels = { en_attente:'En attente', valide:'Validé', rejete:'Rejeté', refuse:'Refusé', actif:'Actif', termine:'Terminé' };
  return `<span class="badge badge-${cls}">${labels[statut]||statut}</span>`;
}

// ── Load sections ──────────────────────────────────────────────────────
async function loadSection(section) {
  if (section === 'dashboard') { loadCharts(); return; }
  const endpoints = {
    plans:'plans', utilisateurs:'utilisateurs', depots:'depots', retraits:'retraits',
    cadeaux:'cadeaux', salaires:'salaires', transactions:'transactions', affiches:'affiches'
  };
  if (!endpoints[section]) return;
  try {
    const res = await fetch('/adminxyz/api/' + endpoints[section]);
    const data = await res.json();
    renderSection(section, data);
  } catch(e) { console.error(e); showToast('Erreur de chargement', 'error'); }
}

function renderSection(section, data) {
  if (section === 'plans') renderPlans(data);
  else if (section === 'utilisateurs') renderUtilisateurs(data);
  else if (section === 'depots') renderDepots(data);
  else if (section === 'retraits') renderRetraits(data);
  else if (section === 'cadeaux') renderCadeaux(data);
  else if (section === 'salaires') renderSalaires(data);
  else if (section === 'transactions') renderTransactions(data);
  else if (section === 'affiches') renderAffiches(data);
}

// ── Render: Plans ──────────────────────────────────────────────────────
function renderPlans({ plans = [], counts = [], error }) {
  document.getElementById('plansCount').textContent = plans.length;
  let html = '';
  if (error) { html = `<div class="empty-state">${esc(error)}</div>`; }
  else if (!plans.length) { html = '<div class="empty-state">Aucun plan</div>'; }
  else {
    html = '<div class="scroll-x"><table><thead><tr><th>#</th><th>Nom</th><th>Prix (FCFA)</th><th>Durée</th><th>Rendement/j</th><th>Actifs</th><th>Actions</th></tr></thead><tbody>';
    plans.forEach((p, i) => {
      const descEscAttr = esc(p.description||'');
      html += `<tr>
        <td>#${esc(p.id)}</td>
        <td><strong>${esc(p.nom)}</strong></td>
        <td style="color:#E8931A;font-weight:700">${fmt(p.prix)}</td>
        <td>${esc(p.duree_jours)}j</td>
        <td>${parseFloat(p.rendement_journalier).toFixed(2)}%</td>
        <td><span class="badge badge-valid">${counts[i]||0}</span></td>
        <td>
          <button class="btn-xs btn-e" onclick='showPlanModal(${parseInt(p.id)},${parseFloat(p.prix)},${parseInt(p.duree_jours)},${parseFloat(p.rendement_journalier)},"${descEscAttr}")'>
            <i class="fas fa-pen"></i> Modifier
          </button>
        </td>
      </tr>`;
    });
    html += '</tbody></table></div>';
  }
  document.getElementById('plansContent').innerHTML = html;
}

// ── Render: Utilisateurs ───────────────────────────────────────────────
function renderUtilisateurs({ users = [], error }) {
  document.getElementById('usersCount').textContent = users.length;
  const tbody = document.getElementById('usersTbody');
  if (error) { tbody.innerHTML = `<tr><td colspan="8" class="empty-state">${esc(error)}</td></tr>`; return; }
  if (!users.length) { tbody.innerHTML = '<tr><td colspan="8" class="empty-state">Aucun utilisateur</td></tr>'; return; }
  tbody.innerHTML = users.map(u => `
    <tr>
      <td>#${parseInt(u.id)}</td>
      <td>
        <strong>${esc(u.nom)}</strong>
        ${u.is_admin ? '<br><span class="badge badge-admin">Admin</span>' : ''}
      </td>
      <td>${esc(u.telephone)}</td>
      <td>${esc(u.pays||'—')}</td>
      <td style="font-weight:700;color:#E8931A">${fmt(u.solde)} <small>FCFA</small></td>
      <td>${u.niveau_vip > 0 ? `<span class="badge badge-vip">VIP ${parseInt(u.niveau_vip)}</span>` : '—'}</td>
      <td>${parseInt(u.nb_filleuls)||0} / ${parseInt(u.nb_commandes)||0} inv.</td>
      <td>
        <button class="btn-xs btn-e" onclick="showBalanceModal(${parseInt(u.id)},${JSON.stringify(u.nom||'')},${parseFloat(u.solde)||0})">
          <i class="fas fa-coins"></i> Solde
        </button>
        <button class="btn-xs ${u.is_admin ? 'btn-r' : 'btn-v'}" onclick="adminAction('toggle_admin',${parseInt(u.id)})">
          ${u.is_admin ? '<i class="fas fa-user-minus"></i> -Admin' : '<i class="fas fa-user-shield"></i> +Admin'}
        </button>
      </td>
    </tr>`).join('');
}

// ── Render: Dépôts ─────────────────────────────────────────────────────
function renderDepots({ depots = [], error }) {
  document.getElementById('depotsCount').textContent = depots.length;
  const tbody = document.getElementById('depotsTbody');
  if (error) { tbody.innerHTML = `<tr><td colspan="7" class="empty-state">${esc(error)}</td></tr>`; return; }
  if (!depots.length) { tbody.innerHTML = '<tr><td colspan="7" class="empty-state">Aucun dépôt</td></tr>'; return; }
  tbody.innerHTML = depots.map(d => `
    <tr>
      <td>#${parseInt(d.id)}</td>
      <td><strong>${esc(d.nom||'—')}</strong><br><small style="color:#888">${esc(d.telephone||'')}</small></td>
      <td style="font-weight:700;color:#22c55e">${fmt(d.montant)} <small>FCFA</small></td>
      <td>${esc(d.methode||'—')}</td>
      <td style="color:#888;font-size:0.8rem">${fmtDate(d.date_depot)}</td>
      <td>${badge(d.statut)}</td>
      <td>
        ${d.statut === 'en_attente' ? `
          <button class="btn-xs btn-v" onclick="adminAction('validate_deposit',${parseInt(d.id)})"><i class="fas fa-check"></i> Valider</button>
          <button class="btn-xs btn-r" onclick="adminAction('reject_deposit',${parseInt(d.id)})"><i class="fas fa-times"></i> Rejeter</button>
        ` : ''}
      </td>
    </tr>`).join('');
}

// ── Render: Retraits ───────────────────────────────────────────────────
function renderRetraits({ retraits = [], error }) {
  document.getElementById('retraitsCount').textContent = retraits.length;
  const tbody = document.getElementById('retraitsTbody');
  if (error) { tbody.innerHTML = `<tr><td colspan="7" class="empty-state">${esc(error)}</td></tr>`; return; }
  if (!retraits.length) { tbody.innerHTML = '<tr><td colspan="7" class="empty-state">Aucun retrait</td></tr>'; return; }
  tbody.innerHTML = retraits.map(r => `
    <tr>
      <td>#${parseInt(r.id)}</td>
      <td><strong>${esc(r.nom||'—')}</strong><br><small style="color:#888">${esc(r.telephone||'')}</small></td>
      <td style="font-weight:700;color:#ef4444">${fmt(r.montant)} <small>FCFA</small></td>
      <td style="font-size:0.8rem">${esc(r.methode||'—')} ${r.numero_compte ? '— '+esc(r.numero_compte) : ''}</td>
      <td style="color:#888;font-size:0.8rem">${fmtDate(r.date_demande)}</td>
      <td>${badge(r.statut)}</td>
      <td>
        ${r.statut === 'en_attente' ? `
          <button class="btn-xs btn-v" onclick="adminAction('validate_retrait',${parseInt(r.id)})"><i class="fas fa-check"></i> Valider</button>
          <button class="btn-xs btn-r" onclick="adminAction('reject_retrait',${parseInt(r.id)})"><i class="fas fa-times"></i> Rejeter</button>
        ` : ''}
      </td>
    </tr>`).join('');
}

// ── Render: Cadeaux ────────────────────────────────────────────────────
function renderCadeaux({ codes = [], error }) {
  document.getElementById('cadeauxCount').textContent = codes.length;
  const tbody = document.getElementById('cadeauxTbody');
  if (error) { tbody.innerHTML = `<tr><td colspan="5" class="empty-state">${esc(error)}</td></tr>`; return; }
  if (!codes.length) { tbody.innerHTML = '<tr><td colspan="5" class="empty-state">Aucun code cadeau utilisé</td></tr>'; return; }
  tbody.innerHTML = codes.map(c => `
    <tr>
      <td>#${parseInt(c.id)}</td>
      <td><strong>${esc(c.nom||'—')}</strong><br><small style="color:#888">${esc(c.telephone||'')}</small></td>
      <td><code style="background:#F5F5F0;padding:2px 8px;border-radius:6px;font-size:0.85rem">${esc(c.code)}</code></td>
      <td style="font-weight:700;color:#E8931A">${fmt(c.montant)} <small>FCFA</small></td>
      <td style="color:#888;font-size:0.8rem">${fmtDate(c.date_utilisation)}</td>
    </tr>`).join('');
}

// ── Render: Salaires ───────────────────────────────────────────────────
function renderSalaires({ salaires = [], error }) {
  document.getElementById('salairesCount').textContent = salaires.length;
  const tbody = document.getElementById('salairesTbody');
  if (error) { tbody.innerHTML = `<tr><td colspan="6" class="empty-state">${esc(error)}</td></tr>`; return; }
  if (!salaires.length) { tbody.innerHTML = '<tr><td colspan="6" class="empty-state">Aucun membre VIP avec salaire</td></tr>'; return; }
  tbody.innerHTML = salaires.map(s => `
    <tr>
      <td>#${parseInt(s.id)}</td>
      <td><strong>${esc(s.nom||'—')}</strong></td>
      <td>${esc(s.telephone||'—')}</td>
      <td><span class="badge badge-vip">VIP ${parseInt(s.niveau)}</span></td>
      <td>${parseInt(s.invitations_actuelles)||0} / ${parseInt(s.invitations_requises)||3}</td>
      <td style="font-weight:700;color:#E8931A">${fmt(s.solde)} <small>FCFA</small></td>
    </tr>`).join('');
}

// ── Render: Transactions ───────────────────────────────────────────────
function renderTransactions({ transactions = [], error }) {
  document.getElementById('transactionsCount').textContent = transactions.length;
  const tbody = document.getElementById('transactionsTbody');
  if (error) { tbody.innerHTML = `<tr><td colspan="5" class="empty-state">${esc(error)}</td></tr>`; return; }
  if (!transactions.length) { tbody.innerHTML = '<tr><td colspan="5" class="empty-state">Aucune transaction</td></tr>'; return; }
  const typeLabels = { paiement_journalier:'Revenu journalier', parrainage:'Parrainage', bonus:'Bonus', cadeau:'Cadeau' };
  tbody.innerHTML = transactions.map(t => `
    <tr>
      <td>#${parseInt(t.id)}</td>
      <td><strong>${esc(t.nom||'—')}</strong><br><small style="color:#888">${esc(t.telephone||'')}</small></td>
      <td style="font-weight:700;color:#22c55e">+${fmt(t.montant)} <small>FCFA</small></td>
      <td><span class="badge badge-valid">${esc(typeLabels[t.type]||t.type||'—')}</span></td>
      <td style="color:#888;font-size:0.8rem">${fmtDate(t.date_creation)}</td>
    </tr>`).join('');
}

// ── Render: Affiches ───────────────────────────────────────────────────
function renderAffiches({ posts = [], error }) {
  document.getElementById('affichesCount').textContent = posts.length;
  const tbody = document.getElementById('afficherTbody');
  if (error) { tbody.innerHTML = `<tr><td colspan="7" class="empty-state">${esc(error)}</td></tr>`; return; }
  if (!posts.length) { tbody.innerHTML = '<tr><td colspan="7" class="empty-state">Aucune affiche</td></tr>'; return; }
  tbody.innerHTML = posts.map(p => `
    <tr>
      <td>#${parseInt(p.id)}</td>
      <td>${esc(p.nom||'—')}</td>
      <td style="max-width:160px;overflow:hidden;text-overflow:ellipsis;white-space:nowrap;font-size:0.82rem">${esc(p.message||'—')}</td>
      <td>${p.image ? `<a href="/uploads/${esc(p.image)}" target="_blank" style="color:#E8931A;font-size:0.8rem"><i class="fas fa-image"></i> Voir</a>` : '—'}</td>
      <td style="color:#888;font-size:0.8rem">${fmtDate(p.date_creation)}</td>
      <td>${badge(p.statut)}</td>
      <td>
        ${p.statut === 'en_attente' ? `
          <button class="btn-xs btn-v" onclick="adminAction('validate_post',${parseInt(p.id)})"><i class="fas fa-check"></i></button>
          <button class="btn-xs btn-r" onclick="adminAction('reject_post',${parseInt(p.id)})"><i class="fas fa-times"></i></button>
        ` : ''}
      </td>
    </tr>`).join('');
}

// ── Charts ─────────────────────────────────────────────────────────────
let tvhChartInst = null;
let actChartInst = null;

async function loadCharts() {
  try {
    const res = await fetch('/adminxyz/api/chart-data');
    const data = await res.json();
    if (data.error) return;
    renderTvhChart(data.today_vs_yesterday);
    renderActivityChart(data.months, data.monthly);
  } catch(e) { console.error('Charts error', e); }
}

function renderTvhChart(tvh) {
  const ctx = document.getElementById('tvhChart').getContext('2d');
  if (tvhChartInst) tvhChartInst.destroy();
  tvhChartInst = new Chart(ctx, {
    type: 'bar',
    data: {
      labels: ['Dépôts', 'Retraits'],
      datasets: [
        { label: "Auj.", data: [tvh.dep_today, tvh.ret_today], backgroundColor: ['rgba(34,197,94,0.85)', 'rgba(239,68,68,0.85)'], borderRadius: 6, barPercentage: 0.4 },
        { label: "Hier", data: [tvh.dep_yesterday, tvh.ret_yesterday], backgroundColor: ['rgba(34,197,94,0.25)', 'rgba(239,68,68,0.25)'], borderRadius: 6, barPercentage: 0.4 }
      ]
    },
    options: {
      responsive: true, maintainAspectRatio: true,
      plugins: { legend: { display: false } },
      scales: {
        x: { grid: { display: false }, ticks: { font: { size: 11 }, color: '#888' } },
        y: { grid: { color: '#f0f0f0' }, ticks: { font: { size: 10 }, color: '#aaa' } }
      }
    }
  });

  // Update mini cards
  const fmt2 = n => (parseFloat(n)||0).toLocaleString('fr-FR');
  document.getElementById('depTodayNum').innerHTML = `${tvh.dep_today_count} <span>· ${fmt2(tvh.dep_today)} FCFA</span>`;
  document.getElementById('retTodayNum').innerHTML = `${tvh.ret_today_count} <span>· ${fmt2(tvh.ret_today)} FCFA</span>`;
  document.getElementById('depYestNum').innerHTML  = `${fmt2(tvh.dep_yesterday)} <span>FCFA</span>`;
  document.getElementById('retYestNum').innerHTML  = `${fmt2(tvh.ret_yesterday)} <span>FCFA</span>`;

  const depDiff = tvh.dep_today - tvh.dep_yesterday;
  const retDiff = tvh.ret_today - tvh.ret_yesterday;
  document.getElementById('depTodayDiff').innerHTML = `<span class="tvh-diff ${depDiff >= 0 ? 'up' : 'down'}">
    ${depDiff >= 0 ? '▲' : '▼'} ${fmt2(Math.abs(depDiff))} vs hier</span>`;
  document.getElementById('retTodayDiff').innerHTML = `<span class="tvh-diff ${retDiff >= 0 ? 'up' : 'down'}">
    ${retDiff >= 0 ? '▲' : '▼'} ${fmt2(Math.abs(retDiff))} vs hier</span>`;
}

function renderActivityChart(labels, monthly) {
  const ctx = document.getElementById('activityChart').getContext('2d');
  if (actChartInst) actChartInst.destroy();
  actChartInst = new Chart(ctx, {
    type: 'bar',
    data: {
      labels,
      datasets: [
        { label: 'Dép. validés',  data: monthly.map(m => m.dep_valides),  backgroundColor: 'rgba(34,197,94,0.8)',  borderRadius: 4, barPercentage: 0.6 },
        { label: 'Dép. rejetés',  data: monthly.map(m => m.dep_rejetes),  backgroundColor: 'rgba(239,68,68,0.8)',  borderRadius: 4, barPercentage: 0.6 },
        { label: 'Ret. validés',  data: monthly.map(m => m.ret_valides),  backgroundColor: 'rgba(59,130,246,0.8)', borderRadius: 4, barPercentage: 0.6 },
        { label: 'Ret. rejetés',  data: monthly.map(m => m.ret_rejetes),  backgroundColor: 'rgba(245,158,11,0.8)', borderRadius: 4, barPercentage: 0.6 }
      ]
    },
    options: {
      responsive: true, maintainAspectRatio: true,
      plugins: { legend: { display: false } },
      scales: {
        x: { grid: { display: false }, ticks: { font: { size: 11 }, color: '#888' } },
        y: { grid: { color: '#f0f0f0' }, ticks: { font: { size: 10 }, color: '#aaa' }, beginAtZero: true }
      }
    }
  });
}

// ── Init ───────────────────────────────────────────────────────────────
loadCharts();
</script>
</body>
</html>
