// ── Notification bell ─────────────────────────────────────────────────
const NOTIF_LABELS = {
  depots:   { label: 'Dépôts en attente',   icon: 'fa-arrow-down',          href: '/adminxyz/depots' },
  retraits: { label: 'Retraits en attente', icon: 'fa-hand-holding-dollar', href: '/adminxyz/retraits' },
  affiches: { label: 'Affiches en attente', icon: 'fa-image',               href: '/adminxyz/affiches' },
};

// The bell shows an "unread" style badge: it disappears once the admin opens
// the dropdown (has "seen" the current pending items), and only reappears
// when a NEW item arrives on top of what was already seen. The per-item
// sidebar badges (Dépôts, Retraits, Affiches) are never dismissed this way —
// they always reflect the true pending count in the database and only
// disappear once that item is actually validated/rejected.
let lastCounts = null;   // most recent counts fetched from the server
let seenCounts = {};     // counts snapshot at the moment the bell was last opened

function renderNotifCounts(counts) {
  lastCounts = counts || { total: 0, depots: 0, retraits: 0, affiches: 0 };
  const badge = document.getElementById('notifBadge');
  const list  = document.getElementById('notifList');

  const unread = {};
  let unreadTotal = 0;
  Object.keys(NOTIF_LABELS).forEach(key => {
    const n = Math.max(0, (lastCounts[key] || 0) - (seenCounts[key] || 0));
    unread[key] = n;
    unreadTotal += n;
  });

  if (unreadTotal <= 0) {
    badge.style.display = 'none';
  } else {
    badge.style.display = 'flex';
    badge.textContent = unreadTotal > 99 ? '99+' : unreadTotal;
  }

  if (lastCounts.total <= 0) {
    list.innerHTML = '<div class="notif-empty">Aucune notification</div>';
  } else {
    list.innerHTML = Object.keys(NOTIF_LABELS).map(key => {
      const n = lastCounts[key] || 0;
      if (n <= 0) return '';
      const meta = NOTIF_LABELS[key];
      return `<a class="notif-item" href="${meta.href}">
        <span><i class="fas ${meta.icon}" style="color:#E8931A;margin-right:8px"></i>${meta.label}</span>
        <span class="notif-count">${n}</span>
      </a>`;
    }).join('') || '<div class="notif-empty">Aucune notification</div>';
  }

  // Sidebar nav badges: always the real pending count — persist until the
  // item's status actually changes, unaffected by opening the bell.
  document.querySelectorAll('[data-nav-count]').forEach(el => {
    const n = (lastCounts && lastCounts[el.dataset.navCount]) || 0;
    el.textContent = n > 99 ? '99+' : n;
    el.classList.toggle('show', n > 0);
  });
}

function toggleNotifDropdown() {
  const dd = document.getElementById('notifDropdown');
  const opening = !dd.classList.contains('open');
  dd.classList.toggle('open');
  if (opening) {
    // Mark current counts as seen — hides the bell badge immediately.
    seenCounts = { ...(lastCounts || {}) };
    renderNotifCounts(lastCounts);
  }
}
document.addEventListener('click', e => {
  const dd = document.getElementById('notifDropdown');
  const btn = document.getElementById('bellBtn');
  if (dd && btn && !dd.contains(e.target) && !btn.contains(e.target)) dd.classList.remove('open');
});

let notifPollTimer = null;
async function refreshNotifCounts() {
  try {
    const r = await fetch('/adminxyz/pending-counts');
    if (r.status === 401) { clearInterval(notifPollTimer); return; }
    const counts = await r.json();
    renderNotifCounts(counts);
  } catch (e) { /* silent */ }
}

// Initial render from server-side data, then poll for live updates
renderNotifCounts(<%- JSON.stringify(pendingCounts || { total: 0, depots: 0, retraits: 0, affiches: 0 }) %>);
notifPollTimer = setInterval(refreshNotifCounts, 15000);

// ── Modals ─────────────────────────────────────────────────────────────
function openModal(id)  { document.getElementById(id).classList.add('open'); }
function closeModal(id) { document.getElementById(id).classList.remove('open'); }

// ── Dropdowns ──────────────────────────────────────────────────────────
function toggleDropdown(ddId) {
  const menu = document.getElementById('ddm-' + ddId.replace('dd-', ''));
  document.querySelectorAll('.dropdown-menu').forEach(m => { if (m !== menu) m.classList.remove('open'); });
  menu.classList.toggle('open');
}
function closeDropdown(ddId) {
  const menu = document.getElementById('ddm-' + ddId.replace('dd-', ''));
  if (menu) menu.classList.remove('open');
}
document.addEventListener('click', e => {
  if (!e.target.closest('.dropdown')) document.querySelectorAll('.dropdown-menu').forEach(m => m.classList.remove('open'));
});

// ── Copy ───────────────────────────────────────────────────────────────
function copyText(text) {
  navigator.clipboard.writeText(text).then(() => toast('✓ Copié !', 'ok')).catch(() => toast('Impossible de copier', 'err'));
}

// ── Card filter ─────────────────────────────────────────────────────────
function filterCards(listId, q) {
  q = q.toLowerCase();
  document.querySelectorAll('#' + listId + ' .card').forEach(card => {
    const search = card.dataset.search || card.textContent.toLowerCase();
    card.style.display = search.includes(q) ? '' : 'none';
  });
}

// ── Transaction filter ──────────────────────────────────────────────────
function filterTx() {
  const typeVal = document.getElementById('txTypeFilter').value;
  const searchVal = document.querySelector('#txList input') ? '' : '';
  document.querySelectorAll('#txList .card').forEach(card => {
    const matchType = !typeVal || card.dataset.type === typeVal;
    card.style.display = matchType ? '' : 'none';
  });
}

