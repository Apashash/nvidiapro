<!DOCTYPE html>
<html lang="fr">
<head>
  <meta charset="UTF-8">
  <meta name="viewport" content="width=device-width, initial-scale=1.0">
  <title>Administration</title>
  <link rel="stylesheet" href="https://cdnjs.cloudflare.com/ajax/libs/font-awesome/6.4.0/css/all.min.css">
  <script src="https://cdn.jsdelivr.net/npm/chart.js@4.4.0/dist/chart.umd.min.js"></script>
  <style>
    * { margin:0; padding:0; box-sizing:border-box; font-family:'Segoe UI','Helvetica Neue',Arial,sans-serif; }
    body { background:#F5F5F0; color:#1a1a1a; min-height:100vh; overflow-x:hidden; }

    /* ── Top bar ───────────────────────────────────────────────── */
    .topbar {
      background:#E8931A;
      padding:0 16px;
      height:56px;
      display:flex;
      align-items:center;
      justify-content:space-between;
      position:sticky; top:0; z-index:300;
    }
    .topbar-btn {
      width:40px; height:40px; background:rgba(255,255,255,0.2); border:none; border-radius:10px;
      color:#fff; font-size:1.1rem; cursor:pointer; display:flex; align-items:center; justify-content:center;
    }
    .topbar-title { color:#fff; font-size:1.05rem; font-weight:700; letter-spacing:0.2px; }

    /* ── Sidebar overlay ───────────────────────────────────────── */
    .sidebar-overlay {
      position:fixed; inset:0; background:rgba(0,0,0,0.45); z-index:400;
      opacity:0; pointer-events:none; transition:opacity 0.25s;
    }
    .sidebar-overlay.open { opacity:1; pointer-events:all; }

    .sidebar {
      position:fixed; top:0; left:0; width:290px; height:100%; background:#fff;
      z-index:500; transform:translateX(-100%); transition:transform 0.28s cubic-bezier(.4,0,.2,1);
      display:flex; flex-direction:column; overflow:hidden;
    }
    .sidebar.open { transform:translateX(0); }

    .sidebar-header {
      background:#E8931A; padding:22px 20px 18px; flex-shrink:0;
    }
    .sidebar-close {
      position:absolute; top:14px; right:14px; width:32px; height:32px;
      background:rgba(255,255,255,0.25); border:none; border-radius:50%;
      color:#fff; font-size:1rem; cursor:pointer; display:flex; align-items:center; justify-content:center;
    }
    .sidebar-icon-wrap {
      width:50px; height:50px; background:rgba(255,255,255,0.25); border-radius:14px;
      display:flex; align-items:center; justify-content:center; margin-bottom:12px;
    }
    .sidebar-icon-wrap i { color:#fff; font-size:1.4rem; }
    .sidebar-header h2 { color:#fff; font-size:1.15rem; font-weight:800; }
    .sidebar-header p { color:rgba(255,255,255,0.8); font-size:0.78rem; margin-top:2px; }

    .sidebar-nav { flex:1; overflow-y:auto; padding:8px 0; }
    .nav-item {
      display:flex; align-items:center; gap:14px; padding:13px 20px; cursor:pointer;
      transition:background 0.15s; border-left:3px solid transparent; text-decoration:none;
    }
    .nav-item:hover { background:#FFF8F0; }
    .nav-item.active { background:#FFF3E0; border-left-color:#E8931A; }
    .nav-item.active .nav-label { color:#E8931A; font-weight:700; }
    .nav-icon {
      width:36px; height:36px; border-radius:10px; display:flex; align-items:center; justify-content:center;
      font-size:0.95rem; flex-shrink:0;
    }
    .nav-label { font-size:0.95rem; color:#2a2a2a; font-weight:500; }

    .sidebar-footer { padding:14px 16px; border-top:1px solid #f0f0f0; }
    .sidebar-footer a {
      display:flex; align-items:center; justify-content:center; gap:8px;
      background:#fff; border:1.5px solid #e0e0e0; border-radius:12px; padding:12px;
      color:#555; text-decoration:none; font-size:0.9rem; font-weight:600; transition:background 0.15s;
    }
    .sidebar-footer a:hover { background:#f5f5f5; }

    /* ── Main content ──────────────────────────────────────────── */
    .main { padding:16px; max-width:680px; margin:0 auto; }

    .section { display:none; }
    .section.active { display:block; }

    /* ── Section header ────────────────────────────────────────── */
    .section-title { font-size:1rem; font-weight:700; color:#1a1a1a; margin-bottom:14px; }

    /* ── Stat grid ─────────────────────────────────────────────── */
    .stats-grid { display:grid; grid-template-columns:1fr 1fr; gap:12px; margin-bottom:16px; }
    .stat-card {
      background:#fff; border-radius:16px; padding:18px 16px;
      box-shadow:0 1px 6px rgba(0,0,0,0.07);
    }
    .stat-card .icon-wrap {
      width:42px; height:42px; border-radius:12px; display:flex; align-items:center;
      justify-content:center; margin-bottom:10px; font-size:1.15rem;
    }
    .stat-card .stat-num { font-size:1.65rem; font-weight:800; color:#1a1a1a; line-height:1; }
    .stat-card .stat-sub { font-size:0.7rem; color:#888; font-weight:600; margin-top:2px; }
    .stat-card .stat-label { font-size:0.82rem; color:#555; margin-top:4px; }

    /* ── Chart card ────────────────────────────────────────────── */
    .chart-card {
      background:#fff; border-radius:16px; padding:18px 16px;
      box-shadow:0 1px 6px rgba(0,0,0,0.07); margin-bottom:16px;
    }
    .chart-card-header { display:flex; align-items:center; gap:10px; margin-bottom:4px; }
    .chart-card-header .ch-icon {
      width:36px; height:36px; background:#FFF3E0; border-radius:10px;
      display:flex; align-items:center; justify-content:center;
    }
    .chart-card-header .ch-icon i { color:#E8931A; font-size:1rem; }
    .chart-card h3 { font-size:1rem; font-weight:700; color:#1a1a1a; }
    .chart-card p  { font-size:0.78rem; color:#888; margin-bottom:14px; }
    .chart-legend { display:flex; flex-wrap:wrap; gap:10px; margin-top:10px; }
    .legend-item { display:flex; align-items:center; gap:5px; font-size:0.75rem; color:#555; }
    .legend-dot { width:10px; height:10px; border-radius:3px; flex-shrink:0; }

    /* Today vs Yesterday mini cards */
    .tvh-grid { display:grid; grid-template-columns:1fr 1fr; gap:10px; margin-top:12px; }
    .tvh-card { background:#fff; border-radius:12px; padding:12px 14px; border:1px solid #f0f0f0; }
    .tvh-card .tvh-label { font-size:0.72rem; color:#888; margin-bottom:4px; }
    .tvh-card .tvh-num { font-size:1.15rem; font-weight:800; color:#1a1a1a; }
    .tvh-card .tvh-num span { font-size:0.72rem; font-weight:600; color:#888; }
    .tvh-card .tvh-diff { font-size:0.72rem; margin-top:2px; }
    .tvh-diff.down { color:#ef4444; }
    .tvh-diff.up { color:#22c55e; }

    /* ── Revenue card ──────────────────────────────────────────── */
    .revenue-card {
      background:#fff; border-radius:16px; padding:18px 16px;
      box-shadow:0 1px 6px rgba(0,0,0,0.07); margin-bottom:16px;
    }
    .revenue-card .rev-header { display:flex; align-items:center; gap:10px; margin-bottom:8px; }
    .rev-icon { width:40px; height:40px; background:#E8F5E9; border-radius:12px; display:flex; align-items:center; justify-content:center; }
    .rev-icon i { color:#22c55e; font-size:1.1rem; }
    .revenue-card h3 { font-size:1rem; font-weight:700; }
    .revenue-card .rev-sub { font-size:0.78rem; color:#888; }
    .revenue-card p { font-size:0.85rem; color:#555; line-height:1.5; margin-bottom:14px; }
    .btn-revenue {
      width:100%; background:#22c55e; color:#fff; border:none; border-radius:12px;
      padding:14px; font-size:0.95rem; font-weight:700; cursor:pointer;
      display:flex; align-items:center; justify-content:center; gap:8px; transition:background 0.2s;
    }
    .btn-revenue:hover { background:#16a34a; }
    .btn-revenue:disabled { background:#9ca3af; cursor:not-allowed; }

    /* ── Data tables ───────────────────────────────────────────── */
    .data-card {
      background:#fff; border-radius:16px; overflow:hidden;
      box-shadow:0 1px 6px rgba(0,0,0,0.07); margin-bottom:16px;
    }
    .data-card-header {
      padding:14px 16px; border-bottom:1px solid #f5f5f5;
      display:flex; align-items:center; justify-content:space-between;
    }
    .data-card-header h3 { font-size:0.95rem; font-weight:700; }
    .data-count { font-size:0.78rem; color:#888; background:#f5f5f5; padding:3px 10px; border-radius:20px; }
    .search-wrap { padding:12px 16px; border-bottom:1px solid #f5f5f5; }
    .search-wrap input {
      width:100%; background:#F5F5F0; border:1.5px solid #e8e8e8; border-radius:10px;
      padding:10px 14px; font-size:0.88rem; outline:none; color:#1a1a1a;
      transition:border-color 0.2s;
    }
    .search-wrap input:focus { border-color:#E8931A; }

    .scroll-x { overflow-x:auto; }
    table { width:100%; border-collapse:collapse; min-width:500px; }
    th { background:#FAFAF8; color:#888; font-size:0.72rem; text-transform:uppercase; letter-spacing:0.5px; padding:10px 14px; text-align:left; font-weight:700; border-bottom:1px solid #f0f0f0; }
    td { padding:10px 14px; border-bottom:1px solid #f9f9f9; font-size:0.85rem; vertical-align:middle; }
    tr:last-child td { border-bottom:none; }
    tr:hover td { background:#FAFAF8; }

    .badge { display:inline-block; padding:3px 10px; border-radius:20px; font-size:0.72rem; font-weight:700; }
    .badge-pending  { background:#FFF7ED; color:#EA580C; }
    .badge-valid    { background:#F0FDF4; color:#16a34a; }
    .badge-rejected { background:#FEF2F2; color:#dc2626; }
    .badge-admin    { background:#EEF2FF; color:#4f46e5; }
    .badge-vip      { background:#FFF7ED; color:#E8931A; }

    .btn-xs { padding:5px 11px; border-radius:7px; border:none; cursor:pointer; font-size:0.72rem; font-weight:700; margin:2px; white-space:nowrap; }
    .btn-v  { background:#F0FDF4; color:#16a34a; }
    .btn-r  { background:#FEF2F2; color:#dc2626; }
    .btn-e  { background:#EFF6FF; color:#2563eb; }
    .btn-v:hover { background:#dcfce7; }
    .btn-r:hover { background:#fee2e2; }
    .btn-e:hover { background:#dbeafe; }

    .empty-state { text-align:center; padding:40px 20px; color:#aaa; font-size:0.9rem; }

    /* ── Modal ─────────────────────────────────────────────────── */
    .modal-overlay {
      position:fixed; inset:0; background:rgba(0,0,0,0.5); z-index:600;
      display:flex; align-items:center; justify-content:center; padding:20px;
      opacity:0; pointer-events:none; transition:opacity 0.2s;
    }
    .modal-overlay.open { opacity:1; pointer-events:all; }
    .modal-box {
      background:#fff; border-radius:20px; padding:24px; width:100%; max-width:380px;
      box-shadow:0 20px 60px rgba(0,0,0,0.2);
    }
    .modal-box h3 { font-size:1rem; font-weight:700; margin-bottom:16px; color:#1a1a1a; }
    .modal-box label { display:block; font-size:0.8rem; color:#888; font-weight:600; margin-bottom:5px; margin-top:12px; }
    .modal-box input {
      width:100%; background:#F5F5F0; border:1.5px solid #e8e8e8; border-radius:10px;
      padding:11px 14px; color:#1a1a1a; font-size:0.9rem; outline:none;
    }
    .modal-box input:focus { border-color:#E8931A; }
    .modal-btns { display:flex; gap:10px; margin-top:18px; }
    .modal-btns button { flex:1; padding:12px; border:none; border-radius:12px; cursor:pointer; font-weight:700; font-size:0.9rem; }
    .modal-cancel { background:#F5F5F0; color:#555; }
    .modal-confirm { background:#E8931A; color:#fff; }

    /* ── Toast ─────────────────────────────────────────────────── */
    .toast {
      position:fixed; bottom:24px; left:50%; transform:translateX(-50%) translateY(80px);
      background:#1a1a1a; color:#fff; padding:12px 22px; border-radius:12px;
      font-size:0.88rem; font-weight:600; z-index:700; transition:transform 0.3s;
      white-space:nowrap; box-shadow:0 4px 20px rgba(0,0,0,0.3);
    }
    .toast.show { transform:translateX(-50%) translateY(0); }
    .toast.success { background:#16a34a; }
    .toast.error   { background:#dc2626; }

    /* ── Loading spinner ───────────────────────────────────────── */
    .spinner-wrap { text-align:center; padding:40px; color:#aaa; }
    .spinner { display:inline-block; width:28px; height:28px; border:3px solid #f0f0f0; border-top-color:#E8931A; border-radius:50%; animation:spin 0.7s linear infinite; }
    @keyframes spin { to { transform:rotate(360deg); } }

    /* ── Plan edit form ────────────────────────────────────────── */
    .plan-row-edit input { width:70px; background:#F5F5F0; border:1.5px solid #e0e0e0; border-radius:6px; padding:4px 7px; font-size:0.8rem; }

    /* Responsive */
    @media(min-width:600px) {
      .main { padding:20px; }
      .stats-grid { grid-template-columns:repeat(4,1fr); }
    }
  </style>
</head>
<body>

<!-- Top bar -->
<div class="topbar">
  <button class="topbar-btn" id="menuBtn" aria-label="Menu"><i class="fas fa-bars"></i></button>
  <span class="topbar-title" id="topbarTitle">Tableau de bord</span>
  <button class="topbar-btn" aria-label="Notifications"><i class="fas fa-bell"></i></button>
</div>

<!-- Sidebar overlay -->
<div class="sidebar-overlay" id="overlay" onclick="closeSidebar()"></div>

<!-- Sidebar -->
<aside class="sidebar" id="sidebar">
  <div class="sidebar-header" style="position:relative">
    <button class="sidebar-close" id="closeBtn" onclick="closeSidebar()"><i class="fas fa-times"></i></button>
    <div class="sidebar-icon-wrap"><i class="fas fa-shield-halved"></i></div>
    <h2>Administration</h2>
    <p>NVIDIA Technology</p>
  </div>

  <nav class="sidebar-nav" id="sidebarNav">
    <a class="nav-item active" data-section="dashboard" onclick="navigate(this,'Tableau de bord')">
      <span class="nav-icon" style="background:#FFF3E0"><i class="fas fa-chart-pie" style="color:#E8931A"></i></span>
      <span class="nav-label">Tableau de bord</span>
    </a>
    <a class="nav-item" data-section="plans" onclick="navigate(this,'Plans VIP')">
      <span class="nav-icon" style="background:#F0FDF4"><i class="fas fa-chart-line" style="color:#22c55e"></i></span>
      <span class="nav-label">Plans VIP</span>
    </a>
    <a class="nav-item" data-section="utilisateurs" onclick="navigate(this,'Utilisateurs')">
      <span class="nav-icon" style="background:#EFF6FF"><i class="fas fa-users" style="color:#3b82f6"></i></span>
      <span class="nav-label">Utilisateurs</span>
    </a>
    <a class="nav-item" data-section="depots" onclick="navigate(this,'Dépôts')">
      <span class="nav-icon" style="background:#F0FDF4"><i class="fas fa-arrow-down" style="color:#22c55e"></i></span>
      <span class="nav-label">Dépôts</span>
    </a>
    <a class="nav-item" data-section="retraits" onclick="navigate(this,'Retraits')">
      <span class="nav-icon" style="background:#EEF2FF"><i class="fas fa-hand-holding-dollar" style="color:#6366f1"></i></span>
      <span class="nav-label">Retraits</span>
    </a>
    <a class="nav-item" data-section="cadeaux" onclick="navigate(this,'Cadeaux VIP')">
      <span class="nav-icon" style="background:#FFF7ED"><i class="fas fa-gift" style="color:#E8931A"></i></span>
      <span class="nav-label">Cadeaux VIP</span>
    </a>
    <a class="nav-item" data-section="salaires" onclick="navigate(this,'Salaires VIP')">
      <span class="nav-icon" style="background:#F0FDF4"><i class="fas fa-money-bill-wave" style="color:#22c55e"></i></span>
      <span class="nav-label">Salaires VIP</span>
    </a>
    <a class="nav-item" data-section="transactions" onclick="navigate(this,'Transactions')">
      <span class="nav-icon" style="background:#F5F3FF"><i class="fas fa-receipt" style="color:#7c3aed"></i></span>
      <span class="nav-label">Transactions</span>
    </a>
    <a class="nav-item" data-section="affiches" onclick="navigate(this,'Affiches')">
      <span class="nav-icon" style="background:#FFF7ED"><i class="fas fa-image" style="color:#E8931A"></i></span>
      <span class="nav-label">Affiches</span>
    </a>
    <a class="nav-item" data-section="parametres" onclick="navigate(this,'Paramètres')">
      <span class="nav-icon" style="background:#F5F5F0"><i class="fas fa-gear" style="color:#6b7280"></i></span>
      <span class="nav-label">Paramètres</span>
    </a>
  </nav>

  <div class="sidebar-footer">
    <a href="/"><i class="fas fa-house" style="color:#E8931A"></i> Retour à l'accueil</a>
  </div>
</aside>

<!-- ════════════════ MAIN CONTENT ════════════════ -->
<div class="main">

  <!-- ── DASHBOARD ── -->
  <div class="section active" id="section-dashboard">
    <!-- Stats grid -->
    <div class="stats-grid">
      <div class="stat-card">
        <div class="icon-wrap" style="background:#EFF6FF"><i class="fas fa-users" style="color:#3b82f6"></i></div>
        <div class="stat-num"><%= stats_users.total || 0 %></div>
        <div class="stat-label">Utilisateurs</div>
      </div>
      <div class="stat-card">
        <div class="icon-wrap" style="background:#F0FDF4"><i class="fas fa-chart-line" style="color:#22c55e"></i></div>
        <div class="stat-num"><%= stats_plans_actifs.total || 0 %></div>
        <div class="stat-label">Plans actifs</div>
      </div>
      <div class="stat-card">
        <div class="icon-wrap" style="background:#FFF7ED"><i class="fas fa-arrow-down" style="color:#E8931A"></i></div>
        <div class="stat-num"><%= (parseFloat(stats_depots.somme) || 0).toLocaleString('fr-FR') %></div>
        <div class="stat-sub">FCFA</div>
        <div class="stat-label">Dépôts validés</div>
      </div>
      <div class="stat-card">
        <div class="icon-wrap" style="background:#EEF2FF"><i class="fas fa-hand-holding-dollar" style="color:#6366f1"></i></div>
        <div class="stat-num"><%= (parseFloat(stats_retraits.somme) || 0).toLocaleString('fr-FR') %></div>
        <div class="stat-sub">FCFA</div>
        <div class="stat-label">Retraits validés</div>
      </div>
      <div class="stat-card">
        <div class="icon-wrap" style="background:#FFF7ED"><i class="fas fa-hourglass-half" style="color:#E8931A"></i></div>
        <div class="stat-num"><%= stats_pending_depots.total || 0 %></div>
        <div class="stat-label">Dépôts en attente</div>
      </div>
      <div class="stat-card">
        <div class="icon-wrap" style="background:#FEF2F2"><i class="fas fa-clock" style="color:#ef4444"></i></div>
        <div class="stat-num"><%= stats_pending_retraits.total || 0 %></div>
        <div class="stat-label">Retraits en attente</div>
      </div>
      <div class="stat-card">
        <div class="icon-wrap" style="background:#F0FDF4"><i class="fas fa-briefcase" style="color:#22c55e"></i></div>
        <div class="stat-num"><%= stats_avec_invest.total || 0 %></div>
        <div class="stat-label">Avec investissement</div>
      </div>
      <div class="stat-card">
        <div class="icon-wrap" style="background:#EEF2FF"><i class="fas fa-user-check" style="color:#6366f1"></i></div>
        <div class="stat-num"><%= stats_users.total || 0 %></div>
        <div class="stat-label">Total inscrits</div>
      </div>
    </div>

    <!-- Today vs Yesterday chart -->
    <div class="chart-card" id="tvhCard">
      <div class="chart-card-header">
        <div class="ch-icon"><i class="fas fa-chart-bar"></i></div>
        <div>
          <h3>Aujourd'hui vs Hier</h3>
        </div>
        <div style="margin-left:auto;display:flex;gap:10px;font-size:0.75rem;color:#888">
          <span><span style="display:inline-block;width:10px;height:10px;background:#1a1a1a;border-radius:2px;margin-right:4px"></span>Auj.</span>
          <span><span style="display:inline-block;width:10px;height:10px;background:#ccc;border-radius:2px;margin-right:4px"></span>Hier</span>
        </div>
      </div>
      <p style="font-size:0.78rem;color:#aaa;margin-bottom:10px;margin-left:46px">Comparaison des transactions</p>
      <canvas id="tvhChart" height="160"></canvas>
      <div class="tvh-grid" id="tvhCards">
        <div class="tvh-card" style="border-left:3px solid #22c55e">
          <div class="tvh-label">Dépôts auj.</div>
          <div class="tvh-num" id="depTodayNum">— <span>FCFA</span></div>
          <div class="tvh-diff" id="depTodayDiff"></div>
        </div>
        <div class="tvh-card" style="border-left:3px solid #ef4444">
          <div class="tvh-label">Retraits auj.</div>
          <div class="tvh-num" id="retTodayNum">— <span>FCFA</span></div>
          <div class="tvh-diff" id="retTodayDiff"></div>
        </div>
        <div class="tvh-card" style="border-left:3px solid #22c55e">
          <div class="tvh-label">Dépôts hier</div>
          <div class="tvh-num" id="depYestNum">— <span>FCFA</span></div>
        </div>
        <div class="tvh-card" style="border-left:3px solid #ef4444">
          <div class="tvh-label">Retraits hier</div>
          <div class="tvh-num" id="retYestNum">— <span>FCFA</span></div>
        </div>
      </div>
    </div>

    <!-- 6-month activity chart -->
    <div class="chart-card">
      <div class="chart-card-header">
        <div class="ch-icon"><i class="fas fa-chart-bar"></i></div>
        <div>
          <h3>Activité financière</h3>
        </div>
      </div>
      <p>6 derniers mois</p>
      <canvas id="activityChart" height="170"></canvas>
      <div class="chart-legend">
        <div class="legend-item"><div class="legend-dot" style="background:#22c55e"></div>Dép. validés</div>
        <div class="legend-item"><div class="legend-dot" style="background:#ef4444"></div>Dép. rejetés</div>
        <div class="legend-item"><div class="legend-dot" style="background:#3b82f6"></div>Ret. validés</div>
        <div class="legend-item"><div class="legend-dot" style="background:#f59e0b"></div>Ret. rejetés</div>
      </div>
    </div>

    <!-- Daily revenue card -->
