<!DOCTYPE html>
<html lang="fr">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0, maximum-scale=1.0, user-scalable=no">
    <title>Accueil - Altiora Capital Africa</title>
    <link href="https://fonts.googleapis.com/css2?family=Poppins:wght@300;400;500;600;700;800&display=swap" rel="stylesheet">
    <link rel="stylesheet" href="https://cdnjs.cloudflare.com/ajax/libs/font-awesome/6.5.0/css/all.min.css">
    <style>
    :root {
        --amber: #C47D1E;
        --amber-dark: #A0631A;
        --amber-light: #D4921F;
        --cream: #F5EFE6;
        --card-bg: #FFFFFF;
        --text-dark: #3D2B1F;
        --text-mid: #7D5A38;
        --text-muted: #A87D50;
        --border: #E8D5B0;
        --light-bg: #FBF5EC;
        --transition: all 0.3s ease;
    }

    * { margin:0; padding:0; box-sizing:border-box; -webkit-tap-highlight-color:transparent; }
    html, body { height:100%; overflow-x:hidden; overflow-y:auto; }
    body {
        font-family: 'Poppins', 'Inter', sans-serif;
        background: var(--cream);
        color: var(--text-dark);
        line-height: 1.6;
        -webkit-text-size-adjust: 100%;
        touch-action: pan-y;
        user-select: none;
        -webkit-user-select: none;
    }
    body * { -webkit-user-select:none; -webkit-touch-callout:none; }

    .container { max-width:430px; margin:0 auto; padding:0 0 90px; }

    /* ───────────── HEADER ───────────── */
    .header {
        background: linear-gradient(135deg, #D4921F, #A0631A);
        padding: 48px 18px 18px;
        display: flex; align-items: center; justify-content: space-between;
    }
    .logo { display:flex; align-items:center; gap:12px; }
    .logo-icon {
        width: 42px; height: 42px; border-radius: 50%;
        background: rgba(255,255,255,0.25);
        display: flex; align-items: center; justify-content: center;
        font-size: 18px; font-weight: 800; color: #fff;
        box-shadow: 0 0 0 2px rgba(255,255,255,0.3);
    }
    .logo-text { color: #fff; font-size: 16px; font-weight: 700; letter-spacing: 0.3px; }
    .logo-subtext { color: rgba(255,255,255,0.8); font-size: 10px; font-weight: 500; letter-spacing: 1px; margin-top: -1px; }
    .header-right { display:flex; gap:8px; }
    .hdr-btn {
        width: 38px; height: 38px; border-radius: 50%;
        background: rgba(255,255,255,0.2); border: none; cursor: pointer;
        display: flex; align-items: center; justify-content: center;
        color: #fff; font-size: 17px; transition: background 0.2s;
    }
    .hdr-btn:hover { background: rgba(255,255,255,0.3); }

    /* ───────────── PHOTO SLIDER ───────────── */
    .photos-section { padding: 16px 16px 0; }
    .photo-slider {
        position: relative; border-radius: 18px; overflow: hidden;
        height: 200px; box-shadow: 0 8px 28px rgba(196,125,30,0.18);
        background: var(--border);
    }
    .photo-slides { position:relative; width:100%; height:100%; }
    .photo-slide {
        position: absolute; inset: 0; opacity: 0;
        transition: opacity 0.6s ease;
    }
    .photo-slide.active { opacity: 1; }
    .photo-image { width:100%; height:100%; object-fit:cover; }
    .photo-overlay {
        position: absolute; bottom: 0; left: 0; right: 0;
        background: linear-gradient(to top, rgba(30,15,0,0.75) 0%, transparent 100%);
        padding: 12px 14px;
    }
    .photo-title { font-size: 15px; font-weight: 700; color: #fff; }
    .photo-subtitle { font-size: 12px; color: rgba(255,255,255,0.8); }
    .photo-indicators { display:flex; gap:6px; justify-content:center; margin-top:10px; }
    .photo-indicator {
        width: 8px; height: 8px; border-radius: 50%;
        background: var(--border); cursor: pointer; transition: all 0.3s;
    }
    .photo-indicator.active { background: var(--amber); width: 22px; border-radius: 4px; }

    /* ───────────── BALANCE + ACTIONS ───────────── */
    .main-section {
        padding: 16px;
        display: flex; gap: 12px;
    }
    .premium-card {
        flex: 1;
        background: linear-gradient(135deg, #D4921F, #A0631A);
        border-radius: 18px; padding: 18px;
        box-shadow: 0 8px 24px rgba(196,125,30,0.35);
        min-width: 0;
    }
    .card-header { display:flex; justify-content:space-between; align-items:flex-start; margin-bottom: 14px; }
    .balance-label { color: rgba(255,255,255,0.85); font-size: 12px; font-weight: 600;
        display: flex; align-items: center; gap: 6px; }
    .balance-label i { font-size: 13px; }
    .card-logo {
        width: 32px; height: 32px; border-radius: 50%;
        background: rgba(255,255,255,0.25); display: flex; align-items: center;
        justify-content: center; font-size: 12px; font-weight: 800; color: #fff;
    }
    .balance-container { margin-bottom: 10px; }
    .balance-amount { font-size: 26px; font-weight: 900; color: #fff; line-height: 1.1; }
    .revenue-info { display:flex; justify-content:space-between; padding-top:10px;
        border-top:1px solid rgba(255,255,255,0.2); }
    .revenue-label { color: rgba(255,255,255,0.7); font-size: 11px; font-weight: 500; }
    .revenue-amount { color: #fff; font-size: 13px; font-weight: 700; }

    /* Action sidebar */
    .action-bar {
        display: flex; flex-direction: column; gap: 8px;
        min-width: 80px; flex-shrink: 0;
    }
    .action-item {
        background: var(--card-bg); border-radius: 14px; padding: 10px 8px;
        text-align: center; cursor: pointer; transition: all 0.2s;
        border: 1px solid var(--border);
        box-shadow: 0 2px 8px rgba(196,125,30,0.08);
        display: flex; flex-direction: column; align-items: center; gap: 5px;
    }
    .action-item:hover { border-color: var(--amber); background: var(--light-bg); }
    .action-icon {
        width: 36px; height: 36px; border-radius: 11px;
        display: flex; align-items: center; justify-content: center; font-size: 15px;
    }
    .action-retrait .action-icon { background: rgba(239,68,68,0.12); color: #EF4444; }
    .action-roue .action-icon { background: rgba(139,92,246,0.12); color: #8B5CF6; }
    .action-cadeau .action-icon { background: rgba(196,125,30,0.12); color: var(--amber); }
    .action-label { font-size: 10px; font-weight: 600; color: var(--text-muted); }

    /* ───────────── HORIZONTAL ACTIONS ───────────── */
    .horizontal-actions { display:flex; gap:10px; padding:0 16px 14px; }
    .h-action-btn {
        flex: 1; background: var(--card-bg); border: 1px solid var(--border);
        border-radius: 14px; padding: 13px 8px; text-align: center;
        display: flex; flex-direction: column; align-items: center; gap: 6px;
        text-decoration: none; cursor: pointer; transition: all 0.2s;
        box-shadow: 0 2px 8px rgba(196,125,30,0.07);
    }
    .h-action-btn:hover { border-color: var(--amber); background: var(--light-bg); transform: translateY(-2px); }
    .h-action-icon { font-size: 18px; color: var(--amber); }
    .h-action-text { font-size: 11px; font-weight: 600; color: var(--text-mid); }

    /* ───────────── NOTIFICATION BAR ───────────── */
    .notification-bar {
        margin: 0 16px 14px;
        background: linear-gradient(135deg, rgba(212,146,31,0.12), rgba(176,112,24,0.08));
        border: 1px solid rgba(196,125,30,0.2);
        border-radius: 12px; padding: 12px 14px;
        overflow: hidden; height: 48px; position: relative;
    }
    .notification-container { position:relative; height:100%; }
    .notification-item {
        position: absolute; top: 0; left: 0; right: 0;
        display: flex; align-items: center; gap: 8px;
        font-size: 13px; font-weight: 500; color: var(--text-mid);
        opacity: 0; transition: opacity 0.5s ease;
        white-space: nowrap; overflow: hidden; text-overflow: ellipsis;
    }
    .notification-item.visible { opacity: 1; }
    .notification-item i { color: var(--amber); flex-shrink: 0; }

    /* ───────────── POSTS SECTION ───────────── */
    .posts-section { padding: 0 16px 16px; }
    .posts-header { display:flex; justify-content:space-between; align-items:center; margin-bottom:12px; }
    .posts-title { font-size: 15px; font-weight: 700; color: var(--text-dark);
        display: flex; align-items: center; gap: 8px; }
    .posts-title i { color: var(--amber); }
    .post-btn {
        background: linear-gradient(135deg, #D4921F, #B07018);
        color: #fff; border: none; border-radius: 20px;
        padding: 7px 14px; font-size: 12px; font-weight: 600; cursor: pointer;
        display: flex; align-items: center; gap: 6px; font-family: 'Poppins', sans-serif;
    }
    .post-slider-container { position: relative; }
    .post-slider {
        height: 320px; border-radius: 18px; overflow: hidden;
        background: var(--card-bg); position: relative;
        box-shadow: 0 4px 16px rgba(196,125,30,0.10); border: 1px solid var(--border);
    }
    .post-slides { position:relative; width:100%; height:100%; }
    .post-slide { position:absolute; inset:0; opacity:0; transition:opacity 0.5s ease; }
    .post-slide.active { opacity:1; }
    .post-image-container { height: 240px; overflow:hidden; background: var(--light-bg); }
    .post-image { width:100%; height:100%; object-fit:cover; }
    .post-content { padding: 12px 14px; }
    .post-text { color: var(--text-dark); font-size: 13px; line-height: 1.5;
        overflow: hidden; text-overflow: ellipsis; display: -webkit-box;
        -webkit-line-clamp: 2; -webkit-box-orient: vertical; }
    .post-indicators { display:flex; gap:6px; justify-content:center; padding:8px; }
    .post-indicator { width:7px; height:7px; border-radius:50%; background:var(--border);
        cursor:pointer; transition:all 0.3s; }
    .post-indicator.active { background:var(--amber); width:20px; border-radius:4px; }

    /* ───────────── POPUP GENERIC ───────────── */
    .popup {
        display: none; position: fixed; inset: 0;
        background: rgba(0,0,0,0.55); backdrop-filter: blur(8px);
        z-index: 2000; align-items: center; justify-content: center; padding: 20px;
    }
    .popup-content {
        background: var(--card-bg); border-radius: 22px;
        width: 100%; max-width: 370px; overflow: hidden;
        box-shadow: 0 24px 60px rgba(0,0,0,0.25);
    }
    .popup-header {
        background: linear-gradient(135deg, #D4921F, #A0631A);
        padding: 18px 20px;
        display: flex; justify-content: space-between; align-items: center;
    }
    .popup-header h3 { color: #fff; font-size: 17px; font-weight: 700; }
    .popup-close { background: rgba(255,255,255,0.2); border: none; color: #fff;
        width: 30px; height: 30px; border-radius: 50%; cursor: pointer; font-size: 18px;
        display: flex; align-items: center; justify-content: center; }
    .popup-body { padding: 20px; }
    .popup-text { color: var(--text-mid); font-size: 14px; line-height: 1.6; margin-bottom: 16px; }
    .community-buttons { display:flex; flex-direction:column; gap:10px; }
    .community-btn {
        display: flex; align-items: center; gap: 12px;
        padding: 13px 15px; border-radius: 12px; text-decoration: none;
        transition: all 0.2s;
        background: rgba(196,125,30,0.06); border: 1px solid rgba(196,125,30,0.2);
    }
    .community-btn:hover { background: rgba(196,125,30,0.12); transform: translateY(-2px); }
    .community-btn i { font-size: 22px; color: #2AABEE; }
    .community-btn-text h4 { color: var(--text-dark); font-size: 14px; margin-bottom: 2px; }
    .community-btn-text p { color: var(--text-muted); font-size: 12px; }

    /* ───────────── POST FORM ───────────── */
    .form-group { margin-bottom: 16px; }
    .form-label { display:block; color: var(--text-muted); font-size: 12px; font-weight:600; margin-bottom:7px; }
    .form-textarea {
        width: 100%; background: var(--light-bg); border: 1.5px solid var(--border);
        border-radius: 12px; padding: 12px; color: var(--text-dark);
        font-size: 14px; font-family: 'Poppins', sans-serif; outline: none;
        min-height: 90px; resize: vertical; transition: border-color 0.2s;
    }
    .form-textarea:focus { border-color: var(--amber); }
    .file-upload { position: relative; }
    .file-upload-btn {
        background: var(--light-bg); border: 2px dashed var(--border);
        border-radius: 12px; padding: 20px; text-align: center;
        color: var(--text-muted); cursor: pointer; font-size: 13px;
        transition: border-color 0.2s;
    }
    .file-upload-btn:hover { border-color: var(--amber); }
    .file-upload-input { position: absolute; inset: 0; opacity: 0; cursor: pointer; width:100%; height:100%; }
    .image-preview-small { max-width: 100%; max-height: 80px; border-radius: 8px; margin-top: 8px; display: none; }
    .submit-btn {
        width: 100%; background: linear-gradient(135deg, #D4921F, #B07018);
        color: #fff; border: none; border-radius: 12px; padding: 14px;
        font-size: 15px; font-weight: 700; cursor: pointer;
        box-shadow: 0 5px 16px rgba(196,125,30,0.35); font-family: 'Poppins', sans-serif;
    }

    /* ───────────── WELCOME POPUP ───────────── */
    .welcome-popup {
        display: flex; position: fixed; inset: 0;
        background: rgba(0,0,0,0.65); backdrop-filter: blur(8px);
        z-index: 2500; align-items: center; justify-content: center; padding: 20px;
    }
    .welcome-content {
        background: var(--card-bg); border-radius: 24px;
        width: 100%; max-width: 360px; overflow: hidden;
        box-shadow: 0 30px 60px rgba(0,0,0,0.3);
        animation: popupIn 0.5s cubic-bezier(0.175, 0.885, 0.32, 1.275);
    }
    @keyframes popupIn { from { transform: scale(0.9); opacity: 0; } to { transform: scale(1); opacity: 1; } }
    .welcome-header {
        padding: 24px 20px;
        background: linear-gradient(135deg, #D4921F, #A0631A);
        color: white; text-align: center; position: relative;
    }
    .welcome-header h3 { font-size: 20px; font-weight: 800; margin-bottom: 8px; }
    .welcome-message { font-size: 13px; color: rgba(255,255,255,0.9); line-height: 1.5; }
    .welcome-close-top {
        position: absolute; top: 12px; right: 14px;
        background: rgba(255,255,255,0.2); border: none; color: #fff;
        width: 28px; height: 28px; border-radius: 50%; cursor: pointer; font-size: 16px;
        display: flex; align-items: center; justify-content: center;
    }
    .welcome-body { padding: 20px; }
    .bonus-section {
        background: linear-gradient(135deg, #D4921F, #A0631A);
        border-radius: 12px; padding: 14px; margin-bottom: 14px; text-align: center; color: #fff;
    }
    .bonus-title { font-weight: 700; font-size: 15px; margin-bottom: 6px; }
    .bonus-text { font-size: 13px; opacity: 0.9; }
    .welcome-buttons { display:flex; flex-direction:column; gap:10px; }
    .welcome-btn {
        padding: 13px; border-radius: 12px; font-weight: 700; cursor: pointer;
        transition: all 0.2s; text-decoration: none; display: flex;
        align-items: center; justify-content: center; gap: 9px;
        font-size: 14px; border: none; font-family: 'Poppins', sans-serif;
    }
    .button-row { display:flex; gap:10px; }
    .button-row .welcome-btn { flex:1; }
    .welcome-btn-join { background: linear-gradient(135deg, #D4921F, #B07018); color: #fff; }
    .welcome-btn-close { background: var(--light-bg); color: var(--text-mid); border: 1.5px solid var(--border); }
    .welcome-btn:hover { transform: translateY(-2px); box-shadow: 0 5px 15px rgba(0,0,0,0.15); }

    /* ───────────── FLOATING SERVICE ───────────── */
    .floating-service {
        position: fixed; bottom: 100px; right: 18px;
        width: 56px; height: 56px; border-radius: 50%;
        background: linear-gradient(135deg, #D4921F, #A0631A);
        color: #fff; display: flex; align-items: center; justify-content: center;
        box-shadow: 0 8px 24px rgba(196,125,30,0.45); cursor: pointer;
        z-index: 99; transition: transform 0.3s; border: none;
    }
    .floating-service:hover { transform: scale(1.08); }
    .floating-service i { font-size: 22px; transform: scaleX(-1); }

    .service-popup {
        position: fixed; bottom: 165px; right: 18px;
        background: var(--card-bg); border-radius: 16px;
        box-shadow: 0 14px 40px rgba(0,0,0,0.18);
        z-index: 100; display: none; flex-direction: column;
        border: 1px solid var(--amber); width: 200px; overflow: hidden;
        animation: slideUp 0.3s ease;
    }
    @keyframes slideUp { from { opacity:0; transform: translateY(14px); } to { opacity:1; transform: translateY(0); } }
    .service-header {
        padding: 13px 15px;
        background: linear-gradient(135deg, #D4921F, #A0631A);
        color: #fff; text-align: center; font-weight: 700; font-size: 13px;
    }
    .service-option {
        display: flex; align-items: center; gap: 10px; padding: 13px 15px;
        cursor: pointer; background: none; border: none; width: 100%;
        color: var(--text-dark); font-size: 13px; font-weight: 600;
        transition: background 0.2s;
    }
    .service-option:hover { background: var(--light-bg); }
    .service-option i { color: var(--amber); font-size: 17px; width: 22px; text-align: center; }

    /* ───────────── RESPONSIVE ───────────── */
    @media (max-width: 480px) {
        .main-section { flex-direction: column; gap: 12px; }
        .action-bar { flex-direction: row; min-width: unset; }
        .action-item { min-width: 0; }
        .balance-amount { font-size: 22px; }
        .photo-slider { height: 170px; }
        .post-slider { height: 280px; }
        .post-image-container { height: 200px; }
    }
    </style>
</head>
<body>
<%- include('partials/menu', { page: 'index' }) %>

<div class="container">
    <!-- Header -->
    <div class="header">
        <div class="logo">
            <div class="logo-icon"><i class="fas fa-chart-line" style="font-size:18px"></i></div>
            <div>
                <div class="logo-text">ALTIORA</div>
                <div class="logo-subtext">CAPITAL AFRICA</div>
            </div>
        </div>
        <div class="header-right">
            <button class="hdr-btn" onclick="toggleServicePopup()"><i class="fas fa-phone-alt"></i></button>
        </div>
    </div>

    <!-- Photo slider -->
    <div class="photos-section">
        <div class="photo-slider" id="photoSlider">
            <div class="photo-slides">
                <div class="photo-slide active">
                    <img src="/images/slide1.jpeg" class="photo-image" alt="Altiora Capital Africa">
                    <div class="photo-overlay">
                        <div class="photo-title">Altiora Capital Africa</div>
                        <div class="photo-subtitle">Investissez aujourd'hui, bâtir l'avenir de l'Afrique</div>
                    </div>
                </div>
                <div class="photo-slide">
                    <img src="/images/slide2.jpeg" class="photo-image" alt="Notre Communauté">
                    <div class="photo-overlay">
                        <div class="photo-title">Notre Communauté</div>
                        <div class="photo-subtitle">Plus de 10 000 investisseurs nous font confiance</div>
                    </div>
                </div>
                <div class="photo-slide">
                    <img src="/images/slide3.jpeg" class="photo-image" alt="Événements Altiora">
                    <div class="photo-overlay">
                        <div class="photo-title">Événements & Formations</div>
                        <div class="photo-subtitle">Ensemble, construisons la richesse de demain</div>
                    </div>
                </div>
                <div class="photo-slide">
                    <img src="/images/slide4.jpeg" class="photo-image" alt="Siège Altiora">
                    <div class="photo-overlay">
                        <div class="photo-title">Notre Siège Social</div>
                        <div class="photo-subtitle">Agriculture · Énergie · Immobilier · Finance</div>
                    </div>
                </div>
            </div>
            <div class="photo-indicators">
                <div class="photo-indicator active" onclick="showPhoto(0)"></div>
                <div class="photo-indicator" onclick="showPhoto(1)"></div>
                <div class="photo-indicator" onclick="showPhoto(2)"></div>
                <div class="photo-indicator" onclick="showPhoto(3)"></div>
            </div>
        </div>
    </div>

    <!-- Balance + Actions -->
    <div class="main-section">
        <div class="premium-card">
            <div class="card-header">
                <div class="balance-label">
                    <i class="fas fa-wallet"></i> Solde Principal
                </div>
                <div class="card-logo"><i class="fas fa-chart-line" style="font-size:14px"></i></div>
            </div>
            <div class="balance-container">
                <div class="balance-amount"><%= user.solde.toLocaleString() %> <%= devise %></div>
            </div>
            <div class="revenue-info">
                <div class="revenue-label">Revenus Totaux</div>
                <div class="revenue-amount"><%= (revenus.total || 0).toLocaleString() %> <%= devise %></div>
            </div>
        </div>

        <div class="action-bar">
            <div class="action-item action-retrait" onclick="window.location.href='/retrait'">
                <div class="action-icon"><i class="fas fa-hand-holding-usd"></i></div>
                <div class="action-label">Retrait</div>
            </div>
            <div class="action-item action-roue" onclick="window.location.href='/roue'">
                <div class="action-icon"><i class="fas fa-dice"></i></div>
                <div class="action-label">Roue</div>
            </div>
            <div class="action-item action-cadeau" onclick="window.location.href='/cadeau'">
                <div class="action-icon"><i class="fas fa-gift"></i></div>
                <div class="action-label">Cadeau</div>
            </div>
        </div>
    </div>

    <!-- Horizontal actions -->
    <div class="horizontal-actions">
        <a href="/depot" class="h-action-btn">
            <i class="fas fa-arrow-down h-action-icon"></i>
            <span class="h-action-text">Dépôt</span>
        </a>
        <a href="/faq" class="h-action-btn">
            <i class="fas fa-play-circle h-action-icon"></i>
            <span class="h-action-text">Tuto</span>
        </a>
        <a href="/investissement" class="h-action-btn">
            <i class="fas fa-crown h-action-icon"></i>
            <span class="h-action-text">VIP</span>
        </a>
        <button class="h-action-btn" onclick="openTelegramPopup()">
            <i class="fab fa-telegram h-action-icon"></i>
            <span class="h-action-text">Rejoindre</span>
        </button>
    </div>

    <!-- Notification bar -->
    <div class="notification-bar">
        <div class="notification-container" id="notificationContainer"></div>
    </div>

    <!-- Posts section -->
    <div class="posts-section">
        <div class="posts-header">
            <div class="posts-title">
                <i class="fas fa-newspaper"></i>
                Actualités Communauté
            </div>
            <button class="post-btn" onclick="openPostPopup()">
                <i class="fas fa-plus"></i> Poster
            </button>
        </div>

        <div class="post-slider-container">
            <div class="post-slider" id="postSlider">
                <div class="post-slides">
                    <% if (posts.length > 0) { %>
                        <% posts.forEach((post, index) => { %>
                            <div class="post-slide <%= index === 0 ? 'active' : '' %>">
                                <div class="post-image-container">
                                    <img src="uploads/<%= post.image %>" class="post-image" alt="Post image"
                                         onerror="this.parentElement.style.background='var(--light-bg)';this.style.display='none'">
                                </div>
                                <div class="post-content">
                                    <div class="post-text"><%= post.message %></div>
                                </div>
                            </div>
                        <% }); %>
                    <% } else { %>
                        <div class="post-slide active">
                            <div class="post-image-container" style="display:flex;align-items:center;justify-content:center;background:var(--light-bg);">
                                <div style="text-align:center;color:var(--text-muted);">
                                    <i class="fas fa-images" style="font-size:40px;margin-bottom:10px;display:block;color:var(--border)"></i>
                                    <p>Aucun post pour le moment</p>
                                </div>
                            </div>
                        </div>
                    <% } %>
                </div>
                <% if (posts.length > 1) { %>
                <div class="post-indicators">
                    <% posts.forEach((post, index) => { %>
                        <div class="post-indicator <%= index === 0 ? 'active' : '' %>" onclick="showPost(<%= index %>)"></div>
                    <% }); %>
                </div>
                <% } %>
            </div>
        </div>
    </div>
</div>

<!-- Floating service btn -->
<button class="floating-service" onclick="toggleServicePopup()">
    <i class="fas fa-phone-alt"></i>
</button>
<div class="service-popup" id="servicePopup">
    <div class="service-header">Service Client</div>
    <button class="service-option" onclick="contactCustomerService()">
        <i class="fas fa-comment-dots"></i><span>Nous contacter</span>
    </button>
</div>

<!-- Welcome popup -->
<div class="welcome-popup" id="welcomePopup">
    <div class="welcome-content">
        <div class="welcome-header">
            <h3>Altiora Capital Africa</h3>
            <div class="welcome-message">
                Fondée en 2026 à Douala, Altiora Capital Africa est une plateforme panafricaine d'investissement participatif. Investissez dans des projets à fort potentiel et générez des revenus quotidiens. <em>« Ensemble, construisons la richesse de demain. »</em>
            </div>
            <button class="welcome-close-top" onclick="closeWelcomePopup()">&times;</button>
        </div>
        <div class="welcome-body">
            <div class="bonus-section">
                <div class="bonus-title">🎁 Bonus d'inscription : 250 FCFA</div>
                <div class="bonus-text">Invitez vos amis et gagnez 20% de leur investissement</div>
            </div>
            <div class="welcome-buttons">
                <div class="button-row">
                    <a href="https://t.me/officielcanalBlackRock" class="welcome-btn welcome-btn-join">
                        <i class="fab fa-telegram"></i> Canal
                    </a>
                    <a href="https://t.me/groupeofficielblackrock" class="welcome-btn welcome-btn-join">
                        <i class="fab fa-telegram"></i> Groupe
                    </a>
                </div>
                <button class="welcome-btn welcome-btn-close" onclick="closeWelcomePopup()">
                    <i class="fas fa-times"></i> Fermer
                </button>
            </div>
        </div>
    </div>
</div>

<!-- Telegram popup -->
<div class="popup" id="telegramPopup">
    <div class="popup-content">
        <div class="popup-header">
            <h3>Rejoignez notre Communauté Altiora</h3>
            <button class="popup-close" onclick="closePopup('telegramPopup')">&times;</button>
        </div>
        <div class="popup-body">
            <p class="popup-text">Restez connecté avec la communauté Altiora Capital Africa et ne manquez aucune opportunité d'investissement!</p>
            <div class="community-buttons">
                <a href="https://t.me/officielcanalBlackRock" class="community-btn">
                    <i class="fab fa-telegram"></i>
                    <div class="community-btn-text">
                        <h4>Canal Officiel</h4>
                        <p>Annonces et actualités</p>
                    </div>
                </a>
                <a href="https://t.me/groupeofficielblackrock" class="community-btn">
                    <i class="fab fa-telegram"></i>
                    <div class="community-btn-text">
                        <h4>Groupe Discussion</h4>
                        <p>Échangez avec la communauté</p>
                    </div>
                </a>
            </div>
        </div>
    </div>
</div>

<!-- Post popup -->
<div class="popup" id="postPopup">
    <div class="popup-content">
        <div class="popup-header">
            <h3>Créer un post</h3>
            <button class="popup-close" onclick="closePopup('postPopup')">&times;</button>
        </div>
        <div class="popup-body">
            <form id="postForm" enctype="multipart/form-data" method="POST">
                <div class="form-group">
                    <label class="form-label" for="postMessage">Message</label>
                    <textarea id="postMessage" name="message" class="form-textarea" placeholder="Partagez votre expérience avec Altiora..." required></textarea>
                </div>
                <div class="form-group">
                    <label class="form-label" for="postImage">Image</label>
                    <div class="file-upload">
                        <div class="file-upload-btn">
                            <i class="fas fa-cloud-upload-alt" style="font-size:24px;margin-bottom:8px;display:block;color:var(--amber)"></i>
                            <div>Cliquez pour télécharger une image</div>
                            <div style="font-size:12px;color:var(--text-muted);margin-top:4px;">PNG, JPG, JPEG max 5MB</div>
                            <img id="imagePreview" class="image-preview-small" alt="Aperçu">
                        </div>
                        <input type="file" id="postImage" name="image" class="file-upload-input"
                               accept="image/*" required onchange="previewImage(this)">
                    </div>
                </div>
                <button type="submit" class="submit-btn">
                    <i class="fas fa-paper-plane"></i> Publier le post
                </button>
            </form>
        </div>
    </div>
</div>

<script>
// ── POPUP UTILITIES ──
function closePopup(id) { const p = document.getElementById(id); if (p) p.style.display = 'none'; }
function closeWelcomePopup() { closePopup('welcomePopup'); }
function openTelegramPopup() { document.getElementById('telegramPopup').style.display = 'flex'; }
function openPostPopup() { document.getElementById('postPopup').style.display = 'flex'; }

// ── SERVICE POPUP ──
function toggleServicePopup() {
    const popup = document.getElementById('servicePopup');
    popup.style.display = popup.style.display === 'flex' ? 'none' : 'flex';
}
function contactCustomerService() {
    window.open('https://t.me/blackrock_support', '_blank');
    document.getElementById('servicePopup').style.display = 'none';
}
document.addEventListener('click', e => {
    const sp = document.getElementById('servicePopup');
    const fb = document.querySelector('.floating-service');
    if (sp && fb && !sp.contains(e.target) && !fb.contains(e.target)) sp.style.display = 'none';
});

// ── PHOTO SLIDER ──
let currentPhoto = 0;
const photoSlides = document.querySelectorAll('.photo-slide');
const photoIndicators = document.querySelectorAll('.photo-indicator');
function showPhoto(index) {
    photoSlides.forEach(s => s.classList.remove('active'));
    photoIndicators.forEach(i => i.classList.remove('active'));
    currentPhoto = index;
    if (photoSlides[index]) photoSlides[index].classList.add('active');
    if (photoIndicators[index]) photoIndicators[index].classList.add('active');
}
setInterval(() => { showPhoto((currentPhoto + 1) % photoSlides.length); }, 4000);

// ── POST SLIDER ──
let currentPost = 0;
const postSlides = document.querySelectorAll('.post-slide');
const postIndicators = document.querySelectorAll('.post-indicator');
function showPost(index) {
    postSlides.forEach(s => s.classList.remove('active'));
    postIndicators.forEach(i => i.classList.remove('active'));
    currentPost = index;
    if (postSlides[index]) postSlides[index].classList.add('active');
    if (postIndicators[index]) postIndicators[index].classList.add('active');
}
if (postSlides.length > 1) setInterval(() => { showPost((currentPost + 1) % postSlides.length); }, 5000);

// ── NOTIFICATIONS ──
const notifications = <%- JSON.stringify(notifications || []) %>;
let notifIndex = 0;
function showNotifications() {
    const container = document.getElementById('notificationContainer');
    if (!container || notifications.length === 0) {
        if (container) container.innerHTML = '<div class="notification-item visible" style="font-size:13px;"><i class="fas fa-bell"></i> Bienvenue sur Altiora Capital Africa !</div>';
        return;
    }
    container.innerHTML = '';
    const item = document.createElement('div');
    item.className = 'notification-item';
    item.innerHTML = `<i class="fas fa-bell"></i> ${notifications[notifIndex % notifications.length].message || notifications[notifIndex % notifications.length]}`;
    container.appendChild(item);
    setTimeout(() => item.classList.add('visible'), 50);
    notifIndex++;
}
showNotifications();
setInterval(() => {
    const current = document.querySelector('.notification-item.visible');
    if (current) { current.classList.remove('visible'); setTimeout(showNotifications, 500); }
    else showNotifications();
}, 3500);

// ── IMAGE PREVIEW ──
function previewImage(input) {
    const preview = document.getElementById('imagePreview');
    if (input.files && input.files[0]) {
        const reader = new FileReader();
        reader.onload = e => { preview.src = e.target.result; preview.style.display = 'block'; };
        reader.readAsDataURL(input.files[0]);
    }
}

// ── DISABLE ZOOM ──
document.addEventListener('wheel', e => { if (e.ctrlKey) e.preventDefault(); }, { passive: false });
document.addEventListener('gesturestart', e => e.preventDefault());
</script>
</body>
</html>
