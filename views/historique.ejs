<!DOCTYPE html>
<html lang="fr">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0, maximum-scale=1.0, user-scalable=no">
    <title>Historique des Transactions - Altiora Capital Africa</title>
    <link href="https://fonts.googleapis.com/css2?family=Poppins:wght@300;400;500;600;700;800&display=swap" rel="stylesheet">
    <link rel="stylesheet" href="https://cdnjs.cloudflare.com/ajax/libs/font-awesome/6.5.0/css/all.min.css">
    <style>
        * { margin:0; padding:0; box-sizing:border-box; font-family:'Poppins','Segoe UI',sans-serif; }
        body { background:#F5EFE6; color:#3D2B1F; min-height:100vh; padding-bottom:90px; }
        .container { max-width:430px; margin:0 auto; }

        .page-header {
            background: linear-gradient(135deg, #D4921F, #A0631A);
            padding: 50px 20px 28px; display:flex; align-items:center; gap:14px;
        }
        .back-btn {
            width:36px; height:36px; border-radius:50%;
            background:rgba(255,255,255,0.2); display:flex; align-items:center;
            justify-content:center; color:#fff; text-decoration:none; font-size:16px; flex-shrink:0;
        }
        .header-txt h1 { font-size:20px; font-weight:700; color:#fff; }
        .header-txt p { font-size:13px; color:rgba(255,255,255,0.85); margin-top:2px; }

        .content { padding:16px; }

        .tx-card {
            background:#fff; border-radius:16px; border:1px solid #F0E0C8;
            box-shadow:0 2px 10px rgba(196,125,30,0.08); overflow:hidden;
        }
        .tx-list { list-style:none; }
        .tx-item { display:flex; justify-content:space-between; align-items:center; padding:16px; border-bottom:1px solid #F5EFE6; }
        .tx-item:last-child { border-bottom:none; }
        .tx-left { display:flex; align-items:center; gap:12px; }
        .tx-ico {
            width:40px; height:40px; border-radius:12px; flex-shrink:0;
            display:flex; align-items:center; justify-content:center; font-size:16px;
        }
        .tx-ico.depot { background:rgba(22,163,74,0.12); color:#16A34A; }
        .tx-ico.retrait { background:rgba(220,38,38,0.12); color:#DC2626; }
        .tx-ico.revenu { background:rgba(196,125,30,0.12); color:#C47D1E; }
        .tx-type { font-size:14px; font-weight:600; color:#3D2B1F; text-transform:capitalize; }
        .tx-date { font-size:12px; color:#A87D50; margin-top:2px; }
        .tx-statut { font-size:11px; margin-top:3px; font-weight:600; }
        .tx-statut.valide { color:#16A34A; }
        .tx-statut.en_attente { color:#C47D1E; }
        .tx-statut.rejete { color:#DC2626; }
        .tx-amt { font-size:14px; font-weight:700; text-align:right; }
        .tx-pos { color:#16A34A; }
        .tx-neg { color:#DC2626; }

        .empty-state { text-align:center; padding:60px 20px; }
        .empty-icon { font-size:52px; color:#E8D5B0; margin-bottom:16px; }
        .empty-title { font-size:16px; font-weight:600; color:#7D5A38; }
        .empty-msg { font-size:13px; color:#A87D50; margin-top:6px; }

        .pagination { display:flex; align-items:center; justify-content:space-between; gap:10px; margin-top:16px; }
        .page-btn {
            flex:1; text-align:center; padding:12px; border-radius:12px;
            background:#fff; border:1px solid #E8D5B0; color:#C47D1E;
            font-weight:700; font-size:13px; text-decoration:none;
        }
        .page-btn.disabled { color:#D8C4A0; pointer-events:none; opacity:0.6; }
        .page-info { font-size:12px; color:#A87D50; white-space:nowrap; }

        /* Verify button */
        .btn-verify {
            margin-top:6px; display:inline-flex; align-items:center; gap:5px;
            background:#FBF5EC; border:1.5px solid #C47D1E; border-radius:8px;
            color:#C47D1E; font-size:11px; font-weight:700; padding:4px 10px;
            cursor:pointer; font-family:'Poppins',sans-serif;
        }
        .btn-verify:disabled { opacity:0.5; cursor:not-allowed; }
        .btn-verify.ok  { border-color:#16A34A; color:#16A34A; background:#F0FFF4; }
        .btn-verify.err { border-color:#DC2626; color:#DC2626; background:#FFF0EE; }
    </style>
</head>
<body>
<%- include('partials/menu', { page: 'compte' }) %>
<div class="container">
    <div class="page-header">
        <a href="/compte" class="back-btn"><i class="fas fa-chevron-left"></i></a>
        <div class="header-txt">
            <h1>Historique</h1>
            <p>Toutes vos transactions</p>
        </div>
    </div>

    <div class="content">
        <% if (transactions && transactions.length > 0) { %>
        <div class="tx-card">
            <ul class="tx-list">
                <% const revenuSourceLabels = { paiement_journalier: 'Investissement', parrainage: 'Parrainage', bonus: 'Machine à sous', cadeau: 'Machine à sous', salaire: 'Salaire VIP' }; %>
                <% transactions.forEach(tx => { %>
                <li class="tx-item" style="flex-wrap:wrap;gap:4px;">
                    <div class="tx-left" style="flex:1;min-width:0;">
                        <div class="tx-ico <%= tx.type %>">
                            <i class="fas <%= tx.type === 'depot' ? 'fa-arrow-down' : tx.type === 'retrait' ? 'fa-arrow-up' : 'fa-coins' %>"></i>
                        </div>
                        <div style="min-width:0;">
                            <div class="tx-type">
                                <%= tx.type === 'depot' ? 'Dépôt' : tx.type === 'retrait' ? 'Retrait' : 'Revenu' %>
                                <% if (tx.type === 'revenu') { %>
                                <span style="font-size:11px;font-weight:600;color:#A87D50;text-transform:none;">— <%= revenuSourceLabels[tx.source] || tx.source || 'Autre' %></span>
                                <% } %>
                            </div>
                            <div class="tx-date"><%= tx.date ? new Date(tx.date).toLocaleString('fr-FR') : '' %></div>
                            <div class="tx-statut <%= tx.statut %>">
                                <%= tx.statut === 'valide' ? '✓ Validé' : tx.statut === 'en_attente' ? '⏳ En attente' : '✗ Rejeté' %>
                            </div>
                            <% if (tx.type === 'depot' && tx.statut === 'en_attente' && tx.id) { %>
                            <button class="btn-verify" onclick="verifierDepot(this, <%= tx.id %>)">
                                <i class="fas fa-sync-alt"></i> Vérifier
                            </button>
                            <% } %>
                        </div>
                    </div>
                    <span class="tx-amt <%= (tx.type === 'retrait') ? 'tx-neg' : 'tx-pos' %>">
                        <%= (tx.type === 'retrait' ? '-' : '+') %><%= parseFloat(tx.montant).toLocaleString('fr-FR') %> FCFA
                    </span>
                </li>
                <% }); %>
            </ul>
        </div>
        <% if (total_pages > 1) { %>
        <div class="pagination">
            <a href="/historique?page=<%= page - 1 %>" class="page-btn <%= page <= 1 ? 'disabled' : '' %>"><i class="fas fa-chevron-left"></i> Préc.</a>
            <span class="page-info">Page <%= page %> / <%= total_pages %></span>
            <a href="/historique?page=<%= page + 1 %>" class="page-btn <%= page >= total_pages ? 'disabled' : '' %>">Suiv. <i class="fas fa-chevron-right"></i></a>
        </div>
        <% } %>
        <% } else { %>
        <div class="empty-state">
            <div class="empty-icon"><i class="fas fa-receipt"></i></div>
            <div class="empty-title">Aucune transaction trouvée</div>
            <div class="empty-msg">Vos dépôts, retraits et revenus s'afficheront ici.</div>
        </div>
        <% } %>
    </div>
</div>
<script>
async function verifierDepot(btn, depotId) {
    btn.disabled = true;
    const icon = btn.querySelector('i');
    icon.classList.add('fa-spin');
    btn.textContent = ' Vérification…';
    btn.prepend(icon);
    try {
        const r = await fetch('/depot/status/' + depotId);
        const d = await r.json();
        icon.classList.remove('fa-spin');
        if (d.statut === 'valide') {
            btn.classList.add('ok');
            btn.innerHTML = '<i class="fas fa-check-circle"></i> Validé — ' + parseFloat(d.montant).toLocaleString('fr-FR') + ' FCFA crédités';
            // Refresh after 1.5s so the row reflects the new status
            setTimeout(() => location.reload(), 1500);
        } else if (d.statut === 'rejete') {
            btn.classList.add('err');
            btn.innerHTML = '<i class="fas fa-times-circle"></i> Rejeté';
            setTimeout(() => location.reload(), 1500);
        } else {
            btn.disabled = false;
            btn.innerHTML = '<i class="fas fa-sync-alt"></i> Toujours en attente';
        }
    } catch(e) {
        icon.classList.remove('fa-spin');
        btn.disabled = false;
        btn.innerHTML = '<i class="fas fa-sync-alt"></i> Réessayer';
    }
}
</script>
</body>
</html>
