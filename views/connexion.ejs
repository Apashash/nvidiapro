<!DOCTYPE html>
<html lang="fr">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0, maximum-scale=1.0, user-scalable=no">
    <title>Connexion - NVIDIA Technologie</title>
    <link href="https://fonts.googleapis.com/css2?family=Poppins:wght@300;400;500;600;700;800&display=swap" rel="stylesheet">
    <link rel="stylesheet" href="https://cdnjs.cloudflare.com/ajax/libs/font-awesome/6.5.0/css/all.min.css">
    <style>
        * { margin:0; padding:0; box-sizing:border-box; -webkit-tap-highlight-color:transparent; }
        html, body { height:100%; overflow-x:hidden; font-family:'Poppins',sans-serif; }
        body {
            background: #F5EFE6;
            min-height: 100vh;
            display: flex;
            flex-direction: column;
        }
        /* Hero header with rice field image */
        .hero {
            height: 260px;
            background: linear-gradient(to bottom, rgba(30,20,0,0.45) 0%, rgba(80,45,0,0.55) 100%),
                        url('https://images.unsplash.com/photo-1536657464919-892534f60d6e?w=800&q=80') center/cover no-repeat;
            display: flex;
            flex-direction: column;
            align-items: center;
            justify-content: center;
            position: relative;
            flex-shrink: 0;
        }
        .hero-logo {
            width: 72px; height: 72px;
            background: linear-gradient(135deg, #D4921F, #B07018);
            border-radius: 50%;
            display: flex; align-items: center; justify-content: center;
            box-shadow: 0 0 0 4px rgba(255,255,255,0.3), 0 8px 24px rgba(0,0,0,0.4);
            margin-bottom: 12px;
        }
        .hero-logo i { font-size: 32px; color: #fff; }
        .hero h1 { font-size: 26px; font-weight: 800; color: #fff; letter-spacing: 0.5px; text-shadow: 0 2px 8px rgba(0,0,0,0.4); }
        .hero p { font-size: 13px; color: rgba(255,255,255,0.85); margin-top: 4px; text-shadow: 0 1px 4px rgba(0,0,0,0.4); }

        /* Form card */
        .form-card {
            background: #fff;
            border-radius: 28px 28px 0 0;
            margin-top: -28px;
            flex: 1;
            padding: 32px 24px 40px;
            box-shadow: 0 -8px 32px rgba(196,125,30,0.10);
        }
        .form-title { font-size: 22px; font-weight: 700; color: #3D2B1F; margin-bottom: 6px; }
        .form-subtitle { font-size: 13px; color: #A87D50; margin-bottom: 28px; }

        .form-group { margin-bottom: 18px; }
        .form-label { display:block; font-size:13px; font-weight:600; color:#7D5A38; margin-bottom:8px; }
        .input-wrap {
            display: flex; align-items: center;
            background: #FBF5EC;
            border: 1.5px solid #E8D5B0;
            border-radius: 14px;
            overflow: hidden;
            transition: border-color 0.2s, box-shadow 0.2s;
        }
        .input-wrap:focus-within {
            border-color: #C47D1E;
            box-shadow: 0 0 0 3px rgba(196,125,30,0.15);
        }
        .input-icon {
            width: 48px; height: 52px;
            background: linear-gradient(135deg, #D4921F, #B07018);
            display: flex; align-items: center; justify-content: center;
            flex-shrink: 0;
            border-radius: 12px;
            margin: 4px;
        }
        .input-icon i { color: #fff; font-size: 16px; }
        .input-wrap input, .input-wrap select {
            flex: 1; border: none; background: transparent;
            padding: 14px 14px 14px 10px;
            font-size: 15px; color: #3D2B1F;
            font-family: 'Poppins', sans-serif;
            outline: none;
        }
        .input-wrap select { cursor: pointer; -webkit-appearance: none; }
        .input-wrap .phone-divider { width: 1px; height: 24px; background: #E8D5B0; flex-shrink: 0; }

        .error-box {
            background: #FFF0EE; border: 1px solid #F5A9A0; border-radius: 12px;
            padding: 13px 16px; margin-bottom: 20px; color: #C0392B; font-size: 13px;
            display: flex; align-items: center; gap: 10px;
        }
        .btn-submit {
            width: 100%; padding: 17px;
            background: linear-gradient(135deg, #D4921F, #B07018);
            border: none; border-radius: 16px;
            font-size: 16px; font-weight: 700; color: #fff;
            cursor: pointer; margin-top: 10px;
            box-shadow: 0 6px 20px rgba(196,125,30,0.4);
            transition: transform 0.2s, box-shadow 0.2s;
            font-family: 'Poppins', sans-serif;
        }
        .btn-submit:hover { transform: translateY(-2px); box-shadow: 0 10px 28px rgba(196,125,30,0.45); }

        .divider { display:flex; align-items:center; gap:12px; margin: 24px 0; }
        .divider hr { flex:1; border:none; border-top: 1px solid #E8D5B0; }
        .divider span { color: #A87D50; font-size: 13px; }

        .btn-register {
            width: 100%; padding: 15px;
            background: #FBF5EC; border: 1.5px solid #E8D5B0;
            border-radius: 16px; font-size: 15px; font-weight: 600;
            color: #C47D1E; cursor: pointer; text-decoration: none;
            display: block; text-align: center; font-family: 'Poppins', sans-serif;
            transition: background 0.2s;
        }
        .btn-register:hover { background: #F5E8D5; }
    </style>
</head>
<body>
    <div class="hero">
        <div class="hero-logo"><i class="fas fa-wheat-awn"></i></div>
        <h1>NVIDIA Technologie</h1>
        <p>Votre Plateforme d'Investissement Premium</p>
    </div>

    <div class="form-card">
        <div class="form-title">Bienvenue ! 👋</div>
        <div class="form-subtitle">Connectez-vous à votre compte</div>

        <% if (error) { %>
            <div class="error-box"><i class="fas fa-exclamation-circle"></i> <%= error %></div>
        <% } %>

        <form action="/connexion" method="post" id="login-form">
            <div class="form-group">
                <label class="form-label">Numéro de Téléphone</label>
                <div class="input-wrap">
                    <div class="input-icon"><i class="fas fa-phone"></i></div>
                    <select id="indicatif" name="indicatif" required style="max-width:90px;">
                        <option value="">Code</option>
                        <% Object.entries(paysEligibles).forEach(([code, pays]) => { %>
                            <option value="<%= code %>" <%= (form_data.indicatif === code) ? 'selected' : '' %>><%= code %></option>
                        <% }) %>
                    </select>
                    <div class="phone-divider"></div>
                    <input type="tel" id="telephone" name="telephone" placeholder="Numéro de téléphone"
                           value="<%= form_data.telephone %>" required>
                </div>
            </div>

            <div class="form-group">
                <label class="form-label">Mot de passe</label>
                <div class="input-wrap">
                    <div class="input-icon"><i class="fas fa-lock"></i></div>
                    <input type="password" id="mot_de_passe" name="mot_de_passe" placeholder="Votre mot de passe" required>
                </div>
            </div>

            <button type="submit" class="btn-submit"><i class="fas fa-sign-in-alt"></i> Se Connecter</button>
        </form>

        <div class="divider"><hr><span>ou</span><hr></div>

        <a href="/inscription" class="btn-register"><i class="fas fa-user-plus"></i> Créer un compte</a>
    </div>

    <script>
        const indicatifSelect = document.getElementById('indicatif');
        const isoToIndicatifMap = <%- JSON.stringify(isoMap) %>;
        function detectUserCountry() {
            try {
                const locale = navigator.language || navigator.userLanguage;
                const parts = locale.split('-');
                if (parts.length > 1) {
                    const cc = parts[parts.length-1].toUpperCase();
                    if (cc.length === 2 && isoToIndicatifMap.hasOwnProperty(cc)) return cc;
                }
            } catch(e) {}
            return null;
        }
        const det = detectUserCountry();
        const phpInd = '<%= form_data.indicatif %>';
        if (det && !phpInd) {
            const req = isoToIndicatifMap[det];
            if (req) indicatifSelect.value = req;
        }
    </script>
</body>
</html>
