<!DOCTYPE html>
<html lang="fr">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0, maximum-scale=1.0, user-scalable=no">
    <title>Équipe - NVIDIA Technologie</title>
    <link rel="stylesheet" href="https://cdnjs.cloudflare.com/ajax/libs/font-awesome/6.4.0/css/all.min.css">
    <style>
        :root {
            --accent-green: #76b900;
            --dark-bg: #0f0f0f;
            --card-bg: rgba(30,30,30,0.95);
            --text-light: #e0e0e0;
            --text-gray: #a0a0a0;
            --border-color: rgba(255,255,255,0.1);
        }
        * { margin:0; padding:0; box-sizing:border-box; font-family:'Inter','Segoe UI',system-ui,sans-serif; }
        body { background:#0f0f0f; color:#e0e0e0; min-height:100vh; padding-bottom:100px; }
        .container { max-width:430px; margin:0 auto; padding:20px 15px; }
        .header { text-align:center; margin-bottom:24px; padding:20px; background:var(--card-bg); border-radius:16px; border:1px solid var(--border-color); }
        .header h1 { color:var(--accent-green); font-size:1.4rem; font-weight:700; }
        .header p { color:var(--text-gray); font-size:0.85rem; margin-top:4px; }
        .referral-link-box { background:var(--card-bg); border:1px solid var(--accent-green); border-radius:12px; padding:15px; margin-bottom:20px; }
        .referral-link-box label { font-size:0.75rem; color:var(--text-gray); text-transform:uppercase; letter-spacing:1px; }
        .referral-link-box .link { display:flex; gap:8px; margin-top:8px; }
        .referral-link-box input { flex:1; background:#1a1a1a; border:1px solid var(--border-color); border-radius:8px; padding:10px; color:var(--text-light); font-size:0.8rem; }
        .copy-btn { background:var(--accent-green); color:#000; border:none; border-radius:8px; padding:10px 16px; cursor:pointer; font-weight:600; font-size:0.85rem; }
        .stats-grid { display:grid; grid-template-columns:repeat(3,1fr); gap:12px; margin-bottom:20px; }
        .stat-card { background:var(--card-bg); border:1px solid var(--border-color); border-radius:12px; padding:15px; text-align:center; }
        .stat-card .number { color:var(--accent-green); font-size:1.5rem; font-weight:700; }
        .stat-card .label { color:var(--text-gray); font-size:0.7rem; margin-top:4px; text-transform:uppercase; letter-spacing:0.5px; }
        .level-section { margin-bottom:20px; }
        .level-header { background:linear-gradient(135deg,var(--accent-green),#588e00); border-radius:12px 12px 0 0; padding:12px 16px; display:flex; justify-content:space-between; align-items:center; }
        .level-header h3 { color:#000; font-weight:700; font-size:0.9rem; }
        .level-header .badge { background:rgba(0,0,0,0.3); color:#fff; border-radius:20px; padding:4px 12px; font-size:0.8rem; font-weight:600; }
        .level-info { background:var(--card-bg); border:1px solid var(--border-color); border-top:none; border-radius:0 0 12px 12px; padding:16px; }
        .level-info .invest { color:var(--text-gray); font-size:0.85rem; margin-top:8px; }
        .level-info .invest span { color:var(--accent-green); font-weight:600; }
        .filleuls-list { margin-top:12px; }
        .filleul-item { background:#1a1a1a; border-radius:8px; padding:10px 12px; margin-bottom:8px; display:flex; justify-content:space-between; align-items:center; }
        .filleul-item .name { font-weight:600; font-size:0.9rem; }
        .filleul-item .phone { color:var(--text-gray); font-size:0.8rem; }
        .filleul-item .status { font-size:0.75rem; padding:4px 10px; border-radius:20px; font-weight:600; }
        .status-active { background:rgba(118,185,0,0.2); color:var(--accent-green); }
        .status-inactive { background:rgba(255,255,255,0.1); color:var(--text-gray); }
        .vip-card { background:var(--card-bg); border:1px solid var(--accent-green); border-radius:12px; padding:16px; margin-bottom:20px; }
        .vip-title { color:var(--accent-green); font-weight:700; font-size:1rem; margin-bottom:12px; }
        .vip-progress { background:#1a1a1a; border-radius:20px; height:8px; overflow:hidden; margin:10px 0; }
        .vip-bar { background:var(--accent-green); height:100%; border-radius:20px; transition:width 0.5s ease; }
        .vip-text { color:var(--text-gray); font-size:0.8rem; }
        .empty-msg { text-align:center; color:var(--text-gray); font-size:0.85rem; padding:20px; }
    </style>
</head>
<body>
<%- include('partials/menu', { page: 'equipe' }) %>

<div class="container">
    <div class="header">
        <h1><i class="fas fa-robot"></i> Mon Équipe</h1>
        <p>Gérez vos filleuls et suivez vos gains de parrainage</p>
    </div>

    <!-- Lien de parrainage -->
    <div class="referral-link-box">
        <label>Votre lien de parrainage</label>
        <div class="link">
            <input type="text" id="referralInput" value="<%= (typeof process !== 'undefined' ? '' : '') %>https://<%= locals.host || '' %>/inscription?p=<%= user.code_parrainage %>" readonly>
            <button class="copy-btn" onclick="copyLink()"><i class="fas fa-copy"></i></button>
        </div>
    </div>

    <!-- VIP -->
    <% if (vip) { %>
    <div class="vip-card">
        <div class="vip-title"><i class="fas fa-crown"></i> Niveau VIP <%= vip.niveau %></div>
        <div class="vip-progress">
            <div class="vip-bar" style="width:<%= Math.min(100, vip.pourcentage || 0) %>%"></div>
        </div>
        <div class="vip-text">
            Filleuls actifs: <strong style="color:var(--accent-green)"><%= vip.invitations_actuelles || 0 %></strong>
            <% if (vip.niveau < 5) { %> — Encore <strong style="color:var(--accent-green)"><%= vip.invitations_requises || 0 %></strong> pour le prochain niveau<% } else { %> — Niveau maximum atteint! 🎉<% } %>
        </div>
    </div>
    <% } %>

    <!-- Stats globales -->
    <div class="stats-grid">
        <div class="stat-card">
            <div class="number"><%= filleuls_niveau1.length %></div>
            <div class="label">Niveau 1</div>
        </div>
        <div class="stat-card">
            <div class="number"><%= filleuls_niveau2.length %></div>
            <div class="label">Niveau 2</div>
        </div>
        <div class="stat-card">
            <div class="number"><%= filleuls_niveau3.length %></div>
            <div class="label">Niveau 3</div>
        </div>
    </div>

    <!-- Niveau 1 -->
    <div class="level-section">
        <div class="level-header">
            <h3><i class="fas fa-users"></i> Filleuls Niveau 1</h3>
            <span class="badge"><%= filleuls_niveau1.length %></span>
        </div>
        <div class="level-info">
            <div class="invest">Investissement actif: <span><%= invest_niveau1.toLocaleString('fr-FR') %> FCFA</span></div>
            <div class="invest">Commission (20%): <span><%= (invest_niveau1 * 0.20).toLocaleString('fr-FR') %> FCFA</span></div>
            <div class="filleuls-list">
                <% if (filleuls_details && filleuls_details.length > 0) { %>
                    <% filleuls_details.forEach(f => { %>
                    <div class="filleul-item">
                        <div>
                            <div class="name"><%= f.nom %></div>
                            <div class="phone"><%= f.telephone %></div>
                        </div>
                        <span class="status <%= f.has_active ? 'status-active' : 'status-inactive' %>">
                            <%= f.has_active ? 'Actif' : 'Inactif' %>
                        </span>
                    </div>
                    <% }); %>
                <% } else if (filleuls_niveau1.length === 0) { %>
                    <div class="empty-msg">Aucun filleul au niveau 1. Partagez votre lien!</div>
                <% } else { %>
                    <div class="empty-msg"><%= filleuls_niveau1.length %> filleul(s) au niveau 1</div>
                <% } %>
            </div>
        </div>
    </div>

    <!-- Niveau 2 -->
    <div class="level-section">
        <div class="level-header" style="background:linear-gradient(135deg,#3a86ff,#2266cc);">
            <h3><i class="fas fa-user-friends"></i> Filleuls Niveau 2</h3>
            <span class="badge"><%= filleuls_niveau2.length %></span>
        </div>
        <div class="level-info">
            <div class="invest">Investissement actif: <span><%= invest_niveau2.toLocaleString('fr-FR') %> FCFA</span></div>
            <div class="invest">Commission (10%): <span><%= (invest_niveau2 * 0.10).toLocaleString('fr-FR') %> FCFA</span></div>
            <% if (filleuls_niveau2.length === 0) { %>
                <div class="empty-msg">Aucun filleul au niveau 2</div>
            <% } else { %>
                <div class="empty-msg"><%= filleuls_niveau2.length %> filleul(s) au niveau 2</div>
            <% } %>
        </div>
    </div>

    <!-- Niveau 3 -->
    <div class="level-section">
        <div class="level-header" style="background:linear-gradient(135deg,#9b59b6,#6c3483);">
            <h3><i class="fas fa-sitemap"></i> Filleuls Niveau 3</h3>
            <span class="badge"><%= filleuls_niveau3.length %></span>
        </div>
        <div class="level-info">
            <div class="invest">Investissement actif: <span><%= invest_niveau3.toLocaleString('fr-FR') %> FCFA</span></div>
            <div class="invest">Commission (5%): <span><%= (invest_niveau3 * 0.05).toLocaleString('fr-FR') %> FCFA</span></div>
            <% if (filleuls_niveau3.length === 0) { %>
                <div class="empty-msg">Aucun filleul au niveau 3</div>
            <% } else { %>
                <div class="empty-msg"><%= filleuls_niveau3.length %> filleul(s) au niveau 3</div>
            <% } %>
        </div>
    </div>
</div>

<script>
function copyLink() {
    const input = document.getElementById('referralInput');
    input.select();
    document.execCommand('copy');
    alert('Lien copié !');
}
</script>
</body>
</html>
