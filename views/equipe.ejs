<!DOCTYPE html>
<html lang="fr">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0, maximum-scale=1.0, user-scalable=no">
    <title>Équipe - NVIDIA Technologie</title>
    <link href="https://fonts.googleapis.com/css2?family=Poppins:wght@300;400;500;600;700;800&display=swap" rel="stylesheet">
    <link rel="stylesheet" href="https://cdnjs.cloudflare.com/ajax/libs/font-awesome/6.5.0/css/all.min.css">
    <style>
        * { margin:0; padding:0; box-sizing:border-box; font-family:'Poppins','Segoe UI',sans-serif; }
        body { background:#F5EFE6; color:#3D2B1F; min-height:100vh; padding-bottom:90px; }
        .container { max-width:430px; margin:0 auto; }

        /* Header */
        .page-header {
            background: linear-gradient(135deg, #D4921F, #A0631A);
            padding: 50px 20px 28px; text-align:center; color:#fff;
        }
        .page-header h1 { font-size:20px; font-weight:700; margin-bottom:4px; }
        .page-header p { font-size:13px; color:rgba(255,255,255,0.85); }

        .content { padding:16px; }

        /* Referral link box */
        .ref-box {
            background:#fff; border-radius:16px; padding:18px;
            margin-bottom:14px; box-shadow:0 4px 16px rgba(196,125,30,0.10);
            border:1px solid #F0E0C8;
        }
        .ref-label { font-size:11px; font-weight:700; color:#A87D50; text-transform:uppercase; letter-spacing:1px; margin-bottom:8px; }
        .ref-row { display:flex; gap:8px; }
        .ref-input {
            flex:1; background:#FBF5EC; border:1.5px solid #E8D5B0;
            border-radius:10px; padding:10px 12px; color:#3D2B1F;
            font-size:12px; font-family:'Poppins',sans-serif; outline:none;
        }
        .copy-btn {
            background:linear-gradient(135deg,#D4921F,#B07018);
            color:#fff; border:none; border-radius:10px;
            padding:10px 16px; cursor:pointer; font-weight:600; font-size:13px;
            font-family:'Poppins',sans-serif;
        }

        /* Stats grid */
        .stats-row { display:grid; grid-template-columns:repeat(3,1fr); gap:10px; margin-bottom:14px; }
        .stat-card {
            background:#fff; border-radius:14px; padding:14px; text-align:center;
            box-shadow:0 2px 10px rgba(196,125,30,0.08); border:1px solid #F0E0C8;
        }
        .stat-num { font-size:24px; font-weight:800; color:#C47D1E; }
        .stat-lbl { font-size:11px; color:#A87D50; margin-top:3px; font-weight:500; }

        /* VIP card */
        .vip-card {
            background:#fff; border:1px solid #E8D5B0; border-radius:16px;
            padding:16px; margin-bottom:14px;
            box-shadow:0 2px 10px rgba(196,125,30,0.08);
        }
        .vip-title { color:#C47D1E; font-weight:700; font-size:15px; margin-bottom:10px; }
        .vip-prog-bg { background:#F0E0C8; border-radius:20px; height:8px; overflow:hidden; margin:10px 0; }
        .vip-prog-fill { background:linear-gradient(135deg,#D4921F,#B07018); height:100%; border-radius:20px; transition:width 0.6s ease; }
        .vip-desc { font-size:13px; color:#7D5A38; }
        .vip-desc strong { color:#C47D1E; }

        /* Level section */
        .level-section { margin-bottom:14px; }
        .level-head {
            border-radius:14px 14px 0 0; padding:13px 16px;
            display:flex; justify-content:space-between; align-items:center;
        }
        .level-head.lv1 { background:linear-gradient(135deg,#D4921F,#B07018); }
        .level-head.lv2 { background:linear-gradient(135deg,#3a86ff,#2266cc); }
        .level-head.lv3 { background:linear-gradient(135deg,#9b59b6,#6c3483); }
        .level-head h3 { color:#fff; font-weight:700; font-size:14px; }
        .level-badge { background:rgba(0,0,0,0.25); color:#fff; border-radius:20px; padding:4px 12px; font-size:13px; font-weight:600; }
        .level-body {
            background:#fff; border:1px solid #F0E0C8; border-top:none;
            border-radius:0 0 14px 14px; padding:16px;
        }
        .level-stat { font-size:13px; color:#7D5A38; margin-bottom:6px; }
        .level-stat span { color:#C47D1E; font-weight:700; }

        /* Filleul items */
        .filleul-list { margin-top:12px; }
        .filleul-item {
            background:#FBF5EC; border-radius:10px; padding:10px 13px;
            margin-bottom:8px; display:flex; justify-content:space-between; align-items:center;
            border:1px solid #F0E0C8;
        }
        .fil-name { font-weight:600; font-size:14px; color:#3D2B1F; }
        .fil-phone { font-size:12px; color:#A87D50; margin-top:2px; }
        .fil-status { font-size:12px; padding:4px 11px; border-radius:20px; font-weight:600; }
        .status-active { background:rgba(196,125,30,0.15); color:#C47D1E; }
        .status-inactive { background:#F0E0C8; color:#A87D50; }
        .empty-msg { text-align:center; color:#A87D50; font-size:13px; padding:18px; }
    </style>
</head>
<body>
<%- include('partials/menu', { page: 'equipe' }) %>

<div class="container">
    <div class="page-header">
        <h1><i class="fas fa-users"></i> Mon Équipe</h1>
        <p>Gérez vos filleuls et suivez vos gains de parrainage</p>
    </div>

    <div class="content">
        <!-- Referral link -->
        <div class="ref-box">
            <div class="ref-label">Votre lien de parrainage</div>
            <div class="ref-row">
                <input type="text" class="ref-input" id="referralInput"
                       value="https://<%= locals.host || '' %>/inscription?p=<%= user.code_parrainage %>" readonly>
                <button class="copy-btn" onclick="copyLink()"><i class="fas fa-copy"></i> Copier</button>
            </div>
        </div>

        <!-- VIP -->
        <% if (vip) { %>
        <div class="vip-card">
            <div class="vip-title"><i class="fas fa-crown"></i> Niveau VIP <%= vip.niveau %></div>
            <div class="vip-prog-bg">
                <div class="vip-prog-fill" style="width:<%= Math.min(100, vip.pourcentage || 0) %>%"></div>
            </div>
            <div class="vip-desc">
                Filleuls actifs: <strong><%= vip.invitations_actuelles || 0 %></strong>
                <% if (vip.niveau < 5) { %> — Encore <strong><%= vip.invitations_requises || 0 %></strong> pour le niveau suivant<% } else { %> — Niveau maximum atteint 🎉<% } %>
            </div>
        </div>
        <% } %>

        <!-- Stats -->
        <div class="stats-row">
            <div class="stat-card">
                <div class="stat-num"><%= filleuls_niveau1.length %></div>
                <div class="stat-lbl">Niveau 1</div>
            </div>
            <div class="stat-card">
                <div class="stat-num"><%= filleuls_niveau2.length %></div>
                <div class="stat-lbl">Niveau 2</div>
            </div>
            <div class="stat-card">
                <div class="stat-num"><%= filleuls_niveau3.length %></div>
                <div class="stat-lbl">Niveau 3</div>
            </div>
        </div>

        <!-- Niveau 1 -->
        <div class="level-section">
            <div class="level-head lv1">
                <h3><i class="fas fa-users"></i> Filleuls Niveau 1</h3>
                <span class="level-badge"><%= filleuls_niveau1.length %></span>
            </div>
            <div class="level-body">
                <div class="level-stat">Investissement actif: <span><%= invest_niveau1.toLocaleString('fr-FR') %> FCFA</span></div>
                <div class="level-stat">Commission (20%): <span><%= (invest_niveau1 * 0.20).toLocaleString('fr-FR') %> FCFA</span></div>
                <div class="filleul-list">
                    <% if (filleuls_details && filleuls_details.length > 0) { %>
                        <% filleuls_details.forEach(f => { %>
                        <div class="filleul-item">
                            <div>
                                <div class="fil-name"><%= f.nom %></div>
                                <div class="fil-phone"><%= f.telephone %></div>
                            </div>
                            <span class="fil-status <%= f.has_active ? 'status-active' : 'status-inactive' %>">
                                <%= f.has_active ? 'Actif' : 'Inactif' %>
                            </span>
                        </div>
                        <% }); %>
                    <% } else if (filleuls_niveau1.length === 0) { %>
                        <div class="empty-msg">Aucun filleul au niveau 1. Partagez votre lien !</div>
                    <% } else { %>
                        <div class="empty-msg"><%= filleuls_niveau1.length %> filleul(s) au niveau 1</div>
                    <% } %>
                </div>
            </div>
        </div>

        <!-- Niveau 2 -->
        <div class="level-section">
            <div class="level-head lv2">
                <h3><i class="fas fa-user-friends"></i> Filleuls Niveau 2</h3>
                <span class="level-badge"><%= filleuls_niveau2.length %></span>
            </div>
            <div class="level-body">
                <div class="level-stat">Investissement actif: <span><%= invest_niveau2.toLocaleString('fr-FR') %> FCFA</span></div>
                <div class="level-stat">Commission (10%): <span><%= (invest_niveau2 * 0.10).toLocaleString('fr-FR') %> FCFA</span></div>
                <% if (filleuls_niveau2.length === 0) { %>
                    <div class="empty-msg">Aucun filleul au niveau 2</div>
                <% } else { %>
                    <div class="empty-msg"><%= filleuls_niveau2.length %> filleul(s) au niveau 2</div>
                <% } %>
            </div>
        </div>

        <!-- Niveau 3 -->
        <div class="level-section">
            <div class="level-head lv3">
                <h3><i class="fas fa-sitemap"></i> Filleuls Niveau 3</h3>
                <span class="level-badge"><%= filleuls_niveau3.length %></span>
            </div>
            <div class="level-body">
                <div class="level-stat">Investissement actif: <span><%= invest_niveau3.toLocaleString('fr-FR') %> FCFA</span></div>
                <div class="level-stat">Commission (5%): <span><%= (invest_niveau3 * 0.05).toLocaleString('fr-FR') %> FCFA</span></div>
                <% if (filleuls_niveau3.length === 0) { %>
                    <div class="empty-msg">Aucun filleul au niveau 3</div>
                <% } else { %>
                    <div class="empty-msg"><%= filleuls_niveau3.length %> filleul(s) au niveau 3</div>
                <% } %>
            </div>
        </div>
    </div>
</div>

<script>
function copyLink() {
    const input = document.getElementById('referralInput');
    navigator.clipboard.writeText(input.value)
        .then(() => { alert('Lien copié !'); })
        .catch(() => { input.select(); document.execCommand('copy'); alert('Lien copié !'); });
}
</script>
</body>
</html>
