<!DOCTYPE html>
<html lang="fr">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0, maximum-scale=1.0, user-scalable=no">
    <title>Équipe - Altiora Capital Africa</title>
    <link href="https://fonts.googleapis.com/css2?family=Poppins:wght@300;400;500;600;700;800&display=swap" rel="stylesheet">
    <link rel="stylesheet" href="https://cdnjs.cloudflare.com/ajax/libs/font-awesome/6.5.0/css/all.min.css">
    <style>
        * { margin:0; padding:0; box-sizing:border-box; font-family:'Poppins','Segoe UI',sans-serif; }
        body { background:#F5EFE6; color:#3D2B1F; min-height:100vh; padding-bottom:90px; }
        .container { max-width:430px; margin:0 auto; }

        /* Header */
        .page-header {
            background: linear-gradient(135deg, #D4921F, #A0631A);
            padding: 50px 20px 28px; text-align:center; color:#fff;
        }
        .page-header h1 { font-size:20px; font-weight:700; margin-bottom:4px; }
        .page-header p { font-size:13px; color:rgba(255,255,255,0.85); }

        .content { padding:16px; }

        /* Referral link box */
        .ref-box {
            background:#fff; border-radius:16px; padding:18px;
            margin-bottom:14px; box-shadow:0 4px 16px rgba(196,125,30,0.10);
            border:1px solid #F0E0C8;
        }
        .ref-label { font-size:11px; font-weight:700; color:#A87D50; text-transform:uppercase; letter-spacing:1px; margin-bottom:8px; }
        .ref-row { display:flex; gap:8px; }
        .ref-input {
            flex:1; background:#FBF5EC; border:1.5px solid #E8D5B0;
            border-radius:10px; padding:10px 12px; color:#3D2B1F;
            font-size:12px; font-family:'Poppins',sans-serif; outline:none;
        }
        .copy-btn {
            background:linear-gradient(135deg,#D4921F,#B07018);
            color:#fff; border:none; border-radius:10px;
            padding:10px 16px; cursor:pointer; font-weight:600; font-size:13px;
            font-family:'Poppins',sans-serif;
        }

        /* Share buttons */
        .share-row {
            display:flex; justify-content:center; gap:14px; margin-top:12px;
        }
        .share-btn {
            display:flex; flex-direction:column; align-items:center; gap:4px;
            background:none; border:none; cursor:pointer; font-size:11px;
            color:#7D5A38; font-family:'Poppins',sans-serif;
        }
        .share-icon {
            width:42px; height:42px; border-radius:50%;
            display:flex; align-items:center; justify-content:center;
            font-size:18px; color:#fff;
        }
        .share-wa { background:#25D366; }
        .share-fb { background:#1877F2; }
        .share-tg { background:#2AABEE; }
        .share-tw { background:#1DA1F2; }

        /* Stats row */
        .stats-row {
            background:#fff; border-radius:16px; padding:16px;
            margin-bottom:14px; box-shadow:0 2px 10px rgba(196,125,30,0.08);
            border:1px solid #F0E0C8;
            display:grid; grid-template-columns:1fr 1px 1fr;
            gap:0;
        }
        .stat-item { text-align:center; padding:4px 0; }
        .stat-divider { background:#F0E0C8; }
        .stat-num { font-size:28px; font-weight:800; color:#C47D1E; line-height:1.1; }
        .stat-lbl { font-size:11px; color:#A87D50; margin-top:2px; }

        /* Commission table */
        .comm-table {
            background:#fff; border-radius:16px; overflow:hidden;
            margin-bottom:14px; box-shadow:0 2px 10px rgba(196,125,30,0.08);
            border:1px solid #F0E0C8;
        }
        .comm-header {
            background:linear-gradient(135deg,#D4921F,#B07018);
            display:grid; grid-template-columns:60px 1fr 1fr 1fr;
            padding:10px 14px;
        }
        .comm-header span { color:#fff; font-weight:700; font-size:13px; text-align:center; }
        .comm-header span:first-child { text-align:left; }
        .comm-row {
            display:grid; grid-template-columns:60px 1fr 1fr 1fr;
            padding:10px 14px; border-top:1px solid #F0E0C8;
        }
        .comm-row span { font-size:13px; text-align:center; color:#7D5A38; }
        .comm-row span:first-child { text-align:left; color:#3D2B1F; font-weight:500; }
        .comm-row .pct { color:#C47D1E; font-weight:700; }

        /* VIP card */
        .vip-card {
            background:#fff; border:1px solid #E8D5B0; border-radius:16px;
            padding:16px; margin-bottom:14px;
            box-shadow:0 2px 10px rgba(196,125,30,0.08);
        }
        .vip-title { color:#C47D1E; font-weight:700; font-size:15px; margin-bottom:10px; }
        .vip-prog-bg { background:#F0E0C8; border-radius:20px; height:8px; overflow:hidden; margin:10px 0; }
        .vip-prog-fill { background:linear-gradient(135deg,#D4921F,#B07018); height:100%; border-radius:20px; transition:width 0.6s ease; }
        .vip-desc { font-size:13px; color:#7D5A38; }
        .vip-desc strong { color:#C47D1E; }

        /* Accordion levels */
        .accordion { margin-bottom:10px; border-radius:16px; overflow:hidden; box-shadow:0 2px 10px rgba(196,125,30,0.08); }
        .acc-head {
            background:#fff; border:1px solid #F0E0C8;
            display:flex; align-items:center; gap:12px;
            padding:14px 16px; cursor:pointer; user-select:none;
            transition:background 0.2s;
        }
        .acc-head:active { background:#FBF5EC; }
        .acc-icon-wrap {
            width:42px; height:42px; border-radius:12px;
            background:linear-gradient(135deg,#D4921F,#B07018);
            display:flex; align-items:center; justify-content:center;
            flex-shrink:0;
        }
        .acc-icon-wrap i { color:#fff; font-size:18px; }
        .acc-info { flex:1; }
        .acc-title { font-size:15px; font-weight:700; color:#3D2B1F; }
        .acc-sub { font-size:12px; color:#A87D50; margin-top:2px; }
        .acc-chevron {
            width:32px; height:32px; border-radius:50%;
            background:#FBF5EC; border:1px solid #E8D5B0;
            display:flex; align-items:center; justify-content:center;
            flex-shrink:0; transition:transform 0.3s ease;
        }
        .acc-chevron i { color:#C47D1E; font-size:14px; }
        .accordion.open .acc-chevron { transform:rotate(180deg); }

        /* Accordion body */
        .acc-body {
            overflow:hidden;
            transition:height 0.35s ease;
            background:#fff; border:1px solid #F0E0C8; border-top:none;
            border-radius:0 0 16px 16px;
            height:0;
        }
        .acc-body-inner { padding:14px 16px; }

        /* Filleul list */
        .filleul-item {
            background:#FBF5EC; border-radius:12px; padding:11px 13px;
            margin-bottom:8px; display:flex; justify-content:space-between; align-items:center;
            border:1px solid #F0E0C8;
        }
        .filleul-item:last-child { margin-bottom:0; }
        .fil-avatar {
            width:36px; height:36px; border-radius:50%;
            background:linear-gradient(135deg,#D4921F,#B07018);
            display:flex; align-items:center; justify-content:center;
            color:#fff; font-weight:700; font-size:14px;
            flex-shrink:0; margin-right:10px;
        }
        .fil-info { flex:1; }
        .fil-name { font-weight:600; font-size:13px; color:#3D2B1F; }
        .fil-phone { font-size:11px; color:#A87D50; margin-top:1px; }
        .fil-status { font-size:11px; padding:4px 10px; border-radius:20px; font-weight:600; flex-shrink:0; }
        .status-active { background:rgba(196,125,30,0.15); color:#C47D1E; }
        .status-inactive { background:#F0E0C8; color:#A87D50; }
        .empty-msg { text-align:center; color:#A87D50; font-size:13px; padding:20px; }

        /* Pagination */
        .pagination {
            display:flex; align-items:center; justify-content:center;
            gap:10px; margin-top:12px; padding-top:10px;
            border-top:1px solid #F0E0C8;
        }
        .pag-btn {
            background:linear-gradient(135deg,#D4921F,#B07018);
            color:#fff; border:none; border-radius:10px;
            padding:7px 16px; font-size:13px; font-weight:600;
            font-family:'Poppins',sans-serif; cursor:pointer;
            transition:opacity 0.2s;
        }
        .pag-btn:disabled { opacity:0.35; cursor:default; }
        .pag-info { font-size:13px; color:#7D5A38; font-weight:500; }
    </style>
</head>
<body>
<%- include('partials/menu', { page: 'equipe' }) %>

<div class="container">
    <div class="page-header">
        <h1><i class="fas fa-users"></i> Mon Équipe</h1>
        <p>Gérez vos filleuls et suivez vos gains de parrainage</p>
    </div>

    <div class="content">

        <!-- Referral link -->
        <div class="ref-box">
            <div class="ref-label">Votre lien de parrainage</div>
            <div class="ref-row">
                <input type="text" class="ref-input" id="referralInput"
                       value="<%= baseUrl %>/inscription1?p=<%= user.code_parrainage %>" readonly>
                <button class="copy-btn" onclick="copyLink()"><i class="fas fa-copy"></i> Copier</button>
            </div>
            <!-- Share buttons -->
            <div class="share-row">
                <button class="share-btn" onclick="shareWA()">
                    <div class="share-icon share-wa"><i class="fab fa-whatsapp"></i></div>
                    <span>WhatsApp</span>
                </button>
                <button class="share-btn" onclick="shareFB()">
                    <div class="share-icon share-fb"><i class="fab fa-facebook-f"></i></div>
                    <span>Facebook</span>
                </button>
                <button class="share-btn" onclick="shareTG()">
                    <div class="share-icon share-tg"><i class="fab fa-telegram-plane"></i></div>
                    <span>Telegram</span>
                </button>
                <button class="share-btn" onclick="shareTW()">
                    <div class="share-icon share-tw"><i class="fab fa-twitter"></i></div>
                    <span>Twitter</span>
                </button>
            </div>
        </div>

        <!-- Stats -->
        <div class="stats-row">
            <div class="stat-item">
                <div class="stat-num"><%= filleuls_niveau1.length + filleuls_niveau2.length + filleuls_niveau3.length %></div>
                <div class="stat-lbl">Nombre de personnes</div>
            </div>
            <div class="stat-divider"></div>
            <div class="stat-item">
                <div class="stat-num"><%= Math.round((invest_niveau1 * 0.20) + (invest_niveau2 * 0.10) + (invest_niveau3 * 0.05)).toLocaleString('fr-FR') %></div>
                <div class="stat-lbl">Total commission</div>
            </div>
        </div>

        <!-- Commission table -->
        <div class="comm-table">
            <div class="comm-header">
                <span>Nv</span>
                <span>Niveau 1</span>
                <span>Niveau 2</span>
                <span>Niveau 3</span>
            </div>
            <div class="comm-row">
                <span>1,2,3</span>
                <span class="pct">20%</span>
                <span class="pct">10%</span>
                <span class="pct">5%</span>
            </div>
        </div>

        <!-- VIP -->
        <% if (vip) { %>
        <div class="vip-card">
            <div class="vip-title"><i class="fas fa-crown"></i> Niveau VIP <%= vip.niveau %></div>
            <div class="vip-prog-bg">
                <div class="vip-prog-fill" style="width:<%= Math.min(100, vip.pourcentage || 0) %>%"></div>
            </div>
            <div class="vip-desc">
                Filleuls actifs: <strong><%= vip.invitations_actuelles || 0 %></strong>
                <% if (vip.niveau < 5) { %> — Encore <strong><%= vip.invitations_requises || 0 %></strong> pour le niveau suivant<% } else { %> — Niveau maximum atteint 🎉<% } %>
            </div>
        </div>
        <% } %>

        <!-- Accordion Niveau 1 -->
        <div class="accordion" id="acc1">
            <div class="acc-head" onclick="toggleAcc('acc1')">
                <div class="acc-icon-wrap"><i class="fas fa-users"></i></div>
                <div class="acc-info">
                    <div class="acc-title">Équipe niveau 1</div>
                    <div class="acc-sub"><%= filleuls_niveau1.length %> membre(s) • 20%</div>
                </div>
                <div class="acc-chevron"><i class="fas fa-chevron-down"></i></div>
            </div>
            <div class="acc-body">
                <div class="acc-body-inner">
                    <div id="list1"></div>
                    <div class="pagination" id="pag1" style="display:none;">
                        <button class="pag-btn" id="prev1" onclick="changePage(1,-1)"><i class="fas fa-chevron-left"></i> Préc.</button>
                        <span class="pag-info" id="info1"></span>
                        <button class="pag-btn" id="next1" onclick="changePage(1,1)">Suiv. <i class="fas fa-chevron-right"></i></button>
                    </div>
                </div>
            </div>
        </div>

        <!-- Accordion Niveau 2 -->
        <div class="accordion" id="acc2">
            <div class="acc-head" onclick="toggleAcc('acc2')">
                <div class="acc-icon-wrap"><i class="fas fa-user-friends"></i></div>
                <div class="acc-info">
                    <div class="acc-title">Équipe niveau 2</div>
                    <div class="acc-sub"><%= filleuls_niveau2.length %> membre(s) • 10%</div>
                </div>
                <div class="acc-chevron"><i class="fas fa-chevron-down"></i></div>
            </div>
            <div class="acc-body">
                <div class="acc-body-inner">
                    <div id="list2"></div>
                    <div class="pagination" id="pag2" style="display:none;">
                        <button class="pag-btn" id="prev2" onclick="changePage(2,-1)"><i class="fas fa-chevron-left"></i> Préc.</button>
                        <span class="pag-info" id="info2"></span>
                        <button class="pag-btn" id="next2" onclick="changePage(2,1)">Suiv. <i class="fas fa-chevron-right"></i></button>
                    </div>
                </div>
            </div>
        </div>

        <!-- Accordion Niveau 3 -->
        <div class="accordion" id="acc3">
            <div class="acc-head" onclick="toggleAcc('acc3')">
                <div class="acc-icon-wrap"><i class="fas fa-sitemap"></i></div>
                <div class="acc-info">
                    <div class="acc-title">Équipe niveau 3</div>
                    <div class="acc-sub"><%= filleuls_niveau3.length %> membre(s) • 5%</div>
                </div>
                <div class="acc-chevron"><i class="fas fa-chevron-down"></i></div>
            </div>
            <div class="acc-body">
                <div class="acc-body-inner">
                    <div id="list3"></div>
                    <div class="pagination" id="pag3" style="display:none;">
                        <button class="pag-btn" id="prev3" onclick="changePage(3,-1)"><i class="fas fa-chevron-left"></i> Préc.</button>
                        <span class="pag-info" id="info3"></span>
                        <button class="pag-btn" id="next3" onclick="changePage(3,1)">Suiv. <i class="fas fa-chevron-right"></i></button>
                    </div>
                </div>
            </div>
        </div>

    </div><!-- /content -->
</div><!-- /container -->

<script>
// ── Data from server ──────────────────────────────────────────────
const DATA = {
  1: <%- JSON.stringify(filleuls_details1 || []) %>,
  2: <%- JSON.stringify(filleuls_details2 || []) %>,
  3: <%- JSON.stringify(filleuls_details3 || []) %>
};
const EMPTY_ICONS = {
  1: 'fa-user-plus',
  2: 'fa-user-friends',
  3: 'fa-sitemap'
};
const EMPTY_MSGS = {
  1: 'Aucun filleul au niveau 1.<br>Partagez votre lien !',
  2: 'Aucun filleul au niveau 2',
  3: 'Aucun filleul au niveau 3'
};

const PAGE_SIZE = 20;
const pages = { 1: 0, 2: 0, 3: 0 };

// ── Render a page for a level ─────────────────────────────────────
function renderPage(level) {
  const data = DATA[level];
  const listEl  = document.getElementById('list' + level);
  const pagEl   = document.getElementById('pag'  + level);
  const infoEl  = document.getElementById('info' + level);
  const prevBtn  = document.getElementById('prev' + level);
  const nextBtn  = document.getElementById('next' + level);
  const page    = pages[level];
  const total   = data.length;
  const totalPages = Math.ceil(total / PAGE_SIZE);

  if (total === 0) {
    listEl.innerHTML = `<div class="empty-msg">
      <i class="fas ${EMPTY_ICONS[level]}" style="font-size:24px;margin-bottom:8px;display:block;opacity:0.4;"></i>
      ${EMPTY_MSGS[level]}</div>`;
    pagEl.style.display = 'none';
    return;
  }

  const start = page * PAGE_SIZE;
  const slice = data.slice(start, start + PAGE_SIZE);

  listEl.innerHTML = slice.map(f => {
    const initial = (f.nom || '?').charAt(0).toUpperCase();
    const active  = f.has_active ? true : false;
    return `<div class="filleul-item">
      <div class="fil-avatar">${initial}</div>
      <div class="fil-info">
        <div class="fil-name">${escHtml(f.nom || '')}</div>
        <div class="fil-phone">${escHtml(f.telephone || '')}</div>
      </div>
      <span class="fil-status ${active ? 'status-active' : 'status-inactive'}">
        ${active ? 'Actif' : 'Inactif'}
      </span>
    </div>`;
  }).join('');

  // Pagination bar
  if (totalPages > 1) {
    pagEl.style.display = 'flex';
    infoEl.textContent  = `Page ${page + 1} / ${totalPages}`;
    prevBtn.disabled    = (page === 0);
    nextBtn.disabled    = (page >= totalPages - 1);
  } else {
    pagEl.style.display = 'none';
  }

  // Recalculate accordion height after content change
  const acc  = document.getElementById('acc' + level);
  const body = acc.querySelector('.acc-body');
  if (acc.classList.contains('open') && body.style.height !== 'auto') {
    body.style.height = body.scrollHeight + 'px';
  } else if (acc.classList.contains('open')) {
    // already auto — force reflow to new content height
    body.style.height = 'auto';
  }
}

function changePage(level, delta) {
  const total      = DATA[level].length;
  const totalPages = Math.ceil(total / PAGE_SIZE);
  pages[level]     = Math.max(0, Math.min(totalPages - 1, pages[level] + delta));
  renderPage(level);
}

// ── Accordion toggle ──────────────────────────────────────────────
function toggleAcc(id) {
  const el   = document.getElementById(id);
  const body = el.querySelector('.acc-body');
  if (el.classList.contains('open')) {
    body.style.height = body.scrollHeight + 'px';
    requestAnimationFrame(() => { body.style.height = '0'; });
    el.classList.remove('open');
  } else {
    el.classList.add('open');
    body.style.height = body.scrollHeight + 'px';
    body.addEventListener('transitionend', function handler() {
      body.style.height = 'auto';
      body.removeEventListener('transitionend', handler);
    });
  }
}

// ── Utilities ─────────────────────────────────────────────────────
function escHtml(s) {
  return s.replace(/&/g,'&amp;').replace(/</g,'&lt;').replace(/>/g,'&gt;').replace(/"/g,'&quot;');
}

function copyLink() {
  const input = document.getElementById('referralInput');
  navigator.clipboard.writeText(input.value)
    .then(() => showToast('Lien copié !'))
    .catch(() => { input.select(); document.execCommand('copy'); showToast('Lien copié !'); });
}
function getLink() { return document.getElementById('referralInput').value; }
function shareWA() { window.open('https://wa.me/?text=' + encodeURIComponent('Rejoins-moi sur Altiora Capital Africa ! ' + getLink()), '_blank'); }
function shareFB() { window.open('https://www.facebook.com/sharer/sharer.php?u=' + encodeURIComponent(getLink()), '_blank'); }
function shareTG() { window.open('https://t.me/share/url?url=' + encodeURIComponent(getLink()) + '&text=' + encodeURIComponent('Rejoins-moi sur Altiora Capital Africa !'), '_blank'); }
function shareTW() { window.open('https://twitter.com/intent/tweet?text=' + encodeURIComponent('Rejoins-moi sur Altiora Capital Africa ! ' + getLink()), '_blank'); }

function showToast(msg) {
  const t = document.createElement('div');
  t.textContent = msg;
  Object.assign(t.style, {
    position:'fixed', bottom:'100px', left:'50%', transform:'translateX(-50%)',
    background:'#3D2B1F', color:'#fff', padding:'10px 22px', borderRadius:'30px',
    fontSize:'14px', fontWeight:'600', zIndex:'9999', opacity:'0', transition:'opacity 0.3s'
  });
  document.body.appendChild(t);
  requestAnimationFrame(() => { t.style.opacity = '1'; });
  setTimeout(() => { t.style.opacity = '0'; setTimeout(() => t.remove(), 300); }, 2000);
}

// ── Init ──────────────────────────────────────────────────────────
renderPage(1);
renderPage(2);
renderPage(3);
</script>
</body>
</html>
