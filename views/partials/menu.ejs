<link rel="stylesheet" href="https://cdnjs.cloudflare.com/ajax/libs/font-awesome/6.5.0/css/all.min.css">
<style>
    :root {
        --amber: #C47D1E;
        --amber-dark: #A0631A;
        --nav-bg: #FFFFFF;
        --nav-inactive: #A87D50;
        --nav-active: #C47D1E;
        --nav-border: #E8D5B0;
    }
    .bottom-nav {
        position: fixed;
        bottom: 0;
        left: 0;
        width: 100%;
        background: var(--nav-bg);
        border-top: 1px solid var(--nav-border);
        display: flex;
        justify-content: space-around;
        align-items: center;
        padding: 8px 0 12px;
        z-index: 9999;
        box-shadow: 0 -4px 20px rgba(196,125,30,0.10);
    }
    .nav-item {
        flex: 1;
        display: flex;
        flex-direction: column;
        align-items: center;
        color: var(--nav-inactive);
        text-decoration: none;
        font-size: 10px;
        padding: 4px 0;
        font-family: 'Inter', 'Segoe UI', sans-serif;
        font-weight: 500;
        transition: color 0.2s;
        gap: 3px;
    }
    .nav-item i { font-size: 20px; }
    .nav-item span { font-size: 10px; letter-spacing: 0.2px; }
    .nav-item.active { color: var(--nav-active); font-weight: 700; }
    .nav-center {
        flex: 1;
        display: flex;
        flex-direction: column;
        align-items: center;
        text-decoration: none;
        gap: 3px;
        margin-top: -22px;
    }
    .nav-center-btn {
        width: 54px;
        height: 54px;
        border-radius: 50%;
        background: linear-gradient(135deg, #D4921F, #B07018);
        display: flex;
        align-items: center;
        justify-content: center;
        box-shadow: 0 4px 16px rgba(196,125,30,0.45);
        border: 3px solid #fff;
    }
    .nav-center-btn i { font-size: 22px; color: #fff; }
    .nav-center span { font-size: 10px; color: var(--nav-inactive); font-weight: 500; font-family: 'Inter', 'Segoe UI', sans-serif; }
    .nav-center.active .nav-center-btn { background: linear-gradient(135deg, #C47D1E, #8B5E0F); }
    .nav-center.active span { color: var(--nav-active); font-weight: 700; }
    body { padding-bottom: 80px !important; }
</style>

<nav class="bottom-nav">
    <a href="/" class="nav-item <%= locals.page === 'index' ? 'active' : '' %>">
        <i class="fas fa-home"></i><span>Accueil</span>
    </a>
    <a href="/investissement" class="nav-item <%= locals.page === 'investissement' ? 'active' : '' %>">
        <i class="fas fa-chart-bar"></i><span>Investir</span>
    </a>
    <a href="/salaire" class="nav-center <%= locals.page === 'salaire' ? 'active' : '' %>">
        <div class="nav-center-btn"><i class="fas fa-coins"></i></div>
        <span>Salaire</span>
    </a>
    <a href="/equipe" class="nav-item <%= locals.page === 'equipe' ? 'active' : '' %>">
        <i class="fas fa-users"></i><span>Équipe</span>
    </a>
    <a href="/compte" class="nav-item <%= locals.page === 'compte' ? 'active' : '' %>">
        <i class="fas fa-user"></i><span>Profil</span>
    </a>
</nav>

<% if (locals.appParams && appParams.whatsapp_link) { %>
<a href="<%= appParams.whatsapp_link %>" target="_blank" rel="noopener"
   style="position:fixed;bottom:100px;right:16px;width:52px;height:52px;border-radius:50%;
          background:#25D366;color:#fff;display:flex;align-items:center;justify-content:center;
          box-shadow:0 6px 20px rgba(37,211,102,0.5);z-index:9998;text-decoration:none;
          transition:transform 0.2s;" onmouseover="this.style.transform='scale(1.1)'" onmouseout="this.style.transform='scale(1)'">
  <i class="fab fa-whatsapp" style="font-size:26px;"></i>
</a>
<% } %>
