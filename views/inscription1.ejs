<!DOCTYPE html>
<html lang="fr">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0, maximum-scale=1.0, user-scalable=no">
    <title>Inscription - Altiora Capital Africa</title>
    <link href="https://fonts.googleapis.com/css2?family=Poppins:wght@300;400;500;600;700;800&display=swap" rel="stylesheet">
    <link rel="stylesheet" href="https://cdnjs.cloudflare.com/ajax/libs/font-awesome/6.5.0/css/all.min.css">
    <style>
        * { margin:0; padding:0; box-sizing:border-box; -webkit-tap-highlight-color:transparent; }
        html {
            scroll-behavior: smooth;
            -webkit-text-size-adjust: 100%;
        }
        html, body { min-height:100vh; overflow-x:hidden; font-family:'Poppins',sans-serif; }
        body {
            background:#F5EFE6;
            display:flex;
            flex-direction:column;
            overflow-y: auto;
            -webkit-overflow-scrolling: touch;
        }
        .hero {
            height: 230px;
            background: linear-gradient(to bottom, rgba(10,5,0,0.30), rgba(10,5,0,0.55)),
                        url('/images/slide1.jpeg') center/cover no-repeat;
            display: flex; flex-direction:column; align-items:center; justify-content:center;
        }
        .hero-logo {
            width:80px; height:80px; border-radius:50%;
            overflow:hidden;
            box-shadow: 0 0 0 3px rgba(212,146,31,0.6), 0 8px 24px rgba(0,0,0,0.5);
            margin-bottom:10px;
        }
        .hero-logo img { width:100%; height:100%; object-fit:cover; }
        .hero h1 { font-size:24px; font-weight:800; color:#fff; text-shadow:0 2px 8px rgba(0,0,0,0.6); }
        .hero p { font-size:12px; color:rgba(255,255,255,0.9); margin-top:3px; }
        .form-card {
            background:#fff; border-radius:28px 28px 0 0; margin-top:-28px;
            flex-shrink:0; padding:28px 24px calc(40px + env(safe-area-inset-bottom, 0px));
            box-shadow: 0 -8px 32px rgba(196,125,30,0.10);
        }
        .bonus-notice {
            background: linear-gradient(135deg, rgba(212,146,31,0.12), rgba(176,112,24,0.08));
            border: 1px solid rgba(196,125,30,0.25);
            border-radius:12px; padding:12px 16px; margin-bottom:20px;
            display:flex; align-items:center; gap:10px;
            color:#7D5A38; font-size:13px; font-weight:600;
        }
        .bonus-notice i { color:#C47D1E; font-size:18px; }
        .referral-notice {
            background: #FBF5EC; border:1px solid #E8D5B0; border-radius:12px;
            padding:11px 14px; margin-bottom:16px; display:flex; align-items:center;
            gap:9px; color:#7D5A38; font-size:13px;
        }
        .referral-notice i { color:#C47D1E; }
        .form-title { font-size:20px; font-weight:700; color:#3D2B1F; margin-bottom:20px; }
        .form-group { margin-bottom:16px; }
        .form-label { display:block; font-size:13px; font-weight:600; color:#7D5A38; margin-bottom:7px; }
        .input-wrap {
            display:flex; align-items:center;
            background:#FBF5EC; border:1.5px solid #E8D5B0; border-radius:14px;
            overflow:hidden; transition:border-color 0.2s, box-shadow 0.2s;
            position:relative;
        }
        .input-wrap input[type="password"],
        .input-wrap input[type="text"] { padding-right:48px !important; }
        .input-wrap:focus-within { border-color:#C47D1E; box-shadow:0 0 0 3px rgba(196,125,30,0.15); }
        .input-icon {
            width:46px; height:50px;
            background:linear-gradient(135deg,#D4921F,#B07018);
            display:flex; align-items:center; justify-content:center;
            flex-shrink:0; border-radius:11px; margin:4px;
        }
        .input-icon i { color:#fff; font-size:15px; }
        .input-wrap input, .input-wrap select {
            flex:1; border:none; background:transparent;
            padding:13px 13px 13px 10px; font-size:14px; color:#3D2B1F;
            font-family:'Poppins',sans-serif; outline:none;
        }
        .input-wrap select { cursor:pointer; -webkit-appearance:none; max-width:95px; }
        .phone-divider { width:1px; height:22px; background:#E8D5B0; flex-shrink:0; }
        .input-wrap.locked { background:#F3ECDE; border-color:#D9C49A; }
        .input-wrap.locked input {
            color:#7D5A38; font-weight:600; cursor:not-allowed;
        }
        .lock-icon {
            width:40px; display:flex; align-items:center; justify-content:center;
            color:#A87D50; font-size:14px; flex-shrink:0;
        }
        .eye-toggle {
            position:absolute; right:0; top:0; bottom:0;
            background:none; border:none; cursor:pointer;
            color:#A87D50; font-size:16px;
            display:flex; align-items:center; justify-content:center;
            width:44px; z-index:2;
        }
        .error-box {
            background:#FFF0EE; border:1px solid #F5A9A0; border-radius:12px;
            padding:12px 16px; margin-bottom:18px; color:#C0392B;
            font-size:13px; display:flex; align-items:center; gap:10px;
        }
        .btn-submit {
            width:100%; padding:16px;
            background:linear-gradient(135deg,#D4921F,#B07018);
            border:none; border-radius:16px;
            font-size:16px; font-weight:700; color:#fff;
            cursor:pointer; margin-top:8px;
            box-shadow:0 6px 20px rgba(196,125,30,0.4);
            transition:transform 0.2s; font-family:'Poppins',sans-serif;
        }
        .btn-submit:hover { transform:translateY(-2px); }
        .login-link { text-align:center; margin-top:20px; font-size:13px; color:#A87D50; }
        .login-link a { color:#C47D1E; font-weight:600; text-decoration:none; }
    </style>
</head>
<body>
    <div class="hero">
        <div class="hero-logo"><img src="/images/logo-altiora.jpeg" alt="Altiora Capital Africa"></div>
        <h1>Altiora Capital Africa</h1>
        <p>« Ensemble, construisons la richesse de demain. »</p>
    </div>

    <div class="form-card">
        <% if (typeof error !== 'undefined' && error) { %>
            <div class="error-box"><i class="fas fa-exclamation-circle"></i> <%= error %></div>
        <% } %>

        <% if (typeof code_parrain !== 'undefined' && code_parrain) { %>
            <div class="referral-notice"><i class="fas fa-user-friends"></i> Vous êtes invité par un ambassadeur Altiora Capital Africa</div>
        <% } %>

        <div class="bonus-notice"><i class="fas fa-gift"></i> Bonus de bienvenue : <%= (locals.appParams && appParams.welcome_bonus !== undefined && appParams.welcome_bonus !== null && appParams.welcome_bonus !== '') ? appParams.welcome_bonus : 250 %> FCFA offerts !</div>

        <div class="form-title">Rejoignez Altiora</div>

        <form action="/inscription1" method="post" id="signup-form">
            <% if (typeof code_parrain !== 'undefined' && code_parrain) { %>
            <div class="form-group">
                <label class="form-label">Code d'invitation</label>
                <div class="input-wrap locked">
                    <div class="input-icon"><i class="fas fa-ticket-alt"></i></div>
                    <input type="text" value="<%= code_parrain %>" readonly tabindex="-1">
                    <div class="lock-icon"><i class="fas fa-lock"></i></div>
                </div>
            </div>
            <% } %>

            <div class="form-group">
                <label class="form-label">Nom complet</label>
                <div class="input-wrap">
                    <div class="input-icon"><i class="fas fa-user"></i></div>
                    <input type="text" name="nom" placeholder="Votre nom complet" required
                           value="<%= typeof form_data !== 'undefined' ? form_data.nom : '' %>">
                </div>
            </div>

            <div class="form-group">
                <label class="form-label">Numéro WhatsApp</label>
                <div class="input-wrap">
                    <div class="input-icon"><i class="fas fa-phone"></i></div>
                    <select id="indicatif" name="indicatif" required>
                        <option value="">Code</option>
                        <% Object.entries(pays_eligibles).forEach(([code, pays]) => { %>
                            <option value="<%= code %>"
                                <%= (typeof form_data !== 'undefined' && form_data && form_data.indicatif === code) || (typeof form_data === 'undefined' && code === '+225') ? 'selected' : '' %>>
                                <%= code %>
                            </option>
                        <% }) %>
                    </select>
                    <div class="phone-divider"></div>
                    <input type="text" id="telephone" name="telephone" placeholder="Numéro de téléphone" required pattern="[0-9 ]{6,}"
                           value="<%= typeof form_data !== 'undefined' ? form_data.telephone : '' %>">
                    <input type="hidden" name="pays" id="pays" value="">
                </div>
            </div>

            <div class="form-group">
                <label class="form-label">Mot de passe</label>
                <div class="input-wrap">
                    <div class="input-icon"><i class="fas fa-lock"></i></div>
                    <input type="password" id="mot_de_passe" name="mot_de_passe" placeholder="Choisissez un mot de passe" required>
                    <button type="button" class="eye-toggle" onclick="togglePwd('mot_de_passe',this)"><i class="fas fa-eye"></i></button>
                </div>
            </div>

            <div class="form-group">
                <label class="form-label">Confirmer le mot de passe</label>
                <div class="input-wrap">
                    <div class="input-icon"><i class="fas fa-lock"></i></div>
                    <input type="password" id="confirmation" name="confirmation" placeholder="Confirmez le mot de passe" required>
                    <button type="button" class="eye-toggle" onclick="togglePwd('confirmation',this)"><i class="fas fa-eye"></i></button>
                </div>
            </div>

            <button type="submit" class="btn-submit"><i class="fas fa-user-plus"></i> Créer mon compte</button>
        </form>

        <div class="login-link">Déjà membre ? <a href="/connexion">Se connecter</a></div>
    </div>

    <script>
        const indicatifSelect = document.getElementById('indicatif');
        const paysInput = document.getElementById('pays');
        const paysMap = <%- JSON.stringify(pays_eligibles) %>;
        function updatePays() { paysInput.value = paysMap[indicatifSelect.value] || ''; }
        updatePays();
        indicatifSelect.addEventListener('change', updatePays);
        function togglePwd(id, btn) {
            const inp = document.getElementById(id);
            if (inp.type === 'password') { inp.type = 'text'; btn.innerHTML = '<i class="fas fa-eye-slash"></i>'; }
            else { inp.type = 'password'; btn.innerHTML = '<i class="fas fa-eye"></i>'; }
        }
    </script>
</body>
</html>
