<!DOCTYPE html>
<html lang="fr">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0, maximum-scale=1.0, user-scalable=no">
    <title>Retrait - Altiora Capital Africa</title>
    <link href="https://fonts.googleapis.com/css2?family=Poppins:wght@300;400;500;600;700;800&display=swap" rel="stylesheet">
    <link rel="stylesheet" href="https://cdnjs.cloudflare.com/ajax/libs/font-awesome/6.5.0/css/all.min.css">
    <style>
        * { margin:0; padding:0; box-sizing:border-box; font-family:'Poppins','Segoe UI',sans-serif; }
        body { background:#F5EFE6; color:#3D2B1F; min-height:100vh; padding-bottom:90px; }
        .container { max-width:430px; margin:0 auto; }

        .page-header {
            background: linear-gradient(135deg, #D4921F, #A0631A);
            padding: 50px 20px 28px; display:flex; align-items:center; gap:14px;
        }
        .back-btn {
            width:36px; height:36px; border-radius:50%;
            background:rgba(255,255,255,0.2); display:flex; align-items:center;
            justify-content:center; color:#fff; text-decoration:none; font-size:16px; flex-shrink:0;
        }
        .header-txt h1 { font-size:20px; font-weight:700; color:#fff; }
        .header-txt p { font-size:13px; color:rgba(255,255,255,0.85); margin-top:2px; }

        .content { padding:16px; }

        /* Balance card */
        .balance-hero {
            background: linear-gradient(135deg, #D4921F, #B07018);
            border-radius:18px; padding:22px; text-align:center;
            margin-bottom:16px; box-shadow:0 6px 20px rgba(196,125,30,0.35);
        }
        .balance-hero .lbl { color:rgba(255,255,255,0.8); font-size:12px; font-weight:600;
            text-transform:uppercase; letter-spacing:1px; margin-bottom:8px; }
        .balance-hero .amt { color:#fff; font-size:36px; font-weight:800; line-height:1; }
        .balance-hero .cur { color:rgba(255,255,255,0.8); font-size:14px; margin-top:6px; }

        /* Alerts */
        .notif { padding:12px 15px; border-radius:12px; margin-bottom:14px;
            font-size:14px; display:flex; align-items:center; gap:9px; }
        .notif.error { background:#FFF0EE; border:1px solid #F5A9A0; color:#C0392B; }
        .notif.success { background:#F0FFF4; border:1px solid #86EFAC; color:#166534; }

        .warning-card {
            background:#FFFBF0; border:1px solid #F5D78A; border-radius:12px;
            padding:13px 15px; margin-bottom:14px; font-size:13px; color:#92660A;
            display:flex; align-items:center; gap:9px;
        }
        .warning-card a { color:#C47D1E; font-weight:600; text-decoration:none; }
        .info-card {
            background:rgba(196,125,30,0.08); border:1px solid rgba(196,125,30,0.2);
            border-radius:12px; padding:13px 15px; margin-bottom:14px;
            font-size:13px; color:#7D5A38;
        }
        .info-card strong { color:#C47D1E; }

        /* Wallet info */
        .wallet-card {
            background:#fff; border-radius:16px; border:1px solid #F0E0C8;
            padding:18px; margin-bottom:14px; box-shadow:0 2px 10px rgba(196,125,30,0.08);
        }
        .wallet-card h3 { color:#C47D1E; font-size:14px; font-weight:700; margin-bottom:14px;
            display:flex; align-items:center; gap:8px; }
        .wallet-row { display:flex; justify-content:space-between; padding:8px 0;
            border-bottom:1px solid #F5EFE6; font-size:13px; }
        .wallet-row:last-child { border-bottom:none; }
        .wallet-key { color:#A87D50; }
        .wallet-val { color:#3D2B1F; font-weight:600; }

        /* Form */
        .form-card {
            background:#fff; border-radius:16px; border:1px solid #F0E0C8;
            padding:18px; margin-bottom:14px; box-shadow:0 2px 10px rgba(196,125,30,0.08);
        }
        .form-card h3 { color:#C47D1E; font-size:14px; font-weight:700; margin-bottom:16px;
            display:flex; align-items:center; gap:8px; }
        .form-group { margin-bottom:14px; }
        .form-label { display:block; font-size:12px; font-weight:600; color:#A87D50; margin-bottom:6px; }
        .form-input {
            width:100%; background:#FBF5EC; border:1.5px solid #E8D5B0;
            border-radius:11px; padding:12px 14px; color:#3D2B1F;
            font-size:14px; font-family:'Poppins',sans-serif; outline:none;
            transition:border-color 0.2s;
        }
        .form-input:focus { border-color:#C47D1E; }
        .btn-submit {
            width:100%; background:linear-gradient(135deg,#D4921F,#B07018);
            color:#fff; border:none; border-radius:12px; padding:15px;
            font-weight:700; font-size:15px; cursor:pointer; font-family:'Poppins',sans-serif;
            box-shadow:0 4px 14px rgba(196,125,30,0.35); transition:transform 0.2s;
        }
        .btn-submit:hover { transform:translateY(-2px); }
    </style>
</head>
<body>
<%- include('partials/menu', { page: 'compte' }) %>
<div class="container">
    <div class="page-header">
        <a href="/" class="back-btn"><i class="fas fa-chevron-left"></i></a>
        <div class="header-txt">
            <h1>Retrait</h1>
            <p>Retirez votre argent en toute sécurité</p>
        </div>
    </div>

    <div class="content">
        <div class="balance-hero">
            <div class="lbl">Solde disponible</div>
            <div class="amt"><%= parseFloat(solde).toLocaleString('fr-FR') %></div>
            <div class="cur">FCFA</div>
        </div>

        <% if (message) { %><%- message %><% } %>

        <% if (!has_wallet) { %>
        <div class="warning-card">
            <i class="fas fa-exclamation-triangle"></i>
            <span>Portefeuille non configuré. <a href="/portefeuille">Configurer maintenant</a></span>
        </div>
        <% } %>
        <% if (!has_transaction_password) { %>
        <div class="warning-card">
            <i class="fas fa-lock"></i>
            <span>Créez d'abord un code PIN. <a href="/compte">Créer le PIN</a></span>
        </div>
        <% } %>
        <% if (!retraits_disponibles) { %>
        <div class="warning-card">
            <i class="fas fa-clock"></i>
            <span>Les retraits sont disponibles du <strong>lundi au samedi de 9h à 19h GMT</strong>.</span>
        </div>
        <% } %>

        <div class="info-card">
            ℹ️ Montant minimum: <strong>1 200 FCFA</strong> — Un seul retrait par 24h — Traitement sous 24h.
        </div>

        <% if (has_wallet && wallet_data) { %>
        <div class="wallet-card">
            <h3><i class="fas fa-wallet"></i> Portefeuille de destination</h3>
            <div class="wallet-row"><span class="wallet-key">Nom</span><span class="wallet-val"><%= wallet_data.nom_portefeuille %></span></div>
            <div class="wallet-row"><span class="wallet-key">Méthode</span><span class="wallet-val"><%= wallet_data.methode_paiement %></span></div>
            <div class="wallet-row"><span class="wallet-key">Numéro</span><span class="wallet-val"><%= wallet_data.numero_telephone %></span></div>
            <div class="wallet-row"><span class="wallet-key">Pays</span><span class="wallet-val"><%= wallet_data.pays %></span></div>
        </div>
        <% } %>

        <% if (has_wallet && has_transaction_password && retraits_disponibles) { %>
        <div class="form-card">
            <h3><i class="fas fa-arrow-up"></i> Effectuer un retrait</h3>
            <form action="/retrait" method="POST">
                <input type="hidden" name="demander_retrait" value="1">
                <div class="form-group">
                    <label class="form-label">Montant à retirer (FCFA)</label>
                    <input type="number" name="montant" min="1200" max="<%= solde %>" step="100"
                           placeholder="Minimum 1 200 FCFA" required class="form-input">
                </div>
                <div class="form-group">
                    <label class="form-label">Code PIN de transaction (4 chiffres)</label>
                    <input type="password" name="transaction_password" maxlength="4"
                           placeholder="****" inputmode="numeric" required class="form-input">
                </div>
                <button type="submit" class="btn-submit">
                    <i class="fas fa-paper-plane"></i> Demander le retrait
                </button>
            </form>
        </div>
        <% } %>
    </div>
</div>
</body>
</html>
