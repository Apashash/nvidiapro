<!DOCTYPE html>
<html lang="fr">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0, maximum-scale=1.0, user-scalable=no">
    <title>Retrait - Altiora Capital Africa</title>
    <link href="https://fonts.googleapis.com/css2?family=Poppins:wght@300;400;500;600;700;800&display=swap" rel="stylesheet">
    <link rel="stylesheet" href="https://cdnjs.cloudflare.com/ajax/libs/font-awesome/6.5.0/css/all.min.css">
    <style>
        * { margin:0; padding:0; box-sizing:border-box; font-family:'Poppins','Segoe UI',sans-serif; }
        body { background:#F5EFE6; color:#3D2B1F; min-height:100vh; padding-bottom:90px; }
        .container { max-width:430px; margin:0 auto; }

        .page-header {
            background: linear-gradient(135deg, #D4921F, #A0631A);
            padding: 50px 20px 28px; display:flex; align-items:center; gap:14px;
        }
        .back-btn {
            width:36px; height:36px; border-radius:50%;
            background:rgba(255,255,255,0.2); display:flex; align-items:center;
            justify-content:center; color:#fff; text-decoration:none; font-size:16px; flex-shrink:0;
        }
        .header-txt h1 { font-size:20px; font-weight:700; color:#fff; }
        .header-txt p  { font-size:13px; color:rgba(255,255,255,0.85); margin-top:2px; }

        .content { padding:16px; }

        .balance-hero {
            background: linear-gradient(135deg, #D4921F, #B07018);
            border-radius:18px; padding:22px; text-align:center;
            margin-bottom:16px; box-shadow:0 6px 20px rgba(196,125,30,0.35);
        }
        .balance-hero .lbl { color:rgba(255,255,255,0.8); font-size:12px; font-weight:600;
            text-transform:uppercase; letter-spacing:1px; margin-bottom:8px; }
        .balance-hero .amt { color:#fff; font-size:36px; font-weight:800; line-height:1; }
        .balance-hero .cur { color:rgba(255,255,255,0.8); font-size:14px; margin-top:6px; }

        .notif { padding:12px 15px; border-radius:12px; margin-bottom:14px;
            font-size:14px; display:flex; align-items:center; gap:9px; }
        .notif.error   { background:#FFF0EE; border:1px solid #F5A9A0; color:#C0392B; }
        .notif.success { background:#F0FFF4; border:1px solid #86EFAC; color:#166534; }

        .warning-card {
            background:#FFFBF0; border:1px solid #F5D78A; border-radius:12px;
            padding:13px 15px; margin-bottom:14px; font-size:13px; color:#92660A;
            display:flex; align-items:center; gap:9px;
        }
        .info-card {
            background:rgba(196,125,30,0.08); border:1px solid rgba(196,125,30,0.2);
            border-radius:12px; padding:13px 15px; margin-bottom:14px;
            font-size:13px; color:#7D5A38;
        }
        .info-card strong { color:#C47D1E; }

        .form-card {
            background:#fff; border-radius:16px; border:1px solid #F0E0C8;
            padding:18px; margin-bottom:14px; box-shadow:0 2px 10px rgba(196,125,30,0.08);
        }
        .form-card h3 { color:#C47D1E; font-size:14px; font-weight:700; margin-bottom:16px;
            display:flex; align-items:center; gap:8px; }
        .form-group { margin-bottom:14px; }
        .form-label { display:block; font-size:12px; font-weight:600; color:#A87D50; margin-bottom:6px; }
        .form-input, .form-select {
            width:100%; background:#FBF5EC; border:1.5px solid #E8D5B0;
            border-radius:11px; padding:12px 14px; color:#3D2B1F;
            font-size:14px; font-family:'Poppins',sans-serif; outline:none;
            transition:border-color 0.2s; appearance:none; -webkit-appearance:none;
        }
        .form-input:focus, .form-select:focus { border-color:#C47D1E; }
        .select-wrap { position:relative; }
        .select-wrap::after {
            content:'\f107'; font-family:'Font Awesome 6 Free'; font-weight:900;
            position:absolute; right:14px; top:50%; transform:translateY(-50%);
            color:#C47D1E; pointer-events:none;
        }

        .phone-row { display:flex; gap:8px; }
        .phone-row .indicatif-box {
            flex-shrink:0; background:#FBF5EC; border:1.5px solid #E8D5B0;
            border-radius:11px; padding:12px 14px; color:#3D2B1F; font-size:14px;
            font-weight:600; min-width:90px; text-align:center;
        }
        .phone-row .form-input { flex:1; }

        .btn-submit {
            width:100%; background:linear-gradient(135deg,#D4921F,#B07018);
            color:#fff; border:none; border-radius:12px; padding:15px;
            font-weight:700; font-size:15px; cursor:pointer; font-family:'Poppins',sans-serif;
            box-shadow:0 4px 14px rgba(196,125,30,0.35); transition:transform 0.2s, opacity 0.2s;
        }
        .btn-submit:hover { transform:translateY(-2px); }
        .btn-submit:disabled { opacity:0.6; transform:none; }

        /* Success popup */
        .popup-overlay {
            display:none; position:fixed; inset:0;
            background:rgba(0,0,0,0.5); z-index:1000;
            align-items:center; justify-content:center; padding:20px;
        }
        .popup-overlay.show { display:flex; }
        .popup-box {
            background:#fff; border-radius:20px; padding:32px 24px;
            text-align:center; width:100%; max-width:340px;
            box-shadow:0 20px 60px rgba(0,0,0,0.25);
            animation: popIn 0.3s cubic-bezier(0.34,1.56,0.64,1);
        }
        @keyframes popIn {
            from { opacity:0; transform:scale(0.8); }
            to   { opacity:1; transform:scale(1); }
        }
        .popup-icon {
            width:72px; height:72px; background:#D4921F; border-radius:50%;
            display:flex; align-items:center; justify-content:center;
            margin:0 auto 18px;
        }
        .popup-icon svg { width:36px; height:36px; }
        .popup-title { color:#D4921F; font-size:1.2rem; font-weight:800; margin-bottom:8px; }
        .popup-msg { color:#666; font-size:0.9rem; margin-bottom:22px; line-height:1.5; }
        .popup-detail {
            background:#FBF5EC; border-radius:12px; padding:14px;
            margin-bottom:20px; font-size:0.9rem;
        }
        .popup-detail .row { display:flex; justify-content:space-between; padding:4px 0; }
        .popup-detail .key { color:#A87D50; }
        .popup-detail .val { font-weight:700; color:#3D2B1F; }
        .popup-ok {
            width:100%; background:linear-gradient(135deg,#D4921F,#B07018);
            color:#fff; border:none; border-radius:12px; padding:14px;
            font-weight:700; font-size:15px; cursor:pointer;
        }
    </style>
</head>
<body>
<%- include('partials/menu', { page: 'compte' }) %>
<div class="container">
    <div class="page-header">
        <a href="/" class="back-btn"><i class="fas fa-chevron-left"></i></a>
        <div class="header-txt">
            <h1>Retrait</h1>
            <p>Retirez votre argent en toute sécurité</p>
        </div>
    </div>

    <div class="content">
        <div class="balance-hero">
            <div class="lbl">Solde disponible</div>
            <div class="amt"><%= parseFloat(solde).toLocaleString('fr-FR') %></div>
            <div class="cur">FCFA</div>
        </div>

        <div id="notif-zone"></div>

        <% if (locals.suspendu) { %>
        <div class="warning-card" style="background:#FFF0EE;border-color:#F5A9A0;color:#C0392B;">
            <i class="fas fa-ban"></i>
            <span>Le retrait est <strong>indisponible pour le moment</strong>, veuillez réessayer plus tard.</span>
        </div>
        <% } else if (!retraits_disponibles) { %>
        <div class="warning-card">
            <i class="fas fa-clock"></i>
            <span><%= locals.schedule ? schedule.message : 'Les retraits ne sont pas disponibles en ce moment.' %></span>
        </div>
        <% } %>

        <div class="info-card">
            ℹ️ Montant minimum : <strong><%= parseInt(locals.params && params.retrait_minimum ? params.retrait_minimum : 1200).toLocaleString('fr-FR') %> FCFA</strong>
            — Max <strong><%= locals.params && params.retrait_max_par_jour ? params.retrait_max_par_jour : 1 %></strong> retrait(s) / 24h
            — Traitement sous 24h.
        </div>

        <div class="form-card">
            <h3><i class="fas fa-arrow-up"></i> Informations de retrait</h3>

            <!-- Pays -->
            <div class="form-group">
                <label class="form-label">Pays</label>
                <div class="select-wrap">
                    <select id="sel-pays" class="form-select" required>
                        <option value="">-- Sélectionnez votre pays --</option>
                        <option value="Cameroun"          data-code="+237" <%= user.pays === 'Cameroun'          ? 'selected' : '' %>>🇨🇲 Cameroun (+237)</option>
                        <option value="Togo"              data-code="+228" <%= user.pays === 'Togo'              ? 'selected' : '' %>>🇹🇬 Togo (+228)</option>
                        <option value="Bénin"             data-code="+229" <%= user.pays === 'Bénin'             ? 'selected' : '' %>>🇧🇯 Bénin (+229)</option>
                        <option value="Côte d'Ivoire"      data-code="+225" <%= user.pays === "Côte d'Ivoire"      ? 'selected' : '' %>>🇨🇮 Côte d'Ivoire (+225)</option>
                        <option value="Burkina Faso"       data-code="+226" <%= user.pays === 'Burkina Faso'       ? 'selected' : '' %>>🇧🇫 Burkina Faso (+226)</option>
                        <option value="Gabon"              data-code="+241" <%= user.pays === 'Gabon'              ? 'selected' : '' %>>🇬🇦 Gabon (+241)</option>
                        <option value="Congo Brazzaville"  data-code="+242" <%= user.pays === 'Congo Brazzaville'  ? 'selected' : '' %>>🇨🇬 Congo Brazzaville (+242)</option>
                        <option value="Niger"              data-code="+227" <%= user.pays === 'Niger'              ? 'selected' : '' %>>🇳🇪 Niger (+227)</option>
                        <option value="Mali"               data-code="+223" <%= user.pays === 'Mali'               ? 'selected' : '' %>>🇲🇱 Mali (+223)</option>
                    </select>
                </div>
            </div>

            <!-- Opérateur -->
            <div class="form-group">
                <label class="form-label">Opérateur Mobile Money</label>
                <div class="select-wrap">
                    <select id="sel-operateur" class="form-select" required>
                        <option value="">-- Choisissez d'abord le pays --</option>
                    </select>
                </div>
            </div>

            <!-- Numéro -->
            <div class="form-group">
                <label class="form-label">Numéro Mobile Money</label>
                <div class="phone-row">
                    <div class="indicatif-box" id="indicatif-display">+237</div>
                    <input type="tel" id="inp-numero" class="form-input"
                           placeholder="Ex: 6XXXXXXXX" inputmode="numeric"
                           value="<%= (user.telephone || '').replace(/^\+\d+/, '') %>">
                </div>
            </div>

            <!-- Nom -->
            <div class="form-group">
                <label class="form-label">Nom complet du titulaire</label>
                <input type="text" id="inp-nom" class="form-input"
                       placeholder="Nom sur le compte Mobile Money"
                       value="<%= user.nom || '' %>">
            </div>

            <!-- Montant -->
            <div class="form-group">
                <label class="form-label">Montant à retirer (FCFA)</label>
                <input type="number" id="inp-montant" class="form-input"
                       min="<%= parseInt(locals.params && params.retrait_minimum ? params.retrait_minimum : 1200) %>" max="<%= solde %>" step="100"
                       placeholder="Minimum <%= parseInt(locals.params && params.retrait_minimum ? params.retrait_minimum : 1200).toLocaleString('fr-FR') %> FCFA" inputmode="numeric">
            </div>

            <% if (locals.fraisPourcentage > 0) { %>
            <div class="info-card" id="fee-summary" style="display:none;">
                <div style="display:flex;justify-content:space-between;margin-bottom:4px;">
                    <span>Montant demandé</span><strong id="fee-montant">—</strong>
                </div>
                <div style="display:flex;justify-content:space-between;margin-bottom:4px;color:#C0392B;">
                    <span>Frais de retrait (<span id="fee-pct"><%= fraisPourcentage %></span>%)</span><strong id="fee-frais">—</strong>
                </div>
                <div style="display:flex;justify-content:space-between;border-top:1px dashed #E8931A;padding-top:6px;">
                    <span>Vous recevrez</span><strong id="fee-net">—</strong>
                </div>
            </div>
            <% } %>

            <button class="btn-submit" id="btn-retrait" <%= !retraits_disponibles ? 'disabled' : '' %>>
                <i class="fas fa-paper-plane"></i> Demander le retrait
            </button>
        </div>
    </div>
</div>

<!-- Success popup -->
<div class="popup-overlay" id="successPopup">
    <div class="popup-box">
        <div class="popup-icon">
            <svg viewBox="0 0 24 24" fill="none" stroke="white" stroke-width="3" stroke-linecap="round" stroke-linejoin="round">
                <polyline points="20 6 9 17 4 12"/>
            </svg>
        </div>
        <div class="popup-title">Retrait envoyé avec succès !</div>
        <div class="popup-msg">Votre demande a été soumise. Elle sera traitée dans les 24h.</div>
        <div class="popup-detail">
            <div class="row"><span class="key">Montant</span><span class="val" id="pop-montant">—</span></div>
            <div class="row"><span class="key">Opérateur</span><span class="val" id="pop-operateur">—</span></div>
            <div class="row"><span class="key">Numéro</span><span class="val" id="pop-numero">—</span></div>
            <div class="row"><span class="key">Nom</span><span class="val" id="pop-nom">—</span></div>
        </div>
        <button class="popup-ok" onclick="window.location.href='/'">OK</button>
    </div>
</div>

<script>
const operateursByPays = {
    'Cameroun':          ['MTN Mobile Money', 'Orange Money'],
    'Togo':              ['Flooz (Moov)', 'T-Money'],
    'Bénin':             ['MTN Mobile Money', 'Moov Money'],
    "Côte d'Ivoire":     ['Orange Money', 'MTN Mobile Money', 'Moov Money', 'Wave'],
    'Burkina Faso':      ['Orange Money', 'Moov Money'],
    'Gabon':             ['Airtel Money', 'Moov Money'],
    'Congo Brazzaville': ['Airtel Money', 'MTN Mobile Money'],
    'Niger':             ['Airtel Money', 'Moov Money'],
    'Mali':              ['Orange Money', 'Moov Money'],
};

const fraisPourcentage = <%= locals.fraisPourcentage || 0 %>;
const feeSummary   = document.getElementById('fee-summary');
const inpMontant   = document.getElementById('inp-montant');

function updateFeeSummary() {
    if (!feeSummary) return;
    const montant = parseFloat(inpMontant.value);
    if (!montant || montant <= 0) {
        feeSummary.style.display = 'none';
        return;
    }
    const frais = Math.round((montant * fraisPourcentage / 100) * 100) / 100;
    const net = montant - frais;
    document.getElementById('fee-montant').textContent = montant.toLocaleString('fr-FR') + ' FCFA';
    document.getElementById('fee-frais').textContent = '- ' + frais.toLocaleString('fr-FR') + ' FCFA';
    document.getElementById('fee-net').textContent = net.toLocaleString('fr-FR') + ' FCFA';
    feeSummary.style.display = 'block';
}
if (inpMontant) inpMontant.addEventListener('input', updateFeeSummary);

const selPays      = document.getElementById('sel-pays');
const selOp        = document.getElementById('sel-operateur');
const indicatifBox = document.getElementById('indicatif-display');

function updateOperateurs() {
    const pays = selPays.value;
    const ops  = operateursByPays[pays] || [];
    const code = selPays.selectedOptions[0]?.dataset?.code || '';
    indicatifBox.textContent = code || '+???';
    selOp.innerHTML = ops.length
        ? ops.map(o => `<option value="${o}">${o}</option>`).join('')
        : '<option value="">-- Choisissez d\'abord le pays --</option>';
}

selPays.addEventListener('change', updateOperateurs);
// Init on load if country already selected
if (selPays.value) updateOperateurs();

document.getElementById('btn-retrait').addEventListener('click', async function () {
    const pays     = selPays.value;
    const operateur= selOp.value;
    const numero   = document.getElementById('inp-numero').value.trim();
    const nom      = document.getElementById('inp-nom').value.trim();
    const montant  = parseFloat(document.getElementById('inp-montant').value);
    const indicatif= selPays.selectedOptions[0]?.dataset?.code || '';
    const notifZone= document.getElementById('notif-zone');

    notifZone.innerHTML = '';

    if (!pays || !operateur || !numero || !nom || !montant) {
        notifZone.innerHTML = '<div class="notif error"><i class="fas fa-exclamation-circle"></i> Veuillez remplir tous les champs.</div>';
        notifZone.scrollIntoView({ behavior: 'smooth' });
        return;
    }

    this.disabled = true;
    this.innerHTML = '<i class="fas fa-spinner fa-spin"></i> Traitement...';

    try {
        const resp = await fetch('/retrait', {
            method: 'POST',
            headers: { 'Content-Type': 'application/x-www-form-urlencoded' },
            body: new URLSearchParams({ pays, operateur, numero: indicatif + numero, nom, montant }),
        });

        // If redirected to login page, session expired
        if (resp.redirected || resp.url.includes('/connexion')) {
            window.location.href = '/connexion';
            return;
        }

        const text = await resp.text();
        let data;
        try { data = JSON.parse(text); }
        catch(e) {
            // Server returned HTML (session expired or server error)
            window.location.href = '/connexion';
            return;
        }

        if (data.success) {
            const netLabel = (typeof data.frais === 'number' && data.frais > 0)
                ? `${parseInt(montant).toLocaleString('fr-FR')} FCFA (frais ${data.frais.toLocaleString('fr-FR')} FCFA, net ${data.montantNet.toLocaleString('fr-FR')} FCFA)`
                : parseInt(montant).toLocaleString('fr-FR') + ' FCFA';
            document.getElementById('pop-montant').textContent   = netLabel;
            document.getElementById('pop-operateur').textContent = operateur;
            document.getElementById('pop-numero').textContent    = indicatif + numero;
            document.getElementById('pop-nom').textContent       = nom;
            document.getElementById('successPopup').classList.add('show');
        } else {
            notifZone.innerHTML = `<div class="notif error"><i class="fas fa-exclamation-circle"></i> ${data.message}</div>`;
            notifZone.scrollIntoView({ behavior: 'smooth' });
            this.disabled = false;
            this.innerHTML = '<i class="fas fa-paper-plane"></i> Demander le retrait';
        }
    } catch (e) {
        notifZone.innerHTML = '<div class="notif error"><i class="fas fa-exclamation-circle"></i> Erreur de connexion.</div>';
        this.disabled = false;
        this.innerHTML = '<i class="fas fa-paper-plane"></i> Demander le retrait';
    }
});
</script>
</body>
</html>
