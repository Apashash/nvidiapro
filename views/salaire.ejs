<!DOCTYPE html>
<html lang="fr">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>Salaire - Altiora Capital Africa</title>
    <link href="https://fonts.googleapis.com/css2?family=Poppins:wght@300;400;500;600;700;800&display=swap" rel="stylesheet">
    <link rel="stylesheet" href="https://cdnjs.cloudflare.com/ajax/libs/font-awesome/6.5.0/css/all.min.css">
    <style>
        * { margin:0; padding:0; box-sizing:border-box; font-family:'Poppins','Segoe UI',sans-serif; }
        body { background:#F5EFE6; color:#3D2B1F; min-height:100vh; padding-bottom:90px; }
        .container { max-width:430px; margin:0 auto; }

        /* Header */
        .page-header {
            background: linear-gradient(135deg, #D4921F, #A0631A);
            padding: 50px 20px 36px; text-align:center; color:#fff; position:relative;
        }
        .page-header h1 { font-size:22px; font-weight:800; margin-bottom:4px; }
        .page-header p { font-size:13px; color:rgba(255,255,255,0.85); }

        /* VIP Salary card */
        .salary-card {
            margin: -20px 16px 0; position:relative; z-index:10;
            background:#fff; border-radius:20px;
            box-shadow:0 8px 28px rgba(196,125,30,0.20);
            padding:28px 20px; text-align:center;
            border:1px solid #F0E0C8;
        }
        .vip-badge {
            display:inline-block; background:linear-gradient(135deg,#D4921F,#B07018);
            color:#fff; padding:6px 18px; border-radius:20px;
            font-weight:700; font-size:12px; margin-bottom:16px;
            box-shadow:0 4px 12px rgba(196,125,30,0.35);
        }
        .salary-amount { font-size:44px; font-weight:900; color:#C47D1E; line-height:1.1; }
        .salary-period { color:#A87D50; font-size:14px; font-weight:500; margin-top:8px; }

        /* Content */
        .content { padding:16px; }

        .alert-box { padding:13px 16px; border-radius:12px; margin-bottom:14px;
            font-size:14px; display:flex; align-items:center; gap:9px; }
        .alert-error { background:#FFF0EE; border:1px solid #F5A9A0; color:#C0392B; }
        .alert-warning { background:#FFFBF0; border:1px solid #F5D78A; color:#92660A; }

        .btn-collect {
            width:100%; padding:18px;
            background:linear-gradient(135deg,#D4921F,#B07018);
            border:none; border-radius:16px; color:#fff;
            font-size:17px; font-weight:700; cursor:pointer;
            display:flex; align-items:center; justify-content:center; gap:12px;
            box-shadow:0 6px 20px rgba(196,125,30,0.4); transition:transform 0.2s;
            font-family:'Poppins',sans-serif; margin-bottom:16px;
        }
        .btn-collect:hover:not(:disabled) { transform:translateY(-2px); box-shadow:0 10px 26px rgba(196,125,30,0.48); }
        .btn-collect:disabled { background:#E8D5B0; color:#A87D50; cursor:not-allowed; transform:none; box-shadow:none; }

        /* Section card */
        .section-card {
            background:#fff; border-radius:16px; border:1px solid #F0E0C8;
            padding:18px; margin-bottom:14px;
            box-shadow:0 2px 10px rgba(196,125,30,0.08);
        }
        .section-title {
            color:#C47D1E; font-size:15px; font-weight:700; margin-bottom:14px;
            display:flex; align-items:center; gap:9px; padding-bottom:12px;
            border-bottom:1px solid #F0E0C8;
        }

        .niveau-item {
            display:flex; justify-content:space-between; align-items:center;
            padding:11px 0; border-bottom:1px solid #F5EFE6;
        }
        .niveau-item:last-child { border-bottom:none; }
        .niveau-info { display:flex; align-items:center; gap:12px; }
        .niveau-num {
            width:32px; height:32px; border-radius:50%;
            display:flex; align-items:center; justify-content:center;
            font-weight:800; font-size:13px; border:1.5px solid #E8D5B0;
            color:#A87D50; background:#FBF5EC;
        }
        .niveau-item.actuel .niveau-num {
            background:linear-gradient(135deg,#D4921F,#B07018);
            color:#fff; border-color:transparent;
        }
        .niveau-name { font-size:14px; color:#3D2B1F; font-weight:500; }
        .niveau-salary { font-weight:700; color:#C47D1E; font-size:14px; }
        .niveau-item.actuel .niveau-name { font-weight:700; color:#C47D1E; }

        .info-item {
            display:flex; align-items:flex-start; gap:12px; padding:10px 0;
            border-bottom:1px solid #F5EFE6;
        }
        .info-item:last-child { border-bottom:none; }
        .info-icon {
            width:36px; height:36px; border-radius:10px; flex-shrink:0;
            background:rgba(196,125,30,0.12); display:flex; align-items:center;
            justify-content:center; color:#C47D1E; font-size:15px;
        }
        .info-text { font-size:13px; color:#7D5A38; line-height:1.5; flex:1; }
        .info-text strong { color:#C47D1E; }

        /* Popup */
        .popup {
            display:none; position:fixed; inset:0;
            background:rgba(0,0,0,0.6); backdrop-filter:blur(6px);
            z-index:1000; align-items:center; justify-content:center; padding:20px;
        }
        .popup-box {
            background:#fff; max-width:360px; width:100%;
            border-radius:24px; overflow:hidden;
            box-shadow:0 24px 60px rgba(0,0,0,0.25);
            animation:popIn 0.4s cubic-bezier(0.175,0.885,0.32,1.275);
        }
        @keyframes popIn { from { transform:scale(0.85); opacity:0; } to { transform:scale(1); opacity:1; } }
        .popup-head {
            background:linear-gradient(135deg,#EF4444,#B91C1C);
            padding:20px; text-align:center;
        }
        .popup-head h3 { color:#fff; font-weight:800; font-size:18px; }
        .popup-body { padding:28px 24px; text-align:center; }
        .popup-icon { font-size:52px; color:#EF4444; margin-bottom:14px; }
        .popup-msg { font-size:14px; color:#7D5A38; line-height:1.6; margin-bottom:20px; }
        .popup-btn {
            width:100%; background:#EF4444; color:#fff; border:none;
            border-radius:12px; padding:14px; font-size:15px; font-weight:700;
            cursor:pointer; font-family:'Poppins',sans-serif;
        }
    </style>
</head>
<body>
<%- include('partials/menu', { page: 'salaire' }) %>

<div class="container">
    <div class="page-header">
        <h1><i class="fas fa-coins"></i> Salaire Quotidien</h1>
        <p>Recevez votre rémunération selon votre niveau VIP</p>
    </div>

    <div class="salary-card">
        <div class="vip-badge">NIVEAU VIP <%= niveau_actuel %></div>
        <div class="salary-amount"><%= new Intl.NumberFormat('fr-FR').format(salaire_actuel) %> FCFA</div>
        <div class="salary-period">Versement Journalier</div>
    </div>

    <div class="content">
        <% if (locals.message_erreur) { %>
            <div class="alert-box alert-error"><i class="fas fa-exclamation-circle"></i> <%= message_erreur %></div>
        <% } %>
        <% if (niveau_actuel == 0) { %>
            <div class="alert-box alert-warning"><i class="fas fa-info-circle"></i> Invitez 3 utilisateurs pour activer votre premier versement (Niveau 1)</div>
        <% } %>

        <button class="btn-collect" onclick="reclamerSalaire()" <%= (niveau_actuel == 0) ? 'disabled' : '' %>>
            <i class="fas fa-coins"></i> Récupérer Mon Salaire
        </button>

        <!-- Progression -->
        <div class="section-card">
            <div class="section-title"><i class="fas fa-chart-line"></i> Progression des Rémunérations</div>
            <% Object.entries(salaires_par_niveau).forEach(([niveau, salaire]) => { %>
            <div class="niveau-item <%= niveau == niveau_actuel ? 'actuel' : '' %>">
                <div class="niveau-info">
                    <div class="niveau-num"><%= niveau %></div>
                    <div class="niveau-name">Niveau VIP <%= niveau %></div>
                </div>
                <div class="niveau-salary"><%= new Intl.NumberFormat('fr-FR').format(salaire) %> FCFA/j</div>
            </div>
            <% }); %>
        </div>

        <!-- VIP Criteria -->
        <div class="section-card">
            <div class="section-title"><i class="fas fa-star"></i> Critères d'Accès VIP</div>
            <div class="info-item"><div class="info-icon"><i class="fas fa-user-plus"></i></div><div class="info-text"><strong>Niveau VIP 1:</strong> 3 invitations validées → 700 FCFA/jour</div></div>
            <div class="info-item"><div class="info-icon"><i class="fas fa-users"></i></div><div class="info-text"><strong>Niveau VIP 2:</strong> 7 invitations validées → 1 200 FCFA/jour</div></div>
            <div class="info-item"><div class="info-icon"><i class="fas fa-crown"></i></div><div class="info-text"><strong>Niveau VIP 3:</strong> 12 invitations validées → 4 000 FCFA/jour</div></div>
            <div class="info-item"><div class="info-icon"><i class="fas fa-star"></i></div><div class="info-text"><strong>Niveau VIP 4:</strong> 20 invitations validées → 5 000 FCFA/jour</div></div>
            <div class="info-item"><div class="info-icon"><i class="fas fa-gem"></i></div><div class="info-text"><strong>Niveau VIP 5:</strong> 40 invitations validées → 7 500 FCFA/jour</div></div>
        </div>
    </div>
</div>

<!-- Access Popup -->
<div class="popup" id="blacklistPopup">
    <div class="popup-box">
        <div class="popup-head"><h3>ACCÈS RESTREINT</h3></div>
        <div class="popup-body">
            <div class="popup-icon"><i class="fas fa-ban"></i></div>
            <div class="popup-msg">
                <%= locals.message_blacklist || "Votre accès a été temporairement restreint. Veuillez contacter le support technique Altiora Capital Africa." %>
            </div>
            <button class="popup-btn" onclick="closePopup()"><i class="fas fa-headset"></i> Contacter le Support</button>
        </div>
    </div>
</div>

<script>
function reclamerSalaire() { document.getElementById('blacklistPopup').style.display = 'flex'; }
function closePopup() {
    document.getElementById('blacklistPopup').style.display = 'none';
    window.open('https://t.me/blackrock_support', '_blank');
}
window.onclick = function(e) {
    const popup = document.getElementById('blacklistPopup');
    if (e.target === popup) closePopup();
};
document.addEventListener('wheel', e => { if (e.ctrlKey) e.preventDefault(); }, { passive: false });
document.addEventListener('gesturestart', e => e.preventDefault());
</script>
</body>
</html>
