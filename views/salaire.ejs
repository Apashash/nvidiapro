<!DOCTYPE html>
<html lang="fr">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0, maximum-scale=1.0, user-scalable=no">
    <title>Salaire - Altiora Capital Africa</title>
    <link href="https://fonts.googleapis.com/css2?family=Poppins:wght@300;400;500;600;700;800&display=swap" rel="stylesheet">
    <link rel="stylesheet" href="https://cdnjs.cloudflare.com/ajax/libs/font-awesome/6.5.0/css/all.min.css">
    <style>
        * { margin:0; padding:0; box-sizing:border-box; font-family:'Poppins','Segoe UI',sans-serif; }
        body { background:#F5EFE6; color:#3D2B1F; min-height:100vh; padding-bottom:90px; }
        .container { max-width:430px; margin:0 auto; }

        .page-header {
            background:linear-gradient(135deg,#D4921F,#A0631A);
            padding:50px 20px 36px; text-align:center; color:#fff;
        }
        .page-header h1 { font-size:22px; font-weight:800; margin-bottom:4px; }
        .page-header p  { font-size:13px; color:rgba(255,255,255,0.85); }

        /* Salary hero card */
        .salary-card {
            margin:-20px 16px 0; position:relative; z-index:10;
            background:#fff; border-radius:20px;
            box-shadow:0 8px 28px rgba(196,125,30,0.20);
            padding:28px 20px; text-align:center;
            border:1px solid #F0E0C8;
        }
        .vip-badge {
            display:inline-block; background:linear-gradient(135deg,#D4921F,#B07018);
            color:#fff; padding:6px 18px; border-radius:20px;
            font-weight:700; font-size:12px; margin-bottom:16px;
            box-shadow:0 4px 12px rgba(196,125,30,0.35);
        }
        .salary-amount { font-size:44px; font-weight:900; color:#C47D1E; line-height:1.1; }
        .salary-period { color:#A87D50; font-size:14px; font-weight:500; margin-top:8px; }

        .content { padding:16px; margin-top:20px; }

        /* Alerts */
        .alert-box { padding:13px 16px; border-radius:12px; margin-bottom:14px;
            font-size:14px; display:flex; align-items:center; gap:9px; }
        .alert-error   { background:#FFF0EE; border:1px solid #F5A9A0; color:#C0392B; }
        .alert-warning { background:#FFFBF0; border:1px solid #F5D78A; color:#92660A; }
        .alert-success { background:#F0FFF4; border:1px solid #86EFAC; color:#166534; }

        /* Collect button */
        .btn-collect {
            width:100%; padding:18px;
            background:linear-gradient(135deg,#D4921F,#B07018);
            border:none; border-radius:16px; color:#fff;
            font-size:17px; font-weight:700; cursor:pointer;
            display:flex; align-items:center; justify-content:center; gap:12px;
            box-shadow:0 6px 20px rgba(196,125,30,0.4); transition:transform 0.2s;
            font-family:'Poppins',sans-serif; margin-bottom:16px;
        }
        .btn-collect:hover:not(:disabled) { transform:translateY(-2px); box-shadow:0 10px 26px rgba(196,125,30,0.48); }
        .btn-collect:disabled { background:#E8D5B0; color:#A87D50; cursor:not-allowed; transform:none; box-shadow:none; }

        /* Section cards */
        .section-card {
            background:#fff; border-radius:16px; border:1px solid #F0E0C8;
            padding:18px; margin-bottom:14px;
            box-shadow:0 2px 10px rgba(196,125,30,0.08);
        }
        .section-title {
            color:#C47D1E; font-size:15px; font-weight:700; margin-bottom:14px;
            display:flex; align-items:center; gap:9px; padding-bottom:12px;
            border-bottom:1px solid #F0E0C8;
        }

        /* Palier progress cards */
        .palier-card {
            background:#fff; border-radius:16px; border:1px solid #F0E0C8;
            padding:16px; margin-bottom:12px;
            box-shadow:0 2px 10px rgba(196,125,30,0.08);
            position:relative; overflow:hidden;
            transition:box-shadow 0.2s;
        }
        .palier-card.unlocked {
            border-color:#C47D1E;
            box-shadow:0 4px 16px rgba(196,125,30,0.18);
        }
        .palier-card.actuel {
            border-color:#D4921F;
            background:linear-gradient(135deg,#FFFBF3,#FFF5E0);
            box-shadow:0 6px 22px rgba(196,125,30,0.22);
        }
        .palier-card.locked { opacity:0.65; }
        .palier-card.paid {
            border-color:#16A34A;
            background:linear-gradient(135deg,#F3FBF5,#EAFBEF);
            box-shadow:0 4px 16px rgba(22,163,74,0.14);
        }

        /* Top row: badge + salary */
        .palier-top {
            display:flex; align-items:center; justify-content:space-between;
            margin-bottom:12px;
        }
        .palier-left { display:flex; align-items:center; gap:10px; }
        .palier-num {
            width:36px; height:36px; border-radius:50%; flex-shrink:0;
            display:flex; align-items:center; justify-content:center;
            font-weight:800; font-size:14px;
            background:#F0E0C8; color:#A87D50; border:2px solid #E8D5B0;
        }
        .palier-card.unlocked .palier-num,
        .palier-card.actuel   .palier-num {
            background:linear-gradient(135deg,#D4921F,#B07018);
            color:#fff; border-color:transparent;
        }
        .palier-card.paid .palier-num {
            background:linear-gradient(135deg,#16A34A,#15803D);
            color:#fff; border-color:transparent;
        }
        .palier-label { font-size:14px; font-weight:700; color:#3D2B1F; }
        .palier-card.actuel .palier-label { color:#C47D1E; }
        .palier-sublabel { font-size:11px; color:#A87D50; margin-top:1px; }

        .palier-salary {
            font-size:15px; font-weight:800; color:#C47D1E;
            white-space:nowrap;
        }
        .palier-card.locked .palier-salary { color:#B0926A; }
        .palier-card.paid .palier-salary { color:#15803D; }

        /* Progress bar */
        .palier-prog-row {
            display:flex; align-items:center; justify-content:space-between;
            margin-bottom:6px;
        }
        .palier-prog-lbl { font-size:11px; color:#7D5A38; }
        .palier-prog-cnt { font-size:12px; font-weight:700; color:#C47D1E; }
        .palier-bar-bg {
            background:#F0E0C8; border-radius:20px; height:10px; overflow:hidden;
        }
        .palier-bar-fill {
            height:100%; border-radius:20px;
            background:linear-gradient(90deg,#D4921F,#B07018);
            transition:width 1s cubic-bezier(.4,0,.2,1);
        }
        .palier-card.unlocked .palier-bar-fill { background:linear-gradient(90deg,#16A34A,#15803D); }

        /* Status badge */
        .palier-status {
            margin-top:8px; font-size:11px; font-weight:600;
            display:flex; align-items:center; gap:5px;
        }
        .palier-status.done    { color:#16A34A; }
        .palier-status.paid    { color:#15803D; }
        .palier-status.current { color:#C47D1E; }
        .palier-status.locked  { color:#A87D50; }

        /* Filleul dots */
        .filleul-dots {
            display:flex; flex-wrap:wrap; gap:7px; margin-top:10px;
        }
        .dot-item {
            display:flex; flex-direction:column; align-items:center; gap:3px;
            width:46px;
        }
        .dot-avatar {
            width:38px; height:38px; border-radius:50%;
            display:flex; align-items:center; justify-content:center;
            font-weight:700; font-size:13px; color:#fff; position:relative;
        }
        .dot-avatar.actif   { background:linear-gradient(135deg,#D4921F,#B07018); }
        .dot-avatar.inactif { background:#E8D5B0; color:#A87D50; }
        .dot-check {
            position:absolute; bottom:-2px; right:-2px;
            width:14px; height:14px; border-radius:50%;
            background:#16A34A; border:2px solid #fff;
            display:flex; align-items:center; justify-content:center;
        }
        .dot-check i { font-size:7px; color:#fff; }
        .dot-name {
            font-size:9px; color:#7D5A38; text-align:center;
            white-space:nowrap; overflow:hidden; text-overflow:ellipsis; width:100%;
        }
        .dot-empty {
            width:38px; height:38px; border-radius:50%;
            background:#F5EFE6; border:2px dashed #E8D5B0;
            display:flex; align-items:center; justify-content:center;
            color:#C8A87A; font-size:13px;
        }

        /* Success popup */
        .popup {
            display:none; position:fixed; inset:0;
            background:rgba(0,0,0,0.6); backdrop-filter:blur(6px);
            z-index:1000; align-items:center; justify-content:center; padding:20px;
        }
        .popup-box {
            background:#fff; max-width:360px; width:100%;
            border-radius:24px; overflow:hidden;
            box-shadow:0 24px 60px rgba(0,0,0,0.25);
            animation:popIn 0.4s cubic-bezier(0.175,0.885,0.32,1.275);
        }
        @keyframes popIn { from{transform:scale(0.85);opacity:0;} to{transform:scale(1);opacity:1;} }
        .popup-head-success { background:linear-gradient(135deg,#D4921F,#B07018); padding:20px; text-align:center; }
        .popup-head-success h3 { color:#fff; font-weight:800; font-size:18px; }
        .popup-body { padding:28px 24px; text-align:center; }
        .popup-icon { font-size:52px; color:#C47D1E; margin-bottom:14px; }
        .popup-msg  { font-size:14px; color:#7D5A38; line-height:1.6; margin-bottom:20px; }
        .popup-btn  {
            width:100%; background:linear-gradient(135deg,#D4921F,#B07018);
            color:#fff; border:none; border-radius:12px; padding:14px;
            font-size:15px; font-weight:700; cursor:pointer; font-family:'Poppins',sans-serif;
        }
    </style>
</head>
<body>
<%- include('partials/menu', { page: 'salaire' }) %>

<div class="container">
    <div class="page-header">
        <h1><i class="fas fa-coins"></i> Salaire Quotidien</h1>
        <p>Recevez votre rémunération selon votre niveau VIP</p>
    </div>

    <!-- Hero salary card -->
    <div class="salary-card">
        <div class="vip-badge">NIVEAU VIP <%= niveau_actuel %></div>
        <div class="salary-amount"><%= new Intl.NumberFormat('fr-FR').format(salaire_actuel) %> FCFA</div>
        <div class="salary-period">Versement unique à l'atteinte du palier</div>
    </div>

    <div class="content">

        <% if (locals.message_erreur) { %>
            <div class="alert-box alert-error"><i class="fas fa-exclamation-circle"></i> <%= message_erreur %></div>
        <% } %>

        <%
          // success message set after POST redirect
          const successMontant = locals.salaire_success;
        %>
        <% if (successMontant) { %>
            <div class="alert-box alert-success"><i class="fas fa-check-circle"></i>
                <strong><%= new Intl.NumberFormat('fr-FR').format(successMontant) %> FCFA</strong> versés dans votre portefeuille !
            </div>
        <% } %>

        <% if (niveau_actuel === 0) { %>
            <div class="alert-box alert-warning"><i class="fas fa-info-circle"></i>
                Atteignez le niveau VIP 1 en invitant <strong><%= filleuls_requis %></strong> filleuls actifs pour débloquer votre salaire.
            </div>
        <% } else if (deja_reclame) { %>
            <div class="alert-box alert-warning"><i class="fas fa-info-circle"></i>
                Vous avez déjà reçu le salaire du palier VIP <%= niveau_actuel %>. Chaque palier n'est payé qu'une seule fois — progressez au niveau suivant pour débloquer un nouveau salaire.
            </div>
        <% } %>

        <!-- Collect button -->
        <form method="POST" action="/salaire">
            <button type="submit" class="btn-collect"
                <%= (!seuil_atteint || deja_reclame || niveau_actuel === 0) ? 'disabled' : '' %>>
                <i class="fas fa-coins"></i>
                <% if (deja_reclame) { %>
                    Salaire déjà reçu pour ce palier
                <% } else if (!seuil_atteint) { %>
                    Débloquez votre salaire
                <% } else { %>
                    Récupérer Mon Salaire
                <% } %>
            </button>
        </form>

        <!-- Per-palier progress cards -->
        <div style="margin-bottom:4px;">
            <div style="font-size:13px;color:#A87D50;font-weight:600;margin-bottom:12px;display:flex;align-items:center;gap:7px;">
                <i class="fas fa-trophy" style="color:#C47D1E;"></i> Progression par palier VIP
            </div>

            <% paliers.forEach(function(p) {
                const req      = parseInt(p.filleuls_requis) || 1;
                const filled   = Math.min(filleuls_actifs, req);
                const pct      = Math.round(filled / req * 100);
                const done     = filleuls_actifs >= req;
                const isCur    = p.niveau == niveau_actuel;
                const isPaid   = niveaux_reclames.includes(p.niveau);
                const cardCls  = isPaid ? 'paid' : (done ? 'unlocked' : (isCur ? 'actuel' : 'locked'));
                // Dots: show actual filleuls up to req, then empty slots
                const dotsFilleuls = filleuls_directs.slice(0, req);
                const emptySlots   = Math.max(0, req - filleuls_directs.length);
            %>
            <div class="palier-card <%= cardCls %>">

                <!-- Top: num + label + salary -->
                <div class="palier-top">
                    <div class="palier-left">
                        <div class="palier-num"><%= p.niveau %></div>
                        <div>
                            <div class="palier-label"><%= p.label || ('Niveau VIP ' + p.niveau) %></div>
                            <div class="palier-sublabel"><i class="fas fa-users" style="font-size:9px"></i> <%= req %> filleul(s) actif(s) requis</div>
                        </div>
                    </div>
                    <div class="palier-salary"><%= new Intl.NumberFormat('fr-FR').format(parseFloat(p.montant_cadeau)) %> FCFA</div>
                </div>

                <!-- Progress bar -->
                <div class="palier-prog-row">
                    <div class="palier-prog-lbl">Filleuls actifs</div>
                    <div class="palier-prog-cnt"><%= filled %> / <%= req %></div>
                </div>
                <div class="palier-bar-bg">
                    <div class="palier-bar-fill" style="width:<%= pct %>%"></div>
                </div>

                <!-- Status -->
                <% if (isPaid) { %>
                <div class="palier-status paid"><i class="fas fa-check-double"></i> Salaire déjà versé (une seule fois par palier)</div>
                <% } else if (done) { %>
                <div class="palier-status done"><i class="fas fa-check-circle"></i> Débloqué — salaire disponible !</div>
                <% } else if (isCur) { %>
                <div class="palier-status current"><i class="fas fa-clock"></i> En cours — encore <%= req - filleuls_actifs %> filleul(s)</div>
                <% } else { %>
                <div class="palier-status locked"><i class="fas fa-lock"></i> Verrouillé — <%= req - filleuls_actifs %> filleul(s) manquants</div>
                <% } %>

                <!-- Filleul avatars (only show for current + unlocked) -->
                <% if (cardCls !== 'locked' || done || isCur) { %>
                <div class="filleul-dots">
                    <% dotsFilleuls.forEach(function(f) { %>
                    <div class="dot-item">
                        <div class="dot-avatar <%= f.actif ? 'actif' : 'inactif' %>">
                            <%= (f.nom || '?').charAt(0).toUpperCase() %>
                            <% if (f.actif) { %><div class="dot-check"><i class="fas fa-check"></i></div><% } %>
                        </div>
                        <div class="dot-name"><%= (f.nom || '').split(' ')[0] %></div>
                    </div>
                    <% }); %>
                    <% for (let i = 0; i < emptySlots; i++) { %>
                    <div class="dot-item">
                        <div class="dot-empty"><i class="fas fa-user-plus"></i></div>
                        <div class="dot-name" style="color:#C8A87A">Inviter</div>
                    </div>
                    <% } %>
                </div>
                <% } %>

            </div>
            <% }); %>

            <% if (!paliers.length) { %>
            <div style="text-align:center;color:#A87D50;font-size:13px;padding:20px 0;background:#fff;border-radius:16px;border:1px solid #F0E0C8;">
                Aucun palier configuré.
            </div>
            <% } %>
        </div>

    </div>
</div>

<script>
// Show success popup if salary was just claimed
<% if (successMontant) { %>
document.addEventListener('DOMContentLoaded', function() {
    document.getElementById('successPopup').style.display = 'flex';
});
<% } %>
function closeSuccess() {
    document.getElementById('successPopup').style.display = 'none';
}
document.addEventListener('wheel', e => { if (e.ctrlKey) e.preventDefault(); }, { passive:false });
document.addEventListener('gesturestart', e => e.preventDefault());
</script>

<!-- Success popup -->
<% if (successMontant) { %>
<div class="popup" id="successPopup">
    <div class="popup-box">
        <div class="popup-head-success"><h3>🎉 SALAIRE REÇU !</h3></div>
        <div class="popup-body">
            <div class="popup-icon"><i class="fas fa-coins"></i></div>
            <div class="popup-msg">
                Félicitations ! <strong><%= new Intl.NumberFormat('fr-FR').format(successMontant) %> FCFA</strong>
                ont été versés dans votre portefeuille.<br><br>Ce palier est maintenant soldé — invitez plus de filleuls actifs pour débloquer le prochain palier VIP et son salaire.
            </div>
            <button class="popup-btn" onclick="closeSuccess()"><i class="fas fa-check"></i> Super, merci !</button>
        </div>
    </div>
</div>
<% } %>

</body>
</html>
