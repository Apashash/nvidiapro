<!DOCTYPE html>
<html lang="fr">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0, maximum-scale=1.0, user-scalable=no">
    <title>NVIDIA Technologie</title>
    <link href="https://fonts.googleapis.com/css2?family=Poppins:wght@300;400;500;600;700;800&display=swap" rel="stylesheet">
    <link rel="stylesheet" href="https://cdnjs.cloudflare.com/ajax/libs/font-awesome/6.5.0/css/all.min.css">
    <style>
        * { margin:0; padding:0; box-sizing:border-box; -webkit-tap-highlight-color:transparent; }
        html, body { height:100%; overflow-x:hidden; font-family:'Poppins',sans-serif; }
        body { background:#F5EFE6; min-height:100vh; display:flex; flex-direction:column; }

        /* Full-height hero */
        .hero {
            min-height: 55vh;
            background: linear-gradient(to bottom, rgba(20,12,0,0.55) 0%, rgba(90,50,5,0.65) 100%),
                        url('https://images.unsplash.com/photo-1536657464919-892534f60d6e?w=800&q=80') center/cover no-repeat;
            display: flex; flex-direction:column; align-items:center; justify-content:center;
            padding: 40px 24px;
            text-align: center;
            position: relative;
        }
        .hero-logo {
            width:80px; height:80px; border-radius:50%;
            background: linear-gradient(135deg, #D4921F, #B07018);
            display:flex; align-items:center; justify-content:center;
            box-shadow: 0 0 0 5px rgba(255,255,255,0.25), 0 12px 32px rgba(0,0,0,0.45);
            margin-bottom:16px;
        }
        .hero-logo i { font-size:36px; color:#fff; }
        .hero h1 { font-size:32px; font-weight:800; color:#fff; letter-spacing:0.5px; text-shadow:0 2px 10px rgba(0,0,0,0.5); }
        .hero p { font-size:14px; color:rgba(255,255,255,0.88); margin-top:6px; text-shadow:0 1px 4px rgba(0,0,0,0.4); }

        /* Slide indicators */
        .slide-dots { display:flex; gap:8px; justify-content:center; margin-top:20px; }
        .dot { width:8px; height:8px; border-radius:50%; background:rgba(255,255,255,0.4); transition:all 0.3s; }
        .dot.active { background:#fff; width:24px; border-radius:4px; }

        .referral-notice {
            background:rgba(212,146,31,0.85); border-radius:12px; padding:12px 20px;
            display:flex; align-items:center; gap:10px; margin-top:16px; color:#fff;
            font-size:13px; font-weight:500; backdrop-filter:blur(4px);
        }

        /* Bottom card */
        .bottom-card {
            background:#fff; border-radius:28px 28px 0 0; margin-top:-28px;
            padding:32px 24px 40px;
            box-shadow: 0 -8px 32px rgba(196,125,30,0.10);
        }
        .tagline { font-size:13px; color:#A87D50; margin-bottom:24px; text-align:center; }

        .stats-row { display:flex; gap:12px; margin-bottom:28px; }
        .stat-item {
            flex:1; background:#FBF5EC; border:1px solid #E8D5B0;
            border-radius:14px; padding:14px; text-align:center;
        }
        .stat-item .sv { font-size:20px; font-weight:800; color:#C47D1E; }
        .stat-item .sl { font-size:11px; color:#A87D50; margin-top:2px; font-weight:500; }

        .btn-register-main {
            display:block; width:100%; padding:17px; text-align:center;
            background:linear-gradient(135deg, #D4921F, #B07018);
            border-radius:16px; font-size:17px; font-weight:700;
            color:#fff; text-decoration:none;
            box-shadow:0 6px 20px rgba(196,125,30,0.4);
            transition:transform 0.2s;
            font-family:'Poppins',sans-serif;
        }
        .btn-register-main:hover { transform:translateY(-2px); }

        .divider { display:flex; align-items:center; gap:12px; margin:18px 0; }
        .divider hr { flex:1; border:none; border-top:1px solid #E8D5B0; }
        .divider span { color:#A87D50; font-size:13px; }

        .btn-login {
            display:block; width:100%; padding:15px; text-align:center;
            background:#FBF5EC; border:1.5px solid #E8D5B0;
            border-radius:16px; font-size:15px; font-weight:600;
            color:#C47D1E; text-decoration:none; font-family:'Poppins',sans-serif;
            transition:background 0.2s;
        }
        .btn-login:hover { background:#F5E8D5; }
    </style>
</head>
<body>
    <div class="hero">
        <div class="hero-logo"><i class="fas fa-wheat-awn"></i></div>
        <h1>NVIDIA</h1>
        <p>Votre Plateforme d'Investissement Premium</p>
        <div class="slide-dots">
            <div class="dot active" id="d0"></div>
            <div class="dot" id="d1"></div>
            <div class="dot" id="d2"></div>
        </div>
        <% if (typeof code_parrain !== 'undefined' && code_parrain) { %>
            <div class="referral-notice"><i class="fas fa-user-friends"></i> Vous êtes invité par un partenaire NVIDIA</div>
        <% } %>
    </div>

    <div class="bottom-card">
        <div class="tagline">Investissez dans l'avenir avec des rendements journaliers</div>

        <div class="stats-row">
            <div class="stat-item">
                <div class="sv">250</div>
                <div class="sl">Bonus FCFA</div>
            </div>
            <div class="stat-item">
                <div class="sv">20%</div>
                <div class="sl">Commission</div>
            </div>
            <div class="stat-item">
                <div class="sv">11</div>
                <div class="sl">Plans VIP</div>
            </div>
        </div>

        <a href="/inscription1<% if (typeof code_parrain !== 'undefined' && code_parrain) { %>?p=<%= code_parrain %><% } %>" class="btn-register-main">
            <i class="fas fa-leaf"></i> Rejoindre l'Innovation
        </a>

        <div class="divider"><hr><span>déjà membre?</span><hr></div>

        <a href="/connexion" class="btn-login"><i class="fas fa-sign-in-alt"></i> Se Connecter</a>
    </div>

    <script>
        let slide = 0;
        const dots = [document.getElementById('d0'), document.getElementById('d1'), document.getElementById('d2')];
        setInterval(() => {
            dots[slide].classList.remove('active');
            slide = (slide + 1) % 3;
            dots[slide].classList.add('active');
        }, 3000);
    </script>
</body>
</html>
